{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

<div class="video-section">
  <div class="container">
    <div class="border-wrapper {% if section.settings.border_top %}border-wrapper--top{% endif %} {% if section.settings.border_bottom %}border-wrapper--bottom{% endif %}">
      <noscript>
        <div
          class="video-section__media color-inverse"
          {% if section.settings.cover_image != blank %}
            style="padding-bottom: {{ 1 | divided_by: section.settings.cover_image.aspect_ratio | times: 100 }}%;"
          {% endif %}
        >
          <a
            href="{{ section.settings.video_url }}"
            class="video-section__poster media media--transparent{% if section.settings.cover_image == blank %} video-section__placeholder{% endif %}"
          >
            {%- if section.settings.cover_image != blank -%}
              <img
                srcset="
                  {%- if section.settings.cover_image.width >= 375 -%}{{ section.settings.cover_image | img_url: '375x' }} 375w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 750 -%}{{ section.settings.cover_image | img_url: '750x' }} 750w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 1100 -%}{{ section.settings.cover_image | img_url: '1100x' }} 1100w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 1500 -%}{{ section.settings.cover_image | img_url: '1500x' }} 1500w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 1780 -%}{{ section.settings.cover_image | img_url: '1780x' }} 1780w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 2000 -%}{{ section.settings.cover_image | img_url: '2000x' }} 2000w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 3000 -%}{{ section.settings.cover_image | img_url: '3000x' }} 3000w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 3840 -%}{{ section.settings.cover_image | img_url: '3840x' }} 3840w,{%- endif -%}
                  {{ section.settings.cover_image | img_url: 'master' }} {{ section.settings.cover_image.width }}w
                "
                src="{{ section.settings.cover_image | img_url: '1920x' }}"
                sizes="{% if section.settings.full_width %}100vw{% else %}(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 10rem), 100vw{% endif %}"
                alt="{{ section.settings.description | escape }}"
                loading="lazy"
                width="{{ section.settings.cover_image.width }}"
                height="{{ section.settings.cover_image.height }}"
              >
            {%- else -%}
              {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {%- endif -%}

            <div class="video-section__content">
              {%- if section.settings.round_stamp_enable -%}
                <div class="video-section__play motion-reduce">
                  {% render 'round-stamp-play' %}
                </div>
              {%- endif -%}
              <div class="subtitle">
                {{ section.settings.sub_title }}
              </div>

              <h2 class="title title--section ">{{ section.settings.heading }}</h2>
            </div>
          </a>
        </div>
      </noscript>
      <deferred-media
        class="video-section__media video-section__media--{{ section.settings.video_fit }} deferred-media color-inverse no-js-hidden video-section__media--{%- if section.settings.video_autoplay -%}autoplay{%- endif -%}"
        data-media-id="{{ section.settings.video_url.id }}"
        {%- if section.settings.video_autoplay -%}
          data-autoplay="true"
        {%- endif -%}
        style="aspect-ratio: {{ section.settings.aspect_ratio }}"
      >
        {%- if section.settings.video_autoplay != true -%}
          <button
            id="Deferred-Poster-Modal-{{ section.settings.video_url.id }}"
            class="video-section__poster media deferred-media__poster media--landscape"
            type="button"
          >
            {%- if section.settings.cover_image != blank -%}
              <img
                srcset="
                  {%- if section.settings.cover_image.width >= 375 -%}{{ section.settings.cover_image | img_url: '375x' }} 375w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 750 -%}{{ section.settings.cover_image | img_url: '750x' }} 750w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 1100 -%}{{ section.settings.cover_image | img_url: '1100x' }} 1100w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 1500 -%}{{ section.settings.cover_image | img_url: '1500x' }} 1500w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 1780 -%}{{ section.settings.cover_image | img_url: '1780x' }} 1780w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 2000 -%}{{ section.settings.cover_image | img_url: '2000x' }} 2000w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 3000 -%}{{ section.settings.cover_image | img_url: '3000x' }} 3000w,{%- endif -%}
                  {%- if section.settings.cover_image.width >= 3840 -%}{{ section.settings.cover_image | img_url: '3840x' }} 3840w,{%- endif -%}
                  {{ section.settings.cover_image | img_url: 'master' }} {{ section.settings.cover_image.width }}w
                "
                src="{{ section.settings.cover_image | img_url: '1920x' }}"
                sizes="{% if section.settings.full_width %}100vw{% else %}(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 10rem), 100vw{% endif %}"
                alt="{{ 'sections.video.load_video' | t: description: section.settings.description | escape }}"
                loading="lazy"
                width="{{ section.settings.cover_image.width }}"
                height="{{ section.settings.cover_image.height }}"
              >
            {%- else -%}
              {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {%- endif -%}
            <div class="video-section__content">
              {%- if section.settings.round_stamp_enable -%}
                <div class="video-section__play motion-reduce">
                  {% render 'round-stamp-play' %}
                </div>
              {%- endif -%}

              <div class="subtitle">
                {{ section.settings.sub_title }}
              </div>

              <h2 class="title title--section ">{{ section.settings.heading }}</h2>
            </div>
          </button>
        {%- endif -%}
        <template>
          {%- if section.settings.video == null and section.settings.video_url != null -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe
                src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?enablejsapi=1&autoplay=1{%- if section.settings.video_autoplay -%}&mute=1{%- endif -%}{%- if section.settings.video_autoplay != true and section.settings.video_muted -%}&mute=1{%- endif -%}{%- if section.settings.video_controls != true -%}&controls=0{%- endif -%}{%- if section.settings.video_loop -%}&playlist={{ section.settings.video_url.id }}&loop=1{%- endif -%}"
                class="js-youtube"
                allow="autoplay; encrypted-media"
                allowfullscreen
                title="{{ section.settings.description | escape }}"
              ></iframe>
            {%- else -%}
              <iframe
                src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?&autoplay=true{%- if section.settings.video_autoplay -%}&muted=true{%- endif -%}{%- if section.settings.video_autoplay != true and section.settings.video_muted -%}&muted=true{%- endif -%}{%- if section.settings.video_controls != true -%}&controls=false{%- endif -%}{%- if section.settings.video_loop -%}&loop=true{%- endif -%}"
                class="js-vimeo"
                allow="autoplay; encrypted-media"
                allowfullscreen
                title="{{ section.settings.description | escape }}"
              ></iframe>
            {%- endif -%}
          {%- else -%}
            {% liquid
              assign muted = section.settings.video_muted
              assign playsinline = false
              assign autoPlay = false
              if section.settings.video_autoplay
                assign autoPlay = autoPlay
                assign muted = true
                assign playsinline = playsinline
              endif
            %}
            {{
              section.settings.video
              | video_tag:
                image_size: '1300x',
                autoPlay: autoPlay,
                muted: muted,
                playsInline: playsinline,
                loop: section.settings.video_loop,
                controls: section.settings.video_controls
            }}
          {% endif %}
        </template>
      </deferred-media>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.video.name",
  "tag": "section",
  "class": "spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "select",
      "id": "video_fit",
      "label": "t:sections.video.settings.video_fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.video.settings.video_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.video.settings.video_fit.options__2.label"
        }
      ],
      "default": "contain",
      "info": "t:sections.video.settings.video_fit.info"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.video.settings.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.video.settings.aspect_ratio.options__2.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.video.settings.aspect_ratio.options__3.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.video.settings.aspect_ratio.options__4.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.video.settings.aspect_ratio.options__5.label"
        }
      ],
      "default": "16/9",
      "label": "t:sections.video.settings.aspect_ratio.label"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "t:sections.video.settings.heading.default",
      "label": "t:sections.video.settings.heading.label"
    },
    {
      "type": "text",
      "id": "sub_title",
      "default": "t:sections.video.settings.sub_title.default",
      "label": "t:sections.video.settings.sub_title.label"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.video.settings.cover_image.label"
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__1.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video.settings.video.label"
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__2.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.video.settings.paragraph.content"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc",
      "label": "t:sections.video.settings.video_url.label",
      "info": "t:sections.video.settings.video_url.info"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.video.settings.description.label",
      "info": "t:sections.video.settings.description.info"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "default": false,
      "label": "t:sections.video.settings.video_autoplay.label"
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "default": false,
      "label": "t:sections.video.settings.video_loop.label"
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "default": false,
      "label": "t:sections.video.settings.video_muted.label",
      "info": "t:sections.video.settings.video_muted.info"
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "default": true,
      "label": "t:sections.video.settings.video_controls.label"
    },
    {
      "type": "checkbox",
      "id": "round_stamp_enable",
      "default": true,
      "label": "t:sections.video.settings.round_stamp_enable.label"
    },
    {
      "type": "text",
      "id": "round_stamp_text",
      "default": "stockholm ~ stockholm ~",
      "label": "t:sections.video.settings.round_stamp_text.label"
    },
    {
      "type": "number",
      "id": "round_stamp_width",
      "default": 140,
      "label": "t:sections.video.settings.round_stamp_width.label",
      "info": "t:sections.video.settings.round_stamp_width.info"
    },
    {
      "type": "number",
      "id": "round_stamp_size",
      "default": 50,
      "label": "t:sections.video.settings.round_stamp_size.label",
      "info": "t:sections.video.settings.round_stamp_size.info"
    },
    {
      "type": "number",
      "id": "round_stamp_letter_spacing",
      "default": 8,
      "label": "t:sections.video.settings.round_stamp_letter_spacing.label"
    },
    {
      "type": "checkbox",
      "id": "border_top",
      "default": false,
      "label": "t:sections.video.settings.border_top.label"
    },
    {
      "type": "checkbox",
      "id": "border_bottom",
      "default": false,
      "label": "t:sections.video.settings.border_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.video.presets.name"
    }
  ]
}
{% endschema %}
