<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-badge.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'template-collection.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-badge.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'template-collection.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-collection-products-text.css' | asset_url | stylesheet_tag }}

<div class="collection-products-text collection--products container">
	<div class="border-wrapper {% if section.settings.border_top %}border-wrapper--top{% endif %} {% if section.settings.border_bottom %}border-wrapper--bottom{% endif %}">
		<div class="collection-products-text__wrapper collection-products-text__wrapper--{{ section.settings.text_align }}">
			{%- if section.settings.sub_title != blank -%}
				<div class="subtitle">
					{{ section.settings.sub_title }}
				</div>
			{%- endif -%}

			<div class="collection-products-text__column">
				{%- if section.settings.title_number != blank or section.settings.title != blank -%}
					<h2 class="{% if section.settings.title_size == 'h2' %} h2 {% else %} h3{% endif %} collection-products-text__title title--section title--section-mt-none">

						{%- unless section.settings.title_number == blank -%}
							<span class="number" style="font-size: {{ section.settings.title_number_size }}px">{{ section.settings.title_number | escape }}</span>
						{%- endunless -%}

						{%- if section.settings.title != blank -%}
							<span class="text">{{ section.settings.title }}</span>
						{%- endif -%}
					</h2>
				{%- endif -%}

				{%- if section.settings.text_information != blank or section.settings.show_view_all and section.settings.button_order == 'above' -%}
					<div class="collection-products-text__information">
						{%- if section.settings.text_information != blank -%}
							<p class="collection-products-text__text">{{ section.settings.text_information | escape }}</p>
						{%- endif -%}

						{%- if section.settings.show_view_all and section.settings.button_order == 'above' -%}
							<a {% if section.settings.collection.url != blank %} href="{{ section.settings.collection.url }}"{% endif %} class="button collection-products-text__button button--arrow button--{{ section.settings.button_style }}" {% if section.settings.collection.url == blank %}aria-disabled="true"{% endif %}>
								<span>{{ section.settings.button_label | escape }}</span> {% render 'icon-button-arrow' %}
							</a>
						{%- endif -%}
					</div>
				{%- endif -%}
			</div>
		</div>

		{%- liquid
			assign products_to_display = section.settings.collection.all_products_count

			if section.settings.collection.all_products_count > section.settings.products_to_show
				assign products_to_display = section.settings.products_to_show
			endif %}

		<slider-component class="slider-mobile-gutter">
			<ul class="collection-product-list collection-product-list--{{ section.settings.columns_mobile }}-mobile 
				row {% if section.settings.columns_mobile == '2' %} row-cols-2 {% else %} row-cols-1 {% endif %} row-cols-sm-2  row-cols-lg-4 row-cols-xl-{{ section.settings.products_to_show_row }} {% if section.settings.swipe_on_mobile %} slider slider--tablet{% endif %}" id="Slider-{{ section.id }}" role="list">
				{%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
					<li class="collection-product-card{% if section.settings.collection.all_products_count > 2 and section.settings.swipe_on_mobile and section.settings.products_to_show > 2 %} slider__slide{% endif %} {%- if settings.quickview_hover -%}quickview--hover{% endif %}">
						{% render 'product-card',
							product_card_product: product,
							media_size: section.settings.image_ratio,
							show_secondary_image: section.settings.show_secondary_image,
							add_image_padding: section.settings.add_image_padding,
							show_desc: section.settings.show_desc,
							show_vendor: section.settings.show_vendor,
							show_sku: section.settings.show_sku %}
					</li>
				{%- else -%}
					{%- for i in (1..4) -%}
						<li class="collection-product-card">
							{% render 'product-card-placeholder', index: forloop.index %}
						</li>
					{%- endfor -%}
				{%- endfor -%}
			</ul>
			{%- if section.settings.collection.all_products_count > 2 and section.settings.swipe_on_mobile and section.settings.products_to_show > 2 -%}
				<div class="slider-buttons no-js-hidden{% if section.settings.collection.all_products_count < 4 %} medium-hide{% endif %}{% if section.settings.collection.all_products_count < 3 %} small-hide{% endif %}">
					<button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'accessibility.previous_slide' | t }}">{% render 'icon-caret-left' %}</button>
					<div class="slider-counter caption">
						<span class="slider-counter--current">1</span>
						<span aria-hidden="true"> / </span>
						<span class="visually-hidden">{{ 'accessibility.of' | t }}</span>
						<span class="slider-counter--total">{{ products_to_display }}</span>
					</div>
					<button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'accessibility.next_slide' | t }}">{% render 'icon-caret-right' %}</button>
				</div>
			{%- endif -%}
		</slider-component>

		{%- if section.settings.show_view_all and section.settings.button_order == 'under' -%}
			<div class="center">
				<a {% if section.settings.collection.url != blank %} href="{{ section.settings.collection.url }}"{% endif %} class="button collection-products-text__button button--arrow button--{{ section.settings.button_style }}" {% if section.settings.collection.url == blank %}aria-disabled="true"{% endif %}>
					<span>{{ section.settings.button_label | escape }}</span> {% render 'icon-button-arrow' %}
				</a>
			</div>
		{%- endif -%}
	</div>
</div>

{% schema %}
{
	"name": "t:sections.featured-collection.name",
	"tag": "section",
	"class": "featured-collection-section spaced-section",
	"enabled_on": {
    "templates": ["*"]
  },
	"settings": [
		{
			"type": "text",
			"id": "title",
			"default": "t:sections.featured-collection.settings.title.default",
			"label": "t:sections.featured-collection.settings.title.label"
		},
		{
			"type": "select",
			"id": "title_size",
			"options": [
				{
					"value": "h2",
					"label": "t:sections.featured-collection.settings.title_size.options__1.label"
				},
				{
					"value": "h3",
					"label": "t:sections.featured-collection.settings.title_size.options__2.label"
				}
			],
			"default": "h2",
			"label": "t:sections.featured-collection.settings.title_size.label"
		},
		{
			"type": "text",
			"id": "title_number",
			"default": "30",
			"label": "t:sections.featured-collection.settings.title_number.label",
			"info": "t:sections.featured-collection.settings.title_number.info"
		},
		{
			"type": "number",
			"id": "title_number_size",
			"default": 100,
			"label": "t:sections.featured-collection.settings.title_number_size.label"
		},
		{
			"type": "text",
			"id": "sub_title",
			"default": "t:sections.featured-collection.settings.sub_title.default",
			"label": "t:sections.featured-collection.settings.sub_title.label"
		},
		{
			"type": "text",
			"id": "text_information",
			"default": "t:sections.featured-collection.settings.text_information.default",
			"label": "t:sections.featured-collection.settings.text_information.label"
		},
		{
			"type": "select",
			"id": "text_align",
			"options": [
				{
					"value": "left",
					"label": "t:sections.featured-collection.settings.text_align.options__1.label"
				},
				{
					"value": "center",
					"label": "t:sections.featured-collection.settings.text_align.options__2.label"
				}
			],
			"default": "left",
			"label": "t:sections.featured-collection.settings.text_align.label"
		},
		{
			"type": "checkbox",
			"id": "show_view_all",
			"default": true,
			"label": "t:sections.featured-collection.settings.show_view_all.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "t:sections.featured-collection.settings.button_label.default",
			"label": "t:sections.featured-collection.settings.button_label.label"
		},
		{
			"type": "select",
			"id": "button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.featured-collection.settings.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.featured-collection.settings.button_style.options__2.label"
				}
			],
			"default": "primary",
			"label": "t:sections.featured-collection.settings.button_style.label"
		},
		{
			"type": "select",
			"id": "button_order",
			"options": [
				{
					"value": "above",
					"label": "t:sections.featured-collection.settings.button_order.options__1.label"
				},
				{
					"value": "under",
					"label": "t:sections.featured-collection.settings.button_order.options__2.label"
				}
			],
			"default": "above",
			"label": "t:sections.featured-collection.settings.button_order.label"
		},
		{
			"type": "collection",
			"id": "collection",
			"label": "t:sections.featured-collection.settings.collection.label"
		},
		{
			"type": "range",
			"id": "products_to_show",
			"min": 2,
			"max": 100,
			"step": 2,
			"default": 4,
			"label": "t:sections.featured-collection.settings.products_to_show.label"
		},
		{
			"type": "range",
			"id": "products_to_show_row",
			"min": 2,
			"max": 6,
			"step": 2,
			"default": 4,
			"label": "t:sections.featured-collection.settings.products_to_show_row.label"
		},
		{
			"type": "checkbox",
			"id": "swipe_on_mobile",
			"default": false,
			"label": "t:sections.featured-collection.settings.swipe_on_mobile.label"
		},
		{
			"type": "checkbox",
			"id": "border_top",
			"default": true,
			"label": "t:sections.featured-collection.settings.border_top.label"
		},
		{
			"type": "checkbox",
			"id": "border_bottom",
			"default": false,
			"label": "t:sections.featured-collection.settings.border_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.featured-collection.settings.header.content"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"options": [
				{
					"value": "adapt",
					"label": "t:sections.featured-collection.settings.image_ratio.options__1.label"
				},
				{
					"value": "portrait",
					"label": "t:sections.featured-collection.settings.image_ratio.options__2.label"
				},
				{
					"value": "square",
					"label": "t:sections.featured-collection.settings.image_ratio.options__3.label"
				}
			],
			"default": "portrait",
			"label": "t:sections.featured-collection.settings.image_ratio.label"
		},
		{
			"type": "checkbox",
			"id": "show_secondary_image",
			"default": false,
			"label": "t:sections.featured-collection.settings.show_secondary_image.label"
		},
		{
			"type": "checkbox",
			"id": "show_vendor",
			"default": false,
			"label": "t:sections.featured-collection.settings.show_vendor.label"
		},
		{
			"type": "checkbox",
			"id": "show_sku",
			"default": false,
			"label": "t:sections.featured-collection.settings.show_sku.label"
		},
		{
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_desc.label",
      "info": "t:sections.featured-collection.settings.show_desc.info"
    },
		{
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header_mobile.content"
    },
		{
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    }
	],
	"presets": [
		{
			"name": "t:sections.featured-collection.presets.name"
		}
	]
}
{% endschema %}
