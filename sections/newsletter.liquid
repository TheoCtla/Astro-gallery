{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

<div class="newsletter{% if section.settings.full_width == false %} newsletter--narrow container{% endif %}">
	<div class="newsletter__wrapper color-{{ section.settings.color_scheme }} {%- if section.settings.image != blank -%}newsletter__wrapper--image{%- endif -%}">
		<div class="newsletter__item">
			<div class="newsletter__inner">
				<h2 class="h2 title--section title--section-m-none ">{{ section.settings.heading | escape }}</h2>
			</div>
			<div class="newsletter__inner">
				<div class="newsletter__form">
					{% form 'customer', class: 'newsletter-form' %}
						<div class="newsletter-form__inner color-background-1">
							<input type="hidden" name="contact[tags]" value="newsletter">
							<div class="newsletter-form__field-wrapper">
								<div class="field">
									<input
										id="NewsletterForm--{{ section.id }}"
										type="email"
										dir="ltr"
										name="contact[email]"
										class="field__input"
										value="{{ form.email }}"
										aria-required="true"
										autocorrect="off"
										autocapitalize="off"
										autocomplete="email"
										{% if form.errors %}
											autofocus
											aria-invalid="true"
											aria-describedby="Newsletter-error--{{ section.id }}"
										{% elsif form.posted_successfully? %}
											aria-describedby="Newsletter-success--{{ section.id }}"
										{% endif %}
										placeholder="{{ 'newsletter.label' | t }}"
										required
									>
									<label class="field__label" for="NewsletterForm--{{ section.id }}" type="hidden">
										{{ 'newsletter.label' | t }}
									</label>
								</div>
								{%- if form.errors -%}
									<small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">{% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
								{%- endif -%}
							</div>
							<button type="submit" class="newsletter__button button button--small" name="commit">
								{{ 'newsletter.button_label' | t }}
							</button>
						</div>
						{%- if form.posted_successfully? -%}
							<h3 class="newsletter-form__message newsletter-form__message--success form__message" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>{% render 'icon-success' %}{{ 'newsletter.success' | t }}</h3>
						{%- endif -%}
					{% endform %}
				</div>
				<div class="newsletter__subheading rte{% if settings.rte_type == 'custom' %} rte__container{% endif %}">{{ section.settings.newsletter_text }}</div>
			</div>
		</div>
		{%- if section.settings.image != blank -%}
			<div class="newsletter__image">
				<img srcset="{%- if section.settings.image.width >= 375 -%}{{ section.settings.image | img_url: '375x' }} 375w,{%- endif -%}
        {%- if section.settings.image.width >= 750 -%}{{ section.settings.image | img_url: '750x' }} 750w,{%- endif -%}
        {%- if section.settings.image.width >= 1100 -%}{{ section.settings.image | img_url: '1100x' }} 1100w,{%- endif -%}
        {%- if section.settings.image.width >= 1300 -%}{{ section.settings.image | img_url: '1355x' }} 1355w,{%- endif -%}
        {%- if section.settings.image.width >= 1780 -%}{{ section.settings.image | img_url: '1780x' }} 1780w,{%- endif -%}
        {%- if section.settings.image.width >= 2000 -%}{{ section.settings.image | img_url: '2000x' }} 2000w,{%- endif -%}
        {%- if section.settings.image.width >= 2700 -%}{{ section.settings.image | img_url: '2736x' }} 2736w{%- endif -%}"
						 src="{{ section.settings.image | img_url: '1355x' }}"
						 loading="lazy"
						 alt="{{ section.settings.image.alt | escape }}"
						 width="{{ section.settings.image.width }}"
						 height="{{ section.settings.image.height }}"
				>
			</div>
		{%- endif -%}
	</div>
</div>

{% schema %}
{
	"name": "t:sections.newsletter.name",
	"tag": "section",
	"class": "spaced-section spaced-section--full-width",
	"enabled_on": {
    "templates": ["*"]
  },
	"settings": [
		{
			"type": "select",
			"id": "color_scheme",
			"options": [
				{
					"value": "background-w",
					"label": "t:sections.newsletter.settings.color_scheme.options__1.label"
				},
				{
					"value": "background-2",
					"label": "t:sections.newsletter.settings.color_scheme.options__2.label"
				},
				{
					"value": "inverse",
					"label": "t:sections.newsletter.settings.color_scheme.options__3.label"
				}
			],
			"default": "background-2",
			"label": "t:sections.newsletter.settings.color_scheme.label"
		},
		{
			"type": "text",
			"id": "heading",
			"default": "t:sections.newsletter.settings.heading.default",
			"label": "t:sections.newsletter.settings.heading.label"
		},
		{
			"type": "richtext",
			"id": "newsletter_text",
			"default": "t:sections.newsletter.settings.newsletter_text.default",
			"label": "t:sections.newsletter.settings.newsletter_text.label"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:sections.newsletter.settings.image.label"
		},
		{
			"type": "checkbox",
			"id": "full_width",
			"default": true,
			"label": "t:sections.newsletter.settings.full_width.label"
		},
		{
			"type": "paragraph",
			"content": "t:sections.newsletter.settings.paragraph.content"
		}
	],
	 "presets": [
    {
      "name": "t:sections.newsletter.presets.name"
    }
  ]
}
{% endschema %}
