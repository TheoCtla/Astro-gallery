{{ 'page-installments.css' | asset_url | stylesheet_tag }}
{{ 'component-breadcrumb.css' | asset_url | stylesheet_tag }}

<div class="installments-page">
  {%- render 'breadcrumb',
      parent_url: '/products/solo',
      parent_label: "L'Œuvre Astrale",
      current: section.settings.breadcrumb_label
  -%}

  <!-- Header -->
  <div class="installments-header">
    <h1 class="installments-header__title">{{ section.settings.title }}</h1>
    <div class="installments-header__subtitle">{{ section.settings.subtitle }}</div>
  </div>

  <!-- Content -->
  <div class="installments-content">
    <!-- Image -->
    <div class="installments-content__image">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 600 }}"
          alt="{{ section.settings.image.alt | default: 'Illustration' | escape }}"
          loading="lazy"
          width="600"
          height="{{ 600 | divided_by: section.settings.image.aspect_ratio | round }}"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    <!-- Form -->
    <div class="installments-content__form">
      <div class="installments-form__success" id="InstallmentsFormSuccess" style="display: none;">
        {{ section.settings.success_message }}
      </div>

      <form id="InstallmentsForm" class="installments-form" novalidate>
        <div class="installments-form__error" id="InstallmentsFormError" style="display: none;">
          {{ section.settings.error_message }}
        </div>

        <div class="installments-form__row">
          <div class="installments-form__field">
            <label for="InstallmentsForm-nom">{{ section.settings.label_nom }} <span class="installments-form__required">*</span></label>
            <input type="text" id="InstallmentsForm-nom" name="nom" placeholder="..." autocomplete="family-name" required aria-required="true">
          </div>
          <div class="installments-form__field">
            <label for="InstallmentsForm-prenom">{{ section.settings.label_prenom }} <span class="installments-form__required">*</span></label>
            <input type="text" id="InstallmentsForm-prenom" name="prenom" placeholder="..." autocomplete="given-name" required aria-required="true">
          </div>
        </div>

        <div class="installments-form__row">
          <div class="installments-form__field">
            <label for="InstallmentsForm-email">{{ section.settings.label_email }} <span class="installments-form__required">*</span></label>
            <input type="email" id="InstallmentsForm-email" name="email" placeholder="..." autocomplete="email" required aria-required="true">
          </div>
          <div class="installments-form__field">
            <label for="InstallmentsForm-phone">{{ section.settings.label_phone }}</label>
            <input type="tel" id="InstallmentsForm-phone" name="telephone" placeholder="..." autocomplete="tel">
          </div>
        </div>

        <div class="installments-form__field installments-form__field--full">
          <label for="InstallmentsForm-message">{{ section.settings.label_message }} <span class="installments-form__required">*</span></label>
          <textarea id="InstallmentsForm-message" name="message" rows="6" placeholder="..." required aria-required="true"></textarea>
        </div>

        <div class="installments-form__submit">
          <button type="submit" class="installments-form__button">
            <span>{{ section.settings.button_text }}</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var GOOGLE_SHEETS_WEBHOOK = 'https://script.google.com/macros/s/AKfycbxfQsxKh36E5fIUVN2fsaOF9AvQ7CqkoBSyCuLrAXuXryrn1OWbgNejWP0PXhdQ2bbjng/exec';

  const form = document.getElementById('InstallmentsForm');
  if (!form) return;

  const successEl = document.getElementById('InstallmentsFormSuccess');
  const errorEl = document.getElementById('InstallmentsFormError');
  const submitBtn = form.querySelector('button[type="submit"]');

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    if (form.dataset.submitting === 'true') return;

    if (errorEl) errorEl.style.display = 'none';

    let hasError = false;

    form.querySelectorAll('[required]').forEach(function(field) {
      const wrapper = field.closest('.installments-form__field');
      field.classList.remove('installments-form__input--error');
      if (wrapper) {
        const msg = wrapper.querySelector('.installments-form__error-message');
        if (msg) msg.remove();
      }

      if (!field.value.trim() || (field.type === 'email' && !field.validity.valid)) {
        hasError = true;
        field.classList.add('installments-form__input--error');
        if (wrapper && !wrapper.querySelector('.installments-form__error-message')) {
          const errorMsg = document.createElement('span');
          errorMsg.className = 'installments-form__error-message';
          errorMsg.textContent = field.type === 'email' ? 'Veuillez entrer un e-mail valide.' : 'Ce champ est obligatoire.';
          wrapper.appendChild(errorMsg);
        }
      }
    });

    if (hasError) {
      form.querySelector('.installments-form__input--error').focus();
      return;
    }

    form.dataset.submitting = 'true';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.6';
      submitBtn.style.cursor = 'wait';
    }

    var sheetData = {
      nom: form.querySelector('[name="nom"]').value.trim(),
      prenom: form.querySelector('[name="prenom"]').value.trim(),
      email: form.querySelector('[name="email"]').value.trim(),
      telephone: form.querySelector('[name="telephone"]').value.trim(),
      message: form.querySelector('[name="message"]').value.trim()
    };

    fetch(GOOGLE_SHEETS_WEBHOOK, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(sheetData)
    })
      .then(function() {
        form.style.display = 'none';
        if (successEl) {
          successEl.style.display = 'block';
          successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      })
      .catch(function() {
        if (errorEl) errorEl.style.display = 'block';
        form.dataset.submitting = 'false';
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '';
          submitBtn.style.cursor = '';
        }
      });
  });

  form.querySelectorAll('[required]').forEach(function(field) {
    field.addEventListener('input', function() {
      if (field.value.trim() && (field.type !== 'email' || field.validity.valid)) {
        field.classList.remove('installments-form__input--error');
        const wrapper = field.closest('.installments-form__field');
        if (wrapper) {
          const msg = wrapper.querySelector('.installments-form__error-message');
          if (msg) msg.remove();
        }
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Paiement plusieurs fois",
  "tag": "section",
  "class": "installments-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "En-tête"
    },
    {
      "type": "text",
      "id": "breadcrumb_label",
      "default": "Payer en plusieurs fois",
      "label": "Breadcrumb label"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Demandez votre Œuvre Astrale en plusieurs fois sans frais",
      "label": "Titre principal"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "default": "<p>Le paiement en 4× ou 10× sans frais sera disponible très prochainement. Remplissez ce formulaire pour être contacté(e) en priorité dès son activation et bénéficier de votre œuvre à 72,50 €/mois sur 4 mois ou 29 €/mois sur 10 mois, sans aucun frais supplémentaire.</p>",
      "label": "Sous-titre"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Illustration"
    },
    {
      "type": "header",
      "content": "Labels du formulaire"
    },
    {
      "type": "text",
      "id": "label_nom",
      "default": "Nom",
      "label": "Label - Nom"
    },
    {
      "type": "text",
      "id": "label_prenom",
      "default": "Prénom",
      "label": "Label - Prénom"
    },
    {
      "type": "text",
      "id": "label_email",
      "default": "E-mail",
      "label": "Label - Email"
    },
    {
      "type": "text",
      "id": "label_phone",
      "default": "Numéro de téléphone",
      "label": "Label - Téléphone"
    },
    {
      "type": "text",
      "id": "label_message",
      "default": "Des questions sur le paiement en plusieurs fois ?",
      "label": "Label - Message"
    },
    {
      "type": "text",
      "id": "button_text",
      "default": "ÊTRE CONTACTÉ(E) EN PRIORITÉ",
      "label": "Texte du bouton"
    },
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "text",
      "id": "success_message",
      "default": "Merci pour votre demande ! Nous vous contacterons en priorité dès l'activation du paiement en plusieurs fois pour finaliser votre commande. À très vite.",
      "label": "Message de succès"
    },
    {
      "type": "text",
      "id": "error_message",
      "default": "Une erreur est survenue. Veuillez réessayer.",
      "label": "Message d'erreur"
    }
  ],
  "presets": [
    {
      "name": "Paiement plusieurs fois"
    }
  ]
}
{% endschema %}
