<style>
  .about-cta-banner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    background-color: #F1EEE5;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
    position: relative;
  }

  .about-cta-banner__container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .about-cta-banner__heading {
    font-family: 'Lemon Milk', sans-serif;
    font-weight: 400;
    font-size: 13px;
    letter-spacing: -0.5px;
    text-transform: uppercase;
    color: #1D1D1B;
    line-height: 1.7;
    margin: 0;
  }

  .about-cta-banner__right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .about-cta-banner__text {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: #1D1D1B;
    line-height: 1.6;
    margin: 0;
    text-align: center;
  }

  .about-cta-banner__btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #DFBE71;
    color: #1D1D1B;
    border: none;
    padding: 0.8rem 2rem;
    text-decoration: none;
    font-family: 'Lemon Milk', sans-serif;
    font-weight: 400;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    white-space: nowrap;
  }

  .about-cta-banner__btn-text {
    position: relative;
    z-index: 1;
    padding: 0 0.5rem;
  }

  .about-cta-banner__btn::before,
  .about-cta-banner__btn::after {
    content: '';
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    background-color: #1D1D1B;
    border-radius: 50%;
    z-index: 2;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .about-cta-banner__btn::before {
    left: 0.8rem;
  }

  .about-cta-banner__btn::after {
    right: 0.8rem;
  }

  @media (hover: hover) and (pointer: fine) {
    .about-cta-banner__btn:hover {
      padding-right: 2.5rem;
    }

    .about-cta-banner__btn:hover::after {
      content: '\2192';
      width: auto;
      height: auto;
      background: none;
      border-radius: 0;
      font-size: 14px;
      line-height: 1;
      color: #1D1D1B;
    }
  }

  /* Tablet */
  @media (min-width: 750px) {
    .about-cta-banner {
      padding: 3rem 3rem;
    }

    .about-cta-banner__container {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
      text-align: left;
    }

    .about-cta-banner__left {
      flex: 1;
    }

    .about-cta-banner__right {
      flex: 1;
      align-items: center;
    }

    .about-cta-banner__heading {
      font-size: 14px;
    }

    .about-cta-banner__text {
      font-size: 14px;
    }

    .about-cta-banner__btn {
      font-size: 10px;
      padding: 0.9rem 2.2rem;
    }
  }

  .about-cta-banner__text-line1 {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: #1D1D1B;
    line-height: 1.6;
  }

  .about-cta-banner__text-line2 {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: #1D1D1B;
    line-height: 1.6;
  }

  /* Desktop */
  @media (min-width: 990px) {
    .about-cta-banner {
      min-height: 277px;
      padding: 0 4rem;
      margin-bottom: 5rem;
      display: flex;
      align-items: center;
    }

    .about-cta-banner__container {
      gap: 4rem;
    }

    .about-cta-banner__heading {
      font-size: 22px;
      line-height: 150%;
    }

    .about-cta-banner__text-line1 {
      font-size: 16px;
    }

    .about-cta-banner__text-line2 {
      font-size: 16px;
    }

    .about-cta-banner__btn {
      font-size: 11px;
      padding: 1rem 2.5rem;
    }
  }
</style>

<div class="about-cta-banner"
  {% if section.settings.background_image != blank %}
    style="background-image: url('{{ section.settings.background_image | image_url: width: 1600 }}');"
  {% endif %}
>
  <div class="about-cta-banner__container">
    <div class="about-cta-banner__left">
      {% if section.settings.heading != blank %}
        <h2 class="about-cta-banner__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="about-cta-banner__right">
      <p class="about-cta-banner__text">
        {% if section.settings.text_line1 != blank %}
          <span class="about-cta-banner__text-line1">{{ section.settings.text_line1 }}</span><br>
        {% endif %}
        {% if section.settings.text_line2 != blank %}
          <span class="about-cta-banner__text-line2">{{ section.settings.text_line2 }}</span>
        {% endif %}
      </p>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn-gold">
          <span class="btn-gold__text">{{ section.settings.button_label }}</span>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bandeau CTA",
  "tag": "section",
  "class": "about-cta-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre (accroche gauche)",
      "default": "OFFREZ À VOTRE INTÉRIEUR UNE ŒUVRE PERSONNELLE, NUMÉROTÉE ET CERTIFIÉE ORIGINALE."
    },
    {
      "type": "text",
      "id": "text_line1",
      "label": "Texte droite - ligne 1 (petite)",
      "default": "Créez dès maintenant la vôtre"
    },
    {
      "type": "text",
      "id": "text_line2",
      "label": "Texte droite - ligne 2 (grande)",
      "default": "et donnez vie à votre thème natal."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "CRÉER MON ŒUVRE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    }
  ],
  "presets": [
    {
      "name": "Bandeau CTA"
    }
  ]
}
{% endschema %}
