<style>
  .hps {
    padding: 80px 1.5rem;
    background-color: #FFFFFF;
  }

  .hps__container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  /* ===== Header ===== */
  .hps__title {
    font-family: 'Lemon Milk', 'LEMONMILK-Regular', sans-serif;
    font-weight: 400;
    font-size: clamp(24px, 3.5vw, 26px);
    line-height: 150%;
    letter-spacing: -0.5px;
    color: #1D1D1B;
    text-transform: uppercase;
    margin: 0 0 0.5rem 0;
  }

  .hps__title-highlight {
    color: #DFBE71;
  }

  .hps__subtitle {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: clamp(18px, 2.5vw, 18px);
    color: #1D1D1B;
    line-height: 160%;
    margin: 0 0 1rem 0;
  }

  .hps__made-in {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 14px;
    color: #1D1D1B;
    margin: 0 0 2.5rem 0;
  }

  .hps__flag {
    width: 30px;
    height: 4px;
    display: inline-block;
  }

  /* ===== Visibility helpers ===== */
  .hps__mobile-only {
    display: block;
  }

  .hps__desktop-only {
    display: none;
  }

  /* ===== Tabs (product images) ===== */
  .hps__tabs {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin: 0 0 0;
    position: relative;
  }

  .hps__tab {
    cursor: pointer;
    position: relative;
    width: 260px;
    max-width: 40%;
    opacity: 0.5;
    transition: opacity 0.4s ease;
    background: none;
    border: none;
    padding: 0;
  }

  .hps__tab.is-active {
    opacity: 1;
  }

  .hps__tab img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .hps__tab-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid #1D1D1B;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hps__tab-icon svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #1D1D1B;
    stroke-width: 1.5;
  }

  .hps__tab:not(.is-active) .hps__tab-icon {
    display: none;
  }

  /* ===== Arrow separator ===== */
  .hps__arrow-separator {
    position: relative;
    width: 100%;
    margin: 1.5rem 0;
    height: 15px;
  }

  .hps__arrow-separator::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background-color: #1D1D1B;
  }

  .hps__arrow-chevron {
    position: absolute;
    top: 0px;
    transition: left 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(-50%);
    line-height: 0;
  }

  .hps__arrow-chevron svg {
    width: 22px;
    height: 12px;
    display: block;
  }

  /* ===== Panels ===== */
  .hps__panels {
    position: relative;
    overflow: hidden;
  }

  .hps__panel {
    display: none;
    animation: hpsFadeIn 0.4s ease;
  }

  .hps__panel.is-active {
    display: block;
  }


  @keyframes hpsFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* --- Panel: Frame --- */
  .hps__panel-frame {
    display: none;
    text-align: left;
    position: relative;
  }

  .hps__panel-frame.is-active {
    display: flex;
    flex-direction: column;
  }

  .hps__panel-frame-left {
    display: contents;
  }

  .hps__panel-frame-text {
    padding: 1.5rem;
  }

  .hps__panel-frame-title {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 140%;
    color: #1D1D1B;
    margin: 0 0 1rem 0;
  }

  .hps__panel-frame-desc {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 600;
    line-height: 170%;
    color: #1D1D1B;
    margin: 0 0 0.5rem 0;
  }

  .hps__panel-frame-details {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 400;
    line-height: 170%;
    color: #1D1D1B;
    margin: 0 0 0.8rem 0;
  }

  .hps__panel-made-in {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 13px;
    color: #1D1D1B;
    margin: 0;
  }

  .hps__panel-made-in .hps__flag {
    width: 30px;
    height: 4px;
  }

  .hps__panel-frame-bottom {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }

  .hps__panel-frame-secondary {
    overflow: hidden;
    width: 100%;
  }

  .hps__panel-frame-secondary img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hps__panel-frame-stamp {
    width: 120px;
    height: 120px;
    position: relative;
    flex-shrink: 0;
    overflow: hidden;
    display: none;
  }

  .hps__panel-frame-stamp svg {
    width: 100%;
    height: 100%;
    display: block;
    fill: #DFBE71;
    animation: hpsStampRotate 20s infinite linear;
  }

  .hps__panel-frame-stamp svg text {
    font-family: 'Poppins', sans-serif;
    font-size: 42px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  @keyframes hpsStampRotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .hps__panel-frame-image {
    width: 100%;
    aspect-ratio: 721 / 370;
    overflow: hidden;
  }

  .hps__panel-frame-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- Panel: Book --- */
  .hps__panel-book {
    display: none;
    text-align: left;
  }

  .hps__panel-book.is-active {
    display: flex;
    flex-direction: column;
  }

  .hps__panel-book-img-main {
    overflow: hidden;
  }

  .hps__panel-book-img-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hps__panel-book-img-secondary {
    overflow: hidden;
  }

  .hps__panel-book-img-secondary img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top;
    display: block;
  }

  .hps__panel-book-right {
    padding: 1.5rem;
  }

  .hps__panel-book-content {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .hps__panel-book-title {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 140%;
    color: #1D1D1B;
    margin: 0;
  }

  .hps__panel-book-desc {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 170%;
    color: #1D1D1B;
    margin: 0;
  }

  /* ===== Panel separator (mobile) ===== */
  .hps__panel-separator {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 2rem 0;
  }

  .hps__panel-separator-line {
    position: absolute;
    top: 50%;
    left: -1.5rem;
    right: -1.5rem;
    height: 1px;
    background-color: #D6D1CE;
  }

  .hps__panel-separator-icon {
    position: relative;
    z-index: 1;
    background: #FFFFFF;
    padding: 0 0.5rem;
  }

  .hps__panel-separator-icon img {
    width: 50px;
    height: 50px;
    object-fit: contain;
    display: block;
  }

  /* ===== CTA ===== */
  .hps__cta {
    margin-top: 2.5rem;
    text-align: center;
  }

  /* ===== Responsive — Mobile (<750px) ===== */
  @media (max-width: 749px) {
    .hps__body {
      border: 1px solid #D6D1CE;
      padding: 1.5rem;
    }

    .hps__panels {
      overflow: visible;
    }

    .hps__tab[data-tab="book"] {
      display: none;
    }

    .hps__tab {
      width: 65%;
      max-width: 65%;
      opacity: 1;
    }

    .hps__tab-icon {
      display: none;
    }

    .hps__arrow-separator {
      display: none;
    }

    .hps__panel-frame {
      display: flex !important;
      flex-direction: column;
    }

    .hps__panel-book {
      display: flex !important;
      flex-direction: column;
      position: relative;
    }

    .hps__panel-book-right {
      display: contents;
    }

    .hps__panel-book-tab-image {
      order: 0;
      width: 65%;
      margin: 0 auto 1rem;
    }

    .hps__panel-book-tab-image img {
      width: 100%;
      height: auto;
      object-fit: contain;
      display: block;
    }

    .hps__panel-book-img-secondary {
      display: none;
    }

    .hps__panel-book-img-secondary img {
      object-fit: contain;
      object-position: center;
    }

    .hps__panel-book-content {
      order: 2;
      padding: 0 1rem 1rem;
    }

    .hps__panel-book-img-main {
      order: 3;
      width: 100%;
      height: 215px;
      overflow: hidden;
      margin-bottom: 2.5rem;
    }

    .hps__panel-book-img-main img {
      height: 100%;
      object-fit: cover;
    }

    .hps__panel-book-img-bottom {
      order: 5;
      width: 100%;
      height: 215px;
      overflow: hidden;
    }

    .hps__panel-book-img-bottom img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .hps__panel-book-right .hps__panel-frame-stamp {
      display: block;
      position: absolute;
      right: 1rem;
      z-index: 2;
      width: 120px;
      height: 120px;
      order: 4;
    }

    .hps__panel-frame.is-active {
      position: relative;
    }


    .hps__panel-frame-left {
      display: contents;
    }

    .hps__panel-frame-text {
      order: 1;
    }

    .hps__panel-frame-bottom {
      align-items: stretch;
      gap: 0;
      display: contents;
    }

    .hps__panel-frame-image {
      height: 215px;
      aspect-ratio: auto;
      order: 2;
      margin-bottom: 2rem;
    }

    .hps__panel-frame-secondary {
      width: 100%;
      height: 215px;
      order: 3;
    }

    .hps__panel-frame-secondary img {
      height: 100%;
      object-fit: cover;
    }

    .hps__panel-frame-stamp {
      display: block;
      position: absolute;
      bottom: 215px;
      right: 1rem;
      transform: translateY(50%);
      z-index: 2;
      width: 120px;
      height: 120px;
    }
  }

  /* ===== Responsive — Images height scaling (350px–749px) ===== */
  @media (min-width: 350px) and (max-width: 749px) {
    .hps__panel-book-img-main,
    .hps__panel-book-img-bottom,
    .hps__panel-frame-image,
    .hps__panel-frame-secondary {
      height: clamp(215px, 45vw, 350px);
    }

    .hps__panel-book-img-main img {
      object-position: center 35%;
    }

    .hps__panel-book-img-bottom img {
      object-position: center 30%;
    }

    .hps__panel-frame-image img {
      object-position: center 40%;
    }

    .hps__panel-frame-secondary img {
      object-position: center 30%;
    }
  }

  /* ===== Responsive — Tablet (750px) ===== */
  @media (min-width: 750px) {
    .hps {
      padding: 80px 2rem;
    }

    .hps__mobile-only {
      display: none;
    }

    .hps__desktop-only {
      display: block;
    }

    .hps__tab {
      width: auto;
    }

    .hps__tab img {
      height: clamp(120px, 16vw, 200px);
      width: auto;
      object-fit: contain;
    }

    .hps__tab[data-tab="book"] img {
      height: clamp(150px, 20vw, 250px);
    }

    .hps__panel-frame.is-active {
      display: flex !important;
      flex-direction: row;
      gap: 2rem;
    }

    .hps__panel-frame-left {
      width: 50%;
      flex-shrink: 0;
    }

    .hps__panel-frame-stamp {
      display: block;
    }

    .hps__panel-frame-bottom {
      align-items: flex-end;
      gap: 1rem;
    }

    .hps__panel-frame-secondary {
      width: 120%;
    }

    .hps__panel-frame-text {
      padding: 1.5rem 4rem 1rem 0;
    }

    .hps__panel-frame-image {
      width: 50%;
      flex-shrink: 0;
      aspect-ratio: auto;
      min-height: 300px;
    }

    .hps__panel-book.is-active {
      display: flex !important;
      flex-direction: row;
      gap: 2rem;
      max-height: 350px;
    }

    .hps__panel-book-img-main {
      width: 47%;
      flex-shrink: 0;
      overflow: hidden;
    }

    .hps__panel-book-img-main img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 35%;
      display: block;
    }

    .hps__panel-book-right {
      width: 50%;
      flex-shrink: 0;
      padding: 0;
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-rows: 200px auto;
      gap: 0.5rem;
    }

    .hps__panel-book-img-secondary {
      grid-row: 1;
      grid-column: 1;
      max-width: 150px;
      max-height: 200px;
      overflow: hidden;
    }

    .hps__panel-book-right .hps__panel-frame-stamp {
      grid-row: 2;
      grid-column: 1;
      width: 120px;
      height: 120px;
      position: relative;
      flex-shrink: 0;
      overflow: hidden;
      justify-self: center;
    }

    .hps__panel-book-right .hps__panel-frame-stamp svg {
      width: 100%;
      height: 100%;
      display: block;
      fill: #DFBE71;
      animation: hpsStampRotate 20s infinite linear;
    }

    .hps__panel-book-content {
      grid-row: 1 / -1;
      grid-column: 2;
      padding: 0 0 0 1.5rem;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }
  }

  /* ===== Responsive — Desktop (990px) ===== */
  @media (min-width: 990px) {
    .hps {
      padding: 80px 3rem;
    }

    .hps__tabs {
      gap: 3rem;
    }

    .hps__tab {
      width: auto;
    }

    .hps__tab img {
      height: clamp(150px, 18vw, 230px);
      width: auto;
      object-fit: contain;
    }

    .hps__tab[data-tab="book"] img {
      height: clamp(180px, 22vw, 290px);
    }

    .hps__panel-frame-text {
      padding: 1.5rem 2rem 1rem 0;
      max-width: 33%;
    }

    .hps__panel-book-right .hps__panel-frame-stamp {
      width: 120px;
      height: 120px;
    }

    .hps__panel-book-content {
      padding: 0 0 0 2rem;
    }
  }
</style>

<section id="product-showcase" class="hps">
  <div class="hps__container">

    <!-- Header -->
    {%- if section.settings.title != blank -%}
      <h2 class="hps__title">
        {{ section.settings.title }}
        {%- if section.settings.title_highlight != blank -%}
          <span class="hps__title-highlight">{{ section.settings.title_highlight }}</span>
        {%- endif -%}
      </h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="hps__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.made_in_text != blank -%}
      <p class="hps__made-in">
        {{ section.settings.made_in_text }}
        {%- if section.settings.flag_icon_1 != blank -%}
          <img class="hps__flag" src="{{ section.settings.flag_icon_1 | image_url: width: 40 }}" alt="Drapeau" loading="lazy">
        {%- endif -%}
        {%- if section.settings.flag_icon_2 != blank -%}
          <img class="hps__flag" src="{{ section.settings.flag_icon_2 | image_url: width: 40 }}" alt="Drapeau" loading="lazy">
        {%- endif -%}
      </p>
    {%- endif -%}

    <!-- Body (tabs + panels + CTA) -->
    <div class="hps__body">

    <!-- Tabs -->
    <div class="hps__tabs">
      <button class="hps__tab is-active" data-tab="frame" aria-label="Voir le cadre">
        {%- if section.settings.tab_frame_image != blank -%}
          <img src="{{ section.settings.tab_frame_image | image_url: width: 640 }}" alt="Le cadre" loading="lazy">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag }}
        {%- endif -%}
      </button>

      <button class="hps__tab" data-tab="book" aria-label="Voir le livre">
        {%- if section.settings.tab_book_image != blank -%}
          <img src="{{ section.settings.tab_book_image | image_url: width: 640 }}" alt="Le livre" loading="lazy">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag }}
        {%- endif -%}
      </button>
    </div>

    <!-- Arrow separator -->
    <div class="hps__arrow-separator">
      <div class="hps__arrow-chevron" id="hps-chevron">
        <svg viewBox="0 0 22 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="0" y="0" width="22" height="2" fill="white"/>
          <path d="M0 1 L11 13 L22 1" stroke="#1D1D1B" stroke-width="1" fill="white"/>
        </svg>
      </div>
    </div>

    <!-- Panels -->
    <div class="hps__panels">

      <!-- Panel: Frame -->
      <div class="hps__panel hps__panel-frame is-active" data-panel="frame">
        <div class="hps__panel-frame-left">
          <div class="hps__panel-frame-text">
            {%- if section.settings.frame_title != blank -%}
              <h3 class="hps__panel-frame-title">{{ section.settings.frame_title }}</h3>
            {%- endif -%}
            {%- if section.settings.frame_desc != blank -%}
              <p class="hps__panel-frame-desc">{{ section.settings.frame_desc }}</p>
            {%- endif -%}
            {%- if section.settings.frame_details != blank -%}
              <p class="hps__panel-frame-details">{{ section.settings.frame_details }}</p>
            {%- endif -%}
            {%- if section.settings.frame_made_in != blank -%}
              <p class="hps__panel-made-in">
                {{ section.settings.frame_made_in }}
                {%- if section.settings.flag_icon_1 != blank -%}
                  <img class="hps__flag" src="{{ section.settings.flag_icon_1 | image_url: width: 40 }}" alt="Drapeau" loading="lazy">
                {%- endif -%}
                {%- if section.settings.flag_icon_2 != blank -%}
                  <img class="hps__flag" src="{{ section.settings.flag_icon_2 | image_url: width: 40 }}" alt="Drapeau" loading="lazy">
                {%- endif -%}
              </p>
            {%- endif -%}
          </div>
          <div class="hps__panel-frame-bottom">
            <div class="hps__panel-frame-secondary hps__desktop-only">
              {%- if section.settings.frame_secondary_image != blank -%}
                <img src="{{ section.settings.frame_secondary_image | image_url: width: 400 }}" alt="Détail œuvre" loading="lazy">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            <div class="hps__panel-frame-secondary hps__mobile-only">
              {%- if section.settings.frame_secondary_image_mobile != blank -%}
                <img src="{{ section.settings.frame_secondary_image_mobile | image_url: width: 600 }}" alt="Détail œuvre" loading="lazy">
              {%- elsif section.settings.frame_secondary_image != blank -%}
                <img src="{{ section.settings.frame_secondary_image | image_url: width: 400 }}" alt="Détail œuvre" loading="lazy">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            <div class="hps__panel-frame-stamp">
              <svg viewBox="0 0 500 500">
                <defs>
                  <path id="hps-textcircle" d="M 100,250 a 150,150 0 1,1 300,0 a 150,150 0 1,1 -300,0"/>
                </defs>
                <text dy="0" dx="0">
                  <textPath xlink:href="#hps-textcircle">· ASTROGALLERY · ASTROGALLERY · ASTROGALLERY</textPath>
                </text>
              </svg>
            </div>
          </div>
        </div>
        <div class="hps__panel-frame-image">
          {%- if section.settings.frame_image != blank -%}
            <img src="{{ section.settings.frame_image | image_url: width: 800 }}" alt="{{ section.settings.frame_title | escape }}" loading="lazy">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
      </div>

      <!-- Separator between panels (mobile only) -->
      <div class="hps__panel-separator hps__mobile-only">
        <div class="hps__panel-separator-line"></div>
        {%- if section.settings.separator_image != blank -%}
          <div class="hps__panel-separator-icon">
            <img src="{{ section.settings.separator_image | image_url: width: 120 }}" alt="" loading="lazy">
          </div>
        {%- endif -%}
      </div>

      <!-- Panel: Book -->
      <div class="hps__panel hps__panel-book" data-panel="book">
        <div class="hps__panel-book-tab-image hps__mobile-only">
          {%- if section.settings.tab_book_image != blank -%}
            <img src="{{ section.settings.tab_book_image | image_url: width: 640 }}" alt="Le livre" loading="lazy">
          {%- endif -%}
        </div>
        <div class="hps__panel-book-img-main">
          {%- if section.settings.book_image_1 != blank -%}
            <picture>
              {%- if section.settings.book_image_1_mobile != blank -%}
                <source media="(max-width: 749px)" srcset="{{ section.settings.book_image_1_mobile | image_url: width: 800 }}">
              {%- endif -%}
              <img src="{{ section.settings.book_image_1 | image_url: width: 800 }}" alt="Livre ouvert" loading="lazy">
            </picture>
          {%- else -%}
            {{ 'image' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        <div class="hps__panel-book-right">
          <div class="hps__panel-book-img-secondary">
            {%- if section.settings.book_image_2 != blank -%}
              <picture>
                {%- if section.settings.book_image_2_mobile != blank -%}
                  <source media="(max-width: 749px)" srcset="{{ section.settings.book_image_2_mobile | image_url: width: 600 }}">
                {%- endif -%}
                <img src="{{ section.settings.book_image_2 | image_url: width: 600 }}" alt="Couverture livre" loading="lazy">
              </picture>
            {%- else -%}
              {{ 'image' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="hps__panel-frame-stamp">
            <svg viewBox="0 0 500 500">
              <defs>
                <path id="hps-textcircle-book" d="M 100,250 a 150,150 0 1,1 300,0 a 150,150 0 1,1 -300,0"/>
              </defs>
              <text dy="0" dx="0">
                <textPath xlink:href="#hps-textcircle-book">· ASTROGALLERY · ASTROGALLERY · ASTROGALLERY</textPath>
              </text>
            </svg>
          </div>
          <div class="hps__panel-book-content">
            {%- if section.settings.book_title != blank -%}
              <h3 class="hps__panel-book-title">{{ section.settings.book_title }}</h3>
            {%- endif -%}
            {%- if section.settings.book_desc != blank -%}
              <p class="hps__panel-book-desc">{{ section.settings.book_desc }}</p>
            {%- endif -%}
            {%- if section.settings.book_made_in != blank -%}
              <p class="hps__panel-made-in">
                {{ section.settings.book_made_in }}
                {%- if section.settings.flag_icon_1 != blank -%}
                  <img class="hps__flag" src="{{ section.settings.flag_icon_1 | image_url: width: 40 }}" alt="Drapeau" loading="lazy">
                {%- endif -%}
                {%- if section.settings.flag_icon_2 != blank -%}
                  <img class="hps__flag" src="{{ section.settings.flag_icon_2 | image_url: width: 40 }}" alt="Drapeau" loading="lazy">
                {%- endif -%}
              </p>
            {%- endif -%}
          </div>
        </div>
        <div class="hps__panel-book-img-bottom hps__mobile-only">
          {%- if section.settings.book_image_2_mobile != blank -%}
            <img src="{{ section.settings.book_image_2_mobile | image_url: width: 600 }}" alt="Couverture livre" loading="lazy">
          {%- elsif section.settings.book_image_2 != blank -%}
            <img src="{{ section.settings.book_image_2 | image_url: width: 600 }}" alt="Couverture livre" loading="lazy">
          {%- endif -%}
        </div>
      </div>

    </div>

    <!-- CTA -->
    {%- if section.settings.button_label != blank -%}
      <div class="hps__cta">
        <a href="{{ section.settings.button_link }}" class="btn-gold">
          <span class="btn-gold__text">{{ section.settings.button_label }}</span>
        </a>
      </div>
    {%- endif -%}

    </div><!-- .hps__body -->
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.querySelector('.hps');
    if (!section) return;

    var tabs = section.querySelectorAll('.hps__tab');
    var panels = section.querySelectorAll('.hps__panel');
    var chevron = document.getElementById('hps-chevron');

    function setActive(tabName) {
      tabs.forEach(function (tab) {
        tab.classList.toggle('is-active', tab.getAttribute('data-tab') === tabName);
      });
      panels.forEach(function (panel) {
        panel.classList.toggle('is-active', panel.getAttribute('data-panel') === tabName);
      });
      moveChevron(tabName);
    }

    function moveChevron(tabName) {
      if (!chevron) return;
      var activeTab = section.querySelector('.hps__tab[data-tab="' + tabName + '"]');
      if (!activeTab) return;
      var separator = chevron.parentElement;
      var separatorRect = separator.getBoundingClientRect();
      var tabRect = activeTab.getBoundingClientRect();
      var center = tabRect.left + tabRect.width / 2 - separatorRect.left;
      var pct = (center / separatorRect.width) * 100;
      chevron.style.left = pct + '%';
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        setActive(tab.getAttribute('data-tab'));
      });
    });

    // Initial position — wait for tab images to load so dimensions are correct
    var tabImages = section.querySelectorAll('.hps__tab img');
    var loaded = 0;
    var total = tabImages.length;

    function initialPosition() {
      moveChevron('frame');
    }

    if (total === 0) {
      initialPosition();
    } else {
      tabImages.forEach(function (img) {
        if (img.complete) {
          loaded++;
          if (loaded >= total) initialPosition();
        } else {
          img.addEventListener('load', function () {
            loaded++;
            if (loaded >= total) initialPosition();
          });
          img.addEventListener('error', function () {
            loaded++;
            if (loaded >= total) initialPosition();
          });
        }
      });
    }

    // Fallback — recalc after page fully loaded (fonts, images, etc.)
    window.addEventListener('load', function () {
      moveChevron('frame');
    });

    // Recalc on resize
    window.addEventListener('resize', function () {
      var active = section.querySelector('.hps__tab.is-active');
      if (active) moveChevron(active.getAttribute('data-tab'));
    });
  });
</script>

