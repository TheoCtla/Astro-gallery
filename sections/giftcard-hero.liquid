<style>
  /* Layout */
  .gc-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }

  .gc-hero__row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .gc-hero__media,
  .gc-hero__info {
    width: 100%;
  }

  /* Breadcrumb */
  .gc-hero__breadcrumb {
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    color: #888;
  }

  .gc-hero__breadcrumb a {
    color: #888;
    text-decoration: none;
  }

  .gc-hero__breadcrumb a:hover {
    color: #1D1D1B;
  }

  /* Image */
  .gc-hero__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    cursor: zoom-in;
  }

  /* Vendor */
  .gc-hero__vendor {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1D1D1B;
    margin: 0 0 1rem 0;
  }

  /* Title */
  .gc-hero__title {
    font-family: 'Lemon Milk', 'LEMONMILK-Regular', sans-serif;
    font-weight: 300;
    font-style: normal;
    font-size: clamp(28px, 5vw, 60px);
    line-height: 1.2;
    color: #1D1D1B;
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
  }

  .gc-hero__title-gold {
    color: #DFBE71;
  }

  /* Subtitle (italic) */
  .gc-hero__subtitle {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: clamp(14px, 1.3vw, 18px);
    color: #1D1D1B;
    line-height: 1.6;
    margin: 0 0 0.5rem 0;
  }

  .gc-hero__subtitle p {
    margin: 0 0 2rem 0;
  }

  /* Description */
  .gc-hero__description {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #1D1D1B;
    line-height: 1.7;
    margin: 0 0 1rem 0;
  }

  .gc-hero__description p {
    margin: 0 0 0.8rem 0;
  }

  /* Highlight text */
  .gc-hero__highlight {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #1D1D1B;
    margin: 1.5rem 0 0 0;
  }

  /* Amount selector */
  .gc-hero__amount {
    margin: 2rem 0;
    padding-top: 2rem;
    border-top: 1px solid #E5E5E5;
  }

  .gc-hero__amount-label {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #1D1D1B;
    margin-bottom: 1rem;
  }

  .gc-hero__amount-options {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.8rem;
  }

  .gc-hero__amount-option {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .gc-hero__amount-btn {
    padding: 0.8rem 1rem;
    border: 1px solid #E5E5E5;
    background: transparent;
    cursor: pointer;
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 16px;
    font-weight: 400;
    color: #1D1D1B;
    transition: all 0.3s ease;
    width: 100%;
    height: 50px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
  }

  .gc-hero__amount-btn:hover {
    border-color: #DFBE71;
  }

  .gc-hero__amount-btn--active {
    border-color: #DFBE71;
    border-width: 2px;
  }

  .gc-hero__amount-sub {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 9px;
    color: #DFBE71;
    font-style: italic;
    text-align: center;
    line-height: 1;
    white-space: nowrap;
  }

  /* Add to cart button */
  .gc-hero__add-btn {
    width: 100%;
    background-color: #DFBE71;
    color: #FFFFFF;
    border: none;
    padding: 1rem 1.5rem;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(13px, 1.1vw, 15px);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-align: center;
    min-height: 50px;
    margin-top: 1rem;
  }

  .gc-hero__add-btn:hover {
    background-color: #D4B265;
  }

  .gc-hero__add-btn[aria-disabled="true"] {
    opacity: 0.7;
    cursor: wait;
  }

  /* Badges */
  .gc-hero__badges {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    flex-wrap: wrap;
  }

  .gc-hero__badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    color: #888;
  }

  .gc-hero__badge-icon {
    width: 18px;
    height: 18px;
    display: inline-block;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Lightbox */
  .gc-hero__lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gc-hero__lightbox-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    cursor: pointer;
  }

  .gc-hero__lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    z-index: 1;
  }

  .gc-hero__lightbox-image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
  }

  .gc-hero__lightbox-close {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: #FFFFFF;
    font-size: 36px;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .gc-hero__lightbox-close:hover {
    opacity: 0.7;
  }

  /* Mobile small */
  @media (max-width: 600px) {
    .gc-hero__amount-options {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
    }

    .gc-hero__amount-btn {
      padding: 0.6rem 0.5rem;
      font-size: 13px;
      height: 44px;
    }

    .gc-hero__amount-sub {
      font-size: 8px;
    }
  }

  /* Tablet */
  @media (min-width: 750px) {
    .gc-hero {
      padding: 0 2rem 4rem;
    }

    .gc-hero__breadcrumb {
      padding: 0 2rem;
    }
  }

  /* Desktop */
  @media (min-width: 990px) {
    .gc-hero__row {
      flex-direction: row;
      gap: 3rem;
      align-items: flex-start;
    }

    .gc-hero__media {
      width: 50%;
      flex-shrink: 0;
    }

    .gc-hero__info {
      width: 50%;
      position: sticky;
      top: 3rem;
    }
  }
</style>

{% if settings.show_breadcrumbs %}
  <nav class="gc-hero__breadcrumb" role="navigation" aria-label="breadcrumbs">
    <a href="{{ routes.root_url }}" title="Home">Home</a>
    {% render 'icon-breadcrumb' %}
    <span>{{ section.settings.breadcrumb_label | default: 'Offrir' }}</span>
  </nav>
{% endif %}

<div class="gc-hero">
  <div class="gc-hero__row">

    <!-- Image produit -->
    <div class="gc-hero__media">
      {%- assign hero_image = section.settings.image | default: product.featured_image -%}
      {%- if hero_image != blank -%}
        <a href="#" class="gc-hero__image-trigger" data-image-src="{{ hero_image | image_url: width: 1200 }}">
          <img
            src="{{ hero_image | image_url: width: 700 }}"
            srcset="
              {{ hero_image | image_url: width: 350 }} 350w,
              {{ hero_image | image_url: width: 700 }} 700w,
              {{ hero_image | image_url: width: 1100 }} 1100w
            "
            sizes="(min-width: 990px) 50vw, 100vw"
            alt="{{ product.title | escape }}"
            class="gc-hero__image"
            loading="eager"
          >
        </a>
      {%- else -%}
        {{ 'image' | placeholder_svg_tag }}
      {%- endif -%}

      <!-- Lightbox -->
      <div id="gc-hero-lightbox" class="gc-hero__lightbox" style="display: none;">
        <div class="gc-hero__lightbox-overlay"></div>
        <div class="gc-hero__lightbox-content">
          <button class="gc-hero__lightbox-close" aria-label="Fermer">&times;</button>
          <img src="" alt="Image agrandie" class="gc-hero__lightbox-image">
        </div>
      </div>
    </div>

    <!-- Informations produit -->
    <div class="gc-hero__info">

      <!-- Vendor -->
      <p class="gc-hero__vendor">{{ product.vendor }}</p>

      <!-- Titre -->
      <h1 class="gc-hero__title">
        {{ section.settings.title_line1 | default: 'CARTE CADEAU' }}<br>
        <span class="gc-hero__title-gold">{{ section.settings.title_line2 | default: 'ASTROGALLERY' }}</span>
      </h1>

      <!-- Sous-titre -->
      {%- if section.settings.subtitle != blank -%}
        <div class="gc-hero__subtitle">
          {{ section.settings.subtitle }}
        </div>
      {%- endif -%}

      <!-- Description -->
      {%- if section.settings.description != blank -%}
        <div class="gc-hero__description">
          {{ section.settings.description }}
        </div>
      {%- endif -%}

      <!-- Texte mis en avant -->
      {%- if section.settings.highlight_text != blank -%}
        <p class="gc-hero__highlight"><strong>{{ section.settings.highlight_text }}</strong></p>
      {%- endif -%}

      <!-- Sélecteur de montant -->
      <div class="gc-hero__amount">
        <label class="gc-hero__amount-label">{{ section.settings.amount_label | default: 'Sélectionner le montant souhaité' }}</label>
        {%- assign allowed_prices = '5000,10000,15000,20000,25000,30000,34900' | split: ',' -%}
        <div class="gc-hero__amount-options">
          {%- assign btn_index = 0 -%}
          {%- for variant in product.variants -%}
            {%- assign variant_price_str = variant.price | append: '' -%}
            {%- if allowed_prices contains variant_price_str -%}
              {%- assign btn_index = btn_index | plus: 1 -%}
              {%- assign price_check = variant.price | times: 1 -%}
              {%- assign is_full_artwork = false -%}
              {%- if price_check == 34900 or variant.title contains '349' -%}
                {%- assign is_full_artwork = true -%}
              {%- endif -%}
              <div class="gc-hero__amount-option">
                <button type="button"
                  class="gc-hero__amount-btn {% if is_full_artwork %}gc-hero__amount-btn--full{% endif %} {% if btn_index == 2 %}gc-hero__amount-btn--active{% endif %}"
                  data-variant-id="{{ variant.id }}"
                  data-variant-price="{{ variant.price | money }}">
                  {{ variant.title }}
                  {%- if is_full_artwork -%}
                    <span class="gc-hero__amount-sub">{{ section.settings.full_artwork_label | default: 'Œuvre complète' }}</span>
                  {%- endif -%}
                </button>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <!-- Bouton d'achat -->
      <button
        type="button"
        id="gc-hero-add-to-cart"
        class="gc-hero__add-btn"
      >
        {{ section.settings.add_to_cart_label | default: '• AJOUTER AU PANIER •' }}
      </button>
      <input type="hidden" id="gc-hero-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

      <!-- Badges -->
      <div class="gc-hero__badges">
        {%- for block in section.blocks -%}
          {%- if block.type == 'badge' -%}
            <div class="gc-hero__badge" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <img
                  class="gc-hero__badge-icon"
                  src="{{ block.settings.icon | image_url: width: 40 }}"
                  alt="{{ block.settings.text | escape }}"
                  width="20"
                  height="20"
                  loading="lazy"
                >
              {%- endif -%}
              <span>{{ block.settings.text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

<!-- SEO Schema -->
<script type="application/ld+json">
  {
    "@context": "http://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    {% if product.featured_image %}
      "image": [{{ product.featured_image | image_url: width: 1920 | prepend: "https:" | json }}],
    {% endif %}
    "description": {{ product.description | strip_html | json }},
    "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
    "offers": [
      {%- for variant in product.variants -%}
        {
          "@type": "Offer",
          "availability": "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
          "price": {{ variant.price | divided_by: 100.00 | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "url": {{ request.origin | append: variant.url | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var amountButtons = document.querySelectorAll('.gc-hero__amount-btn');
  var variantInput = document.getElementById('gc-hero-variant-id');

  amountButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      amountButtons.forEach(function(b) { b.classList.remove('gc-hero__amount-btn--active'); });
      this.classList.add('gc-hero__amount-btn--active');
      if (variantInput) variantInput.value = this.getAttribute('data-variant-id');
    });
  });

  // Pre-select from URL param
  var urlParams = new URLSearchParams(window.location.search);
  var amountParam = urlParams.get('amount');
  var selectedBtn = null;

  if (amountParam) {
    amountButtons.forEach(function(btn) {
      if (btn.textContent.trim().includes(amountParam + '€') || btn.textContent.trim().includes(amountParam + ' €')) {
        selectedBtn = btn;
      }
    });
  }

  if (!selectedBtn && amountButtons.length > 1) selectedBtn = amountButtons[1];
  else if (!selectedBtn && amountButtons.length > 0) selectedBtn = amountButtons[0];

  if (selectedBtn) {
    amountButtons.forEach(function(b) { b.classList.remove('gc-hero__amount-btn--active'); });
    selectedBtn.classList.add('gc-hero__amount-btn--active');
    if (variantInput) variantInput.value = selectedBtn.getAttribute('data-variant-id');
  }

  // Add to cart
  var addBtn = document.getElementById('gc-hero-add-to-cart');
  if (addBtn) {
    addBtn.addEventListener('click', function(e) {
      e.preventDefault();
      var vid = variantInput ? variantInput.value : null;
      if (!vid) return;

      addBtn.classList.add('loading');
      addBtn.setAttribute('aria-disabled', 'true');

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(vid), quantity: 1 }] })
      })
      .then(function(r) { return r.json(); })
      .then(function() {
        var cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer) {
          fetch('/?sections=cart-drawer,cart-icon-bubble')
            .then(function(res) { return res.json(); })
            .then(function(sections) {
              var parser = new DOMParser();
              var drawerHTML = sections['cart-drawer'];
              var doc = parser.parseFromString(drawerHTML, 'text/html');
              var newInner = doc.querySelector('.drawer__inner');
              var curInner = cartDrawer.querySelector('.drawer__inner');
              if (newInner && curInner) curInner.innerHTML = newInner.innerHTML;

              var iconHTML = sections['cart-icon-bubble'];
              var iconDoc = parser.parseFromString(iconHTML, 'text/html');
              var newIcon = iconDoc.querySelector('.shopify-section');
              var curIcon = document.getElementById('cart-icon-bubble');
              if (newIcon && curIcon) curIcon.innerHTML = newIcon.innerHTML;

              cartDrawer.classList.remove('is-empty');
              if (typeof cartDrawer.open === 'function') cartDrawer.open();
              else { cartDrawer.classList.add('animate', 'active'); document.body.classList.add('overflow-hidden'); }
            });
        } else {
          window.location.href = '/cart';
        }
      })
      .catch(function() { alert("Erreur lors de l'ajout au panier."); })
      .finally(function() { addBtn.classList.remove('loading'); addBtn.removeAttribute('aria-disabled'); });
    });
  }

  // Lightbox
  var trigger = document.querySelector('.gc-hero__image-trigger');
  var lightbox = document.getElementById('gc-hero-lightbox');
  if (trigger && lightbox) {
    var overlay = lightbox.querySelector('.gc-hero__lightbox-overlay');
    var closeBtn = lightbox.querySelector('.gc-hero__lightbox-close');
    var lbImage = lightbox.querySelector('.gc-hero__lightbox-image');

    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      lbImage.src = this.getAttribute('data-image-src');
      lightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
    closeBtn.addEventListener('click', function() { lightbox.style.display = 'none'; document.body.style.overflow = ''; });
    overlay.addEventListener('click', function() { lightbox.style.display = 'none'; document.body.style.overflow = ''; });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && lightbox.style.display === 'flex') { lightbox.style.display = 'none'; document.body.style.overflow = ''; }
    });
  }

  // Gift card links from cards section (scroll to top + select amount)
  document.addEventListener('click', function(e) {
    var card = e.target.closest('.giftcard-cards__card');
    if (!card) return;
    e.preventDefault();
    var amount = card.getAttribute('data-amount');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if (amount) {
      amountButtons.forEach(function(btn) {
        if (btn.textContent.trim().includes(amount + '€') || btn.textContent.trim().includes(amount + ' €')) {
          amountButtons.forEach(function(b) { b.classList.remove('gc-hero__amount-btn--active'); });
          btn.classList.add('gc-hero__amount-btn--active');
          if (variantInput) variantInput.value = btn.getAttribute('data-variant-id');
        }
      });
    }
  });
});
</script>

{% schema %}
{
  "name": "Hero Carte Cadeau",
  "tag": "section",
  "class": "giftcard-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image produit"
    },
    {
      "type": "text",
      "id": "breadcrumb_label",
      "label": "Libellé breadcrumb",
      "default": "Offrir"
    },
    {
      "type": "header",
      "content": "Titre"
    },
    {
      "type": "text",
      "id": "title_line1",
      "label": "Titre ligne 1",
      "default": "CARTE CADEAU"
    },
    {
      "type": "text",
      "id": "title_line2",
      "label": "Titre ligne 2 (doré)",
      "default": "ASTROGALLERY"
    },
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Sous-titre (italique)",
      "default": "<p><em>Offrir une carte cadeau Astro Gallery, c'est offrir bien plus qu'un simple présent.</em></p><p><em>C'est permettre à une personne de transformer son thème natal en une œuvre astrale élégante et personnelle, reflet intime de son identité.</em></p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>La carte cadeau donne accès à la création d'une œuvre numérotée et nominative, accompagnée d'un livret de 110 pages dont 40 personnalisées à son ciel. Une expérience complète qui invite à la contemplation et à la découverte de soi.</p><p>La personne à qui vous l'offrez choisit elle même son format, son design et confirme ses informations de naissance. Nous réalisons ensuite sa création dans notre atelier en France.</p><p>Un cadeau profond, esthétique et mémorable pour célébrer une personne unique.</p>"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Texte mis en avant",
      "default": "Création et livraison en 3 à 4 semaines après activation de la carte."
    },
    {
      "type": "header",
      "content": "Sélecteur de montant"
    },
    {
      "type": "text",
      "id": "amount_label",
      "label": "Label du sélecteur",
      "default": "Sélectionner le montant souhaité"
    },
    {
      "type": "text",
      "id": "full_artwork_label",
      "label": "Label sous le prix max (349€)",
      "default": "Œuvre complète"
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Texte du bouton",
      "default": "• AJOUTER AU PANIER •"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge info",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icône"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison gratuite"
        }
      ]
    }
  ]
}
{% endschema %}
