<style>
  .giftcard-cards {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    text-align: center;
    border: 1px solid #E5E5E5;
  }

  .giftcard-cards__heading {
    font-family: 'Lemon Milk', 'LEMONMILK-Bold', sans-serif;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    color: #1D1D1B;
    margin: 0 0 0.8rem 0;
  }

  .giftcard-cards__subtitle {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 13px;
    color: #1D1D1B;
    margin: 0 0 2rem 0;
    line-height: 1.6;
  }

  .giftcard-cards__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .giftcard-cards__card {
    display: block;
    overflow: hidden;
    transition: transform 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .giftcard-cards__card:hover {
    transform: translateY(-3px);
  }

  .giftcard-cards__card img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 750px) {
    .giftcard-cards {
      padding: 4rem 3rem 5rem;
    }

    .giftcard-cards__heading {
      font-size: 22px;
    }

    .giftcard-cards__subtitle {
      font-size: 14px;
    }

    .giftcard-cards__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 990px) {
    .giftcard-cards__heading {
      font-size: 26px;
    }
  }
</style>

<div class="giftcard-cards">
  {%- if section.settings.heading != blank -%}
    <h2 class="giftcard-cards__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.settings.subtitle != blank -%}
    <p class="giftcard-cards__subtitle">{{ section.settings.subtitle }}</p>
  {%- endif -%}

  <div class="giftcard-cards__grid">
    {%- for block in section.blocks -%}
      <a href="#" class="giftcard-cards__card" data-amount="{{ block.settings.amount }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 400 }}"
            alt="Carte Cadeau {{ block.settings.amount }}€"
            loading="lazy"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag }}
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Cartes cadeaux",
  "tag": "section",
  "class": "giftcard-cards-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "OFFREZ UNE CARTE CADEAU"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Faites plaisir à l'un de vos proches en lui offrant une carte cadeau AstroGallery"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Carte cadeau",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de la carte"
        },
        {
          "type": "text",
          "id": "amount",
          "label": "Montant (pour lien automatique)",
          "default": "50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cartes cadeaux",
      "blocks": [
        { "type": "card", "settings": { "amount": "50" } },
        { "type": "card", "settings": { "amount": "100" } },
        { "type": "card", "settings": { "amount": "150" } },
        { "type": "card", "settings": { "amount": "200" } }
      ]
    }
  ]
}
{% endschema %}
