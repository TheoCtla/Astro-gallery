<style>
  .giftcard-book {
    background-color: #1D1D1B;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 2rem 1.5rem;
    overflow: hidden;
  }

  .giftcard-book__container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* Header: logo + titre/intro à gauche, image à droite */
  .giftcard-book__header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .giftcard-book__header-content {
    display: flex;
    flex-direction: column;
  }

  .giftcard-book__logo {
    width: 65px;
    height: 65px;
    margin-bottom: 0.8rem;
  }

  .giftcard-book__logo-svg {
    width: 100%;
    height: 100%;
    animation: giftcard-book-rotate 20s linear infinite;
    fill: #DFBE71;
  }

  .giftcard-book__logo-svg text {
    font-family: 'Poppins', sans-serif;
    font-size: 30px;
    font-weight: 300;
    letter-spacing: 6px;
    text-transform: uppercase;
  }

  @keyframes giftcard-book-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .giftcard-book__heading {
    font-family: 'Lemon Milk', 'LEMONMILK-Regular', sans-serif;
    font-weight: 400;
    font-size: 18px;
    text-transform: uppercase;
    color: #FFFFFF;
    line-height: 1.3;
    margin: 0 0 0.6rem 0;
  }

  .giftcard-book__intro {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 12px;
    color: #FFFFFF;
    line-height: 1.5;
    margin: 1rem 0 1.5rem 0;
    max-width: 500px;
  }

  .giftcard-book__header-image {
    width: 100%;
    overflow: hidden;
    position: relative;
    min-height: 300px;
  }

  .giftcard-book__header-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Blocks image + texte */
  .giftcard-book__block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .giftcard-book__block-image {
    width: 100%;
    overflow: hidden;
    position: relative;
    min-height: 250px;
  }

  .giftcard-book__block-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .giftcard-book__block-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .giftcard-book__block-title {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 12px;
    color: #FFFFFF;
    margin: 0 0 0.5rem 0;
  }

  .giftcard-book__block-text {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.8;
    margin: 0;
  }

  .giftcard-book__block-text p {
    color: rgba(255, 255, 255, 0.8);
  }

  .giftcard-book__block-text ul,
  .giftcard-book__block-text li {
    color: rgba(255, 255, 255, 0.8);
    font-size: 11px;
    line-height: 1.7;
  }

  .giftcard-book__block-text ul {
    padding-left: 1.2rem;
    margin: 0.4rem 0;
  }

  .giftcard-book__block-text ul + p {
    margin-top: 1.5rem;
  }

  /* CTA */
  .giftcard-book__cta {
    text-align: center;
    margin-top: 1.5rem;
  }

  .giftcard-book__cta-sub {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-style: italic;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.8rem;
  }

  /* Tablet */
  @media (min-width: 750px) {
    .giftcard-book {
      padding: 80px 2rem;
    }

    .giftcard-book__header {
      flex-direction: row;
      align-items: stretch;
      gap: 3rem;
      margin-bottom: 4rem;
    }

    .giftcard-book__header-content {
      flex: 1;
    }

    .giftcard-book__header-image {
      width: 40%;
      flex-shrink: 0;
      min-height: 0;
    }

    .giftcard-book__logo {
      width: 80px;
      height: 80px;
    }

    .giftcard-book__heading {
      font-size: 22px;
    }

    .giftcard-book__intro {
      font-size: 13px;
    }

    .giftcard-book__block {
      flex-direction: row;
      gap: 2.5rem;
      align-items: stretch;
      margin-bottom: 1rem;
    }

    .giftcard-book__block--reverse {
      flex-direction: row-reverse;
    }

    .giftcard-book__block-image {
      width: 35%;
      flex-shrink: 0;
      min-height: 0;
    }

    .giftcard-book__block-content {
      flex: 1;
    }

    .giftcard-book__block-title {
      font-size: 13px;
    }

    .giftcard-book__block-text,
    .giftcard-book__block-text p,
    .giftcard-book__block-text li {
      font-size: 12px;
      line-height: 1.6;
    }
  }

  /* Desktop */
  @media (min-width: 990px) {
    .giftcard-book {
      padding: 80px 3rem;
    }

    .giftcard-book__header {
      gap: 4rem;
    }

    .giftcard-book__heading {
      font-size: 26px;
    }

    .giftcard-book__logo {
      width: 100px;
      height: 100px;
    }

    .giftcard-book__intro {
      font-size: 14px;
    }

    .giftcard-book__block {
      gap: 3rem;
    }

    .giftcard-book__block-title {
      font-size: 14px;
    }

    .giftcard-book__block-text,
    .giftcard-book__block-text p,
    .giftcard-book__block-text li {
      font-size: 13px;
    }
  }
</style>

<div class="giftcard-book"
  {%- if section.settings.background_image != blank %}
    style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
  {%- endif %}>
  <div class="giftcard-book__container">

    <!-- Header : logo + titre/intro à gauche, première image à droite -->
    <div class="giftcard-book__header">
      <div class="giftcard-book__header-content">
        <!-- Logo rotatif -->
        <div class="giftcard-book__logo">
          <svg class="giftcard-book__logo-svg" viewBox="0 0 500 500">
            <defs>
              <path id="giftcard-circle-path" d="M 95,250 a 155,155 0 1,1 310,0 a 155,155 0 1,1 -310,0"/>
            </defs>
            <text dy="0" dx="0">
              <textPath xlink:href="#giftcard-circle-path">ASTROGALLERY · ASTROGALLERY · ASTROGALLERY ·</textPath>
            </text>
          </svg>
        </div>

        {%- if section.settings.heading != blank -%}
          <h2 class="giftcard-book__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.intro != blank -%}
          <p class="giftcard-book__intro">{{ section.settings.intro }}</p>
        {%- endif -%}

        <!-- Premier bloc texte sous le titre -->
        {%- assign first_block = section.blocks | first -%}
        {%- if first_block -%}
          <div class="giftcard-book__block-content" style="margin-top: 1rem;" {{ first_block.shopify_attributes }}>
            {%- if first_block.settings.title != blank -%}
              <h3 class="giftcard-book__block-title">{{ first_block.settings.title }}</h3>
            {%- endif -%}
            {%- if first_block.settings.text != blank -%}
              <div class="giftcard-book__block-text">{{ first_block.settings.text }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Première image à droite -->
      {%- if first_block and first_block.settings.image != blank -%}
        <div class="giftcard-book__header-image">
          <img
            src="{{ first_block.settings.image | image_url: width: 800 }}"
            srcset="
              {{ first_block.settings.image | image_url: width: 400 }} 400w,
              {{ first_block.settings.image | image_url: width: 800 }} 800w
            "
            sizes="(min-width: 750px) 45vw, 100vw"
            alt="{{ first_block.settings.title | escape }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
    </div>

    <!-- Blocs suivants : alternance image/texte -->
    {%- for block in section.blocks -%}
      {%- if forloop.index0 > 0 -%}
        {%- assign block_mod = forloop.index0 | modulo: 2 -%}
        <div class="giftcard-book__block {% if block_mod == 0 %}giftcard-book__block--reverse{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="giftcard-book__block-image">
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="
                  {{ block.settings.image | image_url: width: 400 }} 400w,
                  {{ block.settings.image | image_url: width: 800 }} 800w
                "
                sizes="(min-width: 750px) 45vw, 100vw"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}
          <div class="giftcard-book__block-content">
            {%- if block.settings.title != blank -%}
              <h3 class="giftcard-book__block-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="giftcard-book__block-text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="giftcard-book__cta">
        <a href="{{ section.settings.cta_link }}" class="btn-gold">
          <span class="btn-gold__text">{{ section.settings.cta_label }}</span>
        </a>
        {%- if section.settings.cta_sub != blank -%}
          <span class="giftcard-book__cta-sub">{{ section.settings.cta_sub }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Livret personnalisé",
  "tag": "section",
  "class": "giftcard-book-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "UN LIVRE PERSONNALISÉ INCLUS AVEC VOTRE ŒUVRE."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction (italique doré)",
      "default": "Chaque œuvre ASTROGALLERY est accompagnée de son livre d'interprétation de 110 pages, conçu comme un véritable guide personnel."
    },
    {
      "type": "header",
      "content": "Bouton CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton",
      "default": "OFFRIR UNE ŒUVRE"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton"
    },
    {
      "type": "text",
      "id": "cta_sub",
      "label": "Texte sous le bouton",
      "default": "Livret de 110 pages inclus"
    }
  ],
  "blocks": [
    {
      "type": "book_block",
      "name": "Bloc image + texte",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "40 pages entièrement dédiées à votre analyse."
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte",
          "default": "<p>La première partie est entièrement personnalisée à partir de votre date, heure et lieu de naissance.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Livret personnalisé",
      "blocks": [
        {
          "type": "book_block",
          "settings": {
            "title": "40 pages entièrement dédiées à votre analyse.",
            "text": "<p>La première partie est entièrement personnalisée à partir de votre date, heure et lieu de naissance.</p>"
          }
        },
        {
          "type": "book_block",
          "settings": {
            "title": "70 pages pour comprendre et lire votre carte.",
            "text": "<p>La seconde partie est un guide complet et accessible pour apprendre à lire votre carte du ciel.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
