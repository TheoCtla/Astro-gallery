{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="footer color-{{ section.settings.color_scheme }}">
  <div class="footer__content-top container">
    <div class="footer__custom-wrapper">
      <!-- Colonne 1 : Logo + Tagline -->
      <div class="footer__column footer__column--left">
        <div class="footer__custom-logo">
          {%- if section.settings.footer_logo != blank -%}
            <img
              src="{{ section.settings.footer_logo | image_url: width: 300 }}"
              alt="{{ section.settings.footer_logo.alt | default: shop.name | escape }}"
              class="footer__logo-img"
              width="300"
              height="{{ 300 | divided_by: section.settings.footer_logo.aspect_ratio | round }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'footer__logo-img' }}
          {%- endif -%}
        </div>
        <p class="footer__tagline">
          <span class="footer__tagline-line1">{{ section.settings.footer_tagline_1 }}</span>
          <span class="footer__tagline-line2">{{ section.settings.footer_tagline_2 }}</span>
        </p>
      </div>

      <!-- Colonne 2 : Liens -->
      <div class="footer__column footer__column--right">
        <!-- Sections -->
        <div class="footer__links-column">
          <h3 class="footer__section-title">{{ section.settings.footer_sections_title }}</h3>
          <ul class="footer__section-links list-unstyled">
            {%- for link in section.settings.footer_menu_left.links -%}
              <li>
                <a href="{{ link.url }}" class="footer__link">
                  {{ link.title | upcase }}
                </a>
              </li>
            {%- endfor -%}
            {%- for link in section.settings.footer_menu_right.links -%}
              <li>
                <a href="{{ link.url }}" class="footer__link">
                  {{ link.title | upcase }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>

        <!-- Social Media -->
        <div class="footer__links-column">
          <h3 class="footer__section-title">{{ section.settings.footer_social_title }}</h3>
          <ul class="footer__social-links list-unstyled">
            {%- if settings.social_instagram_link != blank -%}
              <li>
                <a
                  href="{{ settings.social_instagram_link }}"
                  class="footer__link"
                  {% if settings.new_tab %}target="_blank"{% endif %}
                >INSTAGRAM</a>
              </li>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <li>
                <a
                  href="{{ settings.social_facebook_link }}"
                  class="footer__link"
                  {% if settings.new_tab %}target="_blank"{% endif %}
                >FACEBOOK</a>
              </li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li>
                <a
                  href="{{ settings.social_tiktok_link }}"
                  class="footer__link"
                  {% if settings.new_tab %}target="_blank"{% endif %}
                >TIKTOK</a>
              </li>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <li>
                <a
                  href="{{ settings.social_pinterest_link }}"
                  class="footer__link"
                  {% if settings.new_tab %}target="_blank"{% endif %}
                >PINTEREST</a>
              </li>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <li>
                <a
                  href="{{ settings.social_youtube_link }}"
                  class="footer__link"
                  {% if settings.new_tab %}target="_blank"{% endif %}
                >YOUTUBE</a>
              </li>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <li>
                <a
                  href="{{ settings.social_twitter_link }}"
                  class="footer__link"
                  {% if settings.new_tab %}target="_blank"{% endif %}
                >TWITTER</a>
              </li>
            {%- endif -%}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Section Paiement -->
  <div class="footer__content-middle">
    <div class="container">
      <div class="footer__payment-section">
        <h3 class="footer__payment-title">{{ section.settings.footer_payment_title }}</h3>
        <div class="footer__payment-icons">
          {%- for i in (1..6) -%}
            {%- assign icon_id = 'payment_icon_' | append: i -%}
            {%- assign icon = section.settings[icon_id] -%}
            {%- if icon != blank -%}
              <img
                src="{{ icon | image_url: height: 40 }}"
                alt="{{ icon.alt | default: 'Moyen de paiement' | escape }}"
                class="footer__payment-icon"
                height="40"
                loading="lazy"
              >
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "background-1",
          "label": "t:sections.footer.settings.color_scheme.options__3.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.footer.settings.color_scheme.options__4.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.footer.settings.color_scheme.options__5.label"
        }
      ],
      "default": "inverse",
      "label": "t:sections.footer.settings.color_scheme.label"
    },
    {
      "type": "header",
      "content": "Logo & Tagline"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Logo du footer"
    },
    {
      "type": "text",
      "id": "footer_tagline_1",
      "default": "De votre ciel de naissance",
      "label": "Tagline - ligne 1"
    },
    {
      "type": "text",
      "id": "footer_tagline_2",
      "default": "à votre œuvre astrale.",
      "label": "Tagline - ligne 2"
    },
    {
      "type": "header",
      "content": "Liens - Sections"
    },
    {
      "type": "text",
      "id": "footer_sections_title",
      "default": "SECTIONS",
      "label": "Titre de la colonne Sections"
    },
    {
      "type": "link_list",
      "id": "footer_menu_left",
      "label": "Menu sections (gauche)"
    },
    {
      "type": "link_list",
      "id": "footer_menu_right",
      "label": "Menu sections (droite)"
    },
    {
      "type": "header",
      "content": "Réseaux sociaux"
    },
    {
      "type": "text",
      "id": "footer_social_title",
      "default": "SOCIAL MEDIA",
      "label": "Titre de la colonne Social"
    },
    {
      "type": "header",
      "content": "Paiement"
    },
    {
      "type": "text",
      "id": "footer_payment_title",
      "default": "MOYENS DE PAIEMENT",
      "label": "Titre section paiement"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_1",
      "label": "Icône paiement 1"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_2",
      "label": "Icône paiement 2"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_3",
      "label": "Icône paiement 3"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_4",
      "label": "Icône paiement 4"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_5",
      "label": "Icône paiement 5"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_6",
      "label": "Icône paiement 6"
    }
  ]
}
{% endschema %}
