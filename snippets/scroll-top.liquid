<style>
  .scroll-top {
    display: block !important;
    position: fixed !important;
    bottom: 2rem;
    right: 2rem;
    z-index: 999;
    border: none;
    background: none !important;
    padding: 0;
    cursor: pointer;
    opacity: 1 !important;
    visibility: visible !important;
  }

  .scroll-top__img {
    width: 40px;
    height: 40px;
    display: block;
  }

  @media (min-width: 750px) {
    .scroll-top {
      bottom: auto;
      top: 75%;
      right: 3rem;
      transform: translateY(-50%);
    }

    .scroll-top__img {
      width: 48px;
      height: 48px;
    }
  }

  @media (min-width: 1300px) {
    .scroll-top {
      right: calc((100vw - 1200px) / 4);
    }

    .scroll-top__img {
      width: 56px;
      height: 56px;
    }
  }
</style>

<button class="scroll-top" aria-label="Retour en haut">
  <img src="{{ 'iconTop.png' | asset_url }}" alt="Retour en haut" class="scroll-top__img" loading="lazy">
</button>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.querySelector('.scroll-top');
    if (!btn) return;

    btn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
