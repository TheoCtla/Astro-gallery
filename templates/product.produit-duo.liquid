<!-- Script de connexion des variantes -->
<script type="application/json" id="product-variants-json-duo">
  {{ product.variants | json }}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // ===== CONNEXION DES VARIANTES POUR DUO =====
  // Ce script détecte les sélections de l'utilisateur et met à jour le variant ID et le prix
  
  const variantsData = JSON.parse(document.getElementById('product-variants-json-duo').textContent);
  const formatSelect = document.getElementById('format-oeuvre');
  const matiereSelect = document.getElementById('matiere-support');
  const encadrementSelect = document.getElementById('encadrement-oeuvre');
  // Correction du sélecteur pour l'input variant ID
  const variantInput = document.querySelector('#product-form-solo input[name="id"]');
  // Sélectionner tous les éléments de prix (regular et sale)
  const priceElement = document.querySelector('#price-duo .price-item--regular') || document.querySelector('#price-duo .price-item--sale');
  
  console.log('=== CONNEXION VARIANTES DUO ===');
  console.log('Nombre de variantes:', variantsData.length);
  console.log('formatSelect trouvé:', !!formatSelect);
  console.log('matiereSelect trouvé:', !!matiereSelect);
  console.log('encadrementSelect trouvé:', !!encadrementSelect);
  console.log('variantInput trouvé:', !!variantInput);
  console.log('priceElement trouvé:', !!priceElement);
  
  // Mapping des valeurs du formulaire vers les noms Shopify (exactement comme dans le CSV)
  const formatMapping = {
    'ronde-40x40': 'Ronde (40 x 40)',
    'ronde-50x50': 'Ronde (50 x 50)',
    'carree-40x40': 'Carré (40 x 40)',
    'carree-50x50': 'Carré (50 x 50)',
    'rectangle-vertical-35x50': 'Rectangulaire vertical (35 x 50)',
    'rectangle-vertical-50x70': 'Rectangulaire vertical (50 x 70)',
    'rectangle-horizontal-50x35': 'Rectangulaire horizontal (50 x 35)',
    'rectangle-horizontal-70x50': 'Rectangulaire horizontal (70 x 50)'
  };
  
  // Noms exacts des matières dans Shopify
  const matiereMapping = {
    'alu-dibond': 'Alu dibond',
    'plexi-brillant': "Plexi'art",
    'plexi-mat': "PlexiI'art mat anti-reflet"
  };
  
  // Noms exacts des encadrements dans Shopify
  const encadrementMapping = {
    'attache-metal': 'Attache métal',
    'chassis': 'Chassis',
    'slim': 'Slim',
    'box-noir': 'Caisse Américaine Noir',
    'box-alu-noir': 'Caisse Américaine Alu Noir',
    'box-blanc': 'CADRE BOX US ALUMINIUM',
    'box-chene': 'Caisse Américaine Chêne Naturel'
  };
  
  function findMatchingVariant() {
    if (!formatSelect || !matiereSelect || !encadrementSelect) {
      console.log('Selects non trouvés');
      return null;
    }
    
    const formatValue = formatMapping[formatSelect.value];
    const matiereValue = matiereMapping[matiereSelect.value];
    const encadrementValue = encadrementMapping[encadrementSelect.value];
    
    // CORRECTION SPECIFIQUE: Pour le format Rond, "Chassis" dans l'UI correspond à "Attache métal" dans les variantes Shopify
    let targetEncadrement = encadrementValue;
    if (formatValue && formatValue.toLowerCase().includes('ronde') && encadrementSelect.value === 'chassis') {
        console.log('🔄 Remapping Chassis -> Attache métal pour le format Rond (DUO)');
        targetEncadrement = 'Attache métal';
    }

    console.log('Recherche variante DUO:', formatValue, '|', matiereValue, '|', targetEncadrement);
    
    // Chercher la variante correspondante avec comparaison exacte
    const matchingVariant = variantsData.find(function(variant) {
      // Vérifier que les 3 options correspondent (peu importe l'ordre)
      const options = [variant.option1, variant.option2, variant.option3];
      
      const hasFormat = options.includes(formatValue);
      const hasMatiere = options.includes(matiereValue);
      const hasEncadrement = options.includes(targetEncadrement);
      
      return hasFormat && hasMatiere && hasEncadrement;
    });
    
    if (matchingVariant) {
      console.log('Variante DUO trouvée:', matchingVariant.id, '-', matchingVariant.title, '- Prix:', matchingVariant.price);
    } else {
      console.log('Aucune variante DUO correspondante trouvée');
      console.log('Options recherchées:', formatValue, matiereValue, encadrementValue);
      // Afficher quelques variantes pour debug
      console.log('Premières variantes disponibles:', variantsData.slice(0, 3).map(v => ({
        id: v.id,
        opt1: v.option1,
        opt2: v.option2,
        opt3: v.option3
      })));
    }
    
    return matchingVariant;
  }
  
  // Référence vers l'élément d'affichage principal pour les images
  const mainDisplay = document.querySelector('.product__media-item');
  const thumbs = document.querySelectorAll('.product__thumbnail');
  
  function updateVariant() {
    const variant = findMatchingVariant();
    
    if (variant) {
      // Mettre à jour l'input variant ID
      if (variantInput) {
        variantInput.value = variant.id;
        console.log('Variant ID DUO mis à jour:', variant.id);
      }
      
      // Mettre à jour aussi l'input dans le formulaire d'installment
      const installmentInput = document.querySelector('#product-form-installment-solo input[name="id"]');
      if (installmentInput) {
        installmentInput.value = variant.id;
      }
      
      // Formater le prix
      const formattedPrice = (variant.price / 100).toLocaleString('fr-FR', {
        style: 'currency',
        currency: 'EUR'
      });
      
      // Mettre à jour tous les éléments de prix dans le wrapper
      const priceWrapper = document.querySelector('#price-duo');
      if (priceWrapper) {
        const allPrices = priceWrapper.querySelectorAll('.price-item');
        allPrices.forEach(function(el) {
          el.textContent = formattedPrice;
        });
        console.log('Prix DUO mis à jour:', formattedPrice);
      }
      
      // Mettre à jour aussi le prix dans la section des boutons
      const priceButtonsWrapper = document.querySelector('#price-display-buttons-duo');
      if (priceButtonsWrapper) {
        const buttonPrices = priceButtonsWrapper.querySelectorAll('.price-item');
        buttonPrices.forEach(function(el) {
          el.textContent = formattedPrice;
        });
      }
    }
    
    // ===== MISE À JOUR DE L'IMAGE =====
    updateImageDisplay();
  }
  
  function updateImageDisplay() {
    const format = formatSelect ? formatSelect.value : "";
    const matiere = matiereSelect ? matiereSelect.value : "";
    const encadrement = encadrementSelect ? encadrementSelect.value : "";
    
    console.log('Update Duo Image - Format:', format, 'Matiere:', matiere, 'Encadrement:', encadrement);

    let targetImage = '';

    // CAS 1 : Tout est vide (initial) -> On ne fait rien (la vidéo reste)
    if (format === "" && matiere === "" && encadrement === "") {
        return; 
    }

    // PRIORITY 1 : Combinaison complète (Format + Matière + Encadrement sont sélectionnés)
    if (format !== "" && matiere !== "" && encadrement !== "") {
        console.log('Update Duo: Case FULL COMBINATION');
        
        // --- ROND ---
        if (format === 'ronde-40x40') {
             if (matiere === 'alu-dibond') {
                 // Rond Mat Chassis (Seule option)
                 if (encadrement === 'chassis') targetImage = "{{ '_duo-ronde-mat-chassis.webp' | asset_url }}";
             } else if (matiere === 'plexi-brillant') { // Brillant
                 if (encadrement === 'chassis') targetImage = "{{ '_duo-ronde-brillant-chassis.webp' | asset_url }}";
             }
        }
        
        // --- CARRE ---
        else if (format === 'carree-40x40') {
            if (matiere === 'alu-dibond') { // Mat
                if (encadrement === 'chassis') targetImage = "{{ '_duo-carre-mat-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_duo-carre-mat-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_duo-carre-mat-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_duo-carre-mat-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_duo-carre-mat-chene.webp' | asset_url }}";
            } else if (matiere === 'plexi-brillant') { // Brillant
                if (encadrement === 'chassis') targetImage = "{{ '_duo-carre-brillant-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_duo-carre-brillant-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_duo-carre-brillant-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_duo-carre-brillant-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_duo-carre-brillant-chene.webp' | asset_url }}";
            }
        }
        
        // --- VERTICAL ---
        else if (format === 'rectangle-vertical-35x50') {
            if (matiere === 'alu-dibond') { // Mat
                if (encadrement === 'chassis') targetImage = "{{ '_duo-vertical-mat-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_duo-vertical-mat-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_duo-vertical-mat-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_duo-vertical-mat-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_duo-vertical-mat-chene.webp' | asset_url }}";
            } else if (matiere === 'plexi-brillant') { // Brillant
                if (encadrement === 'chassis') targetImage = "{{ '_duo-vertical-brillant-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_duo-vertical-brillant-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_duo-vertical-brillant-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_duo-vertical-brillant-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_duo-vertical-brillant-chene.webp' | asset_url }}";
            }
        }
        
        // --- HORIZONTAL ---
        else if (format === 'rectangle-horizontal-50x35') {
            if (matiere === 'alu-dibond') { // Mat
                if (encadrement === 'chassis') targetImage = "{{ '_duo-horizontal-mat-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_duo-horizontal-mat-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_duo-horizontal-mat-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_duo-horizontal-mat-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_duo-horizontal-mat-chene.webp' | asset_url }}";
            } else if (matiere === 'plexi-brillant') { // Brillant
                if (encadrement === 'chassis') targetImage = "{{ '_duo-horizontal-brillant-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_duo-horizontal-brillant-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_duo-horizontal-brillant-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_duo-horizontal-brillant-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_duo-horizontal-brillant-chene.webp' | asset_url }}";
            }
        }
    }

    // PRIORITY 2 : Format et Matière sélectionnés (Encadrement vide)
    else if (format !== "" && matiere !== "" && encadrement === "") {
        console.log('Update Duo: Case FORMAT + MATIERE');
        // On affiche une image par défaut de cette combinaison (ex: Chassis)
        if (format.includes('ronde')) {
             if (matiere === 'alu-dibond') targetImage = "{{ '_duo-ronde-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_duo-ronde-brillant-chassis.webp' | asset_url }}";
        }
        else if (format.includes('carree')) {
             if (matiere === 'alu-dibond') targetImage = "{{ '_duo-carre-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_duo-carre-brillant-chassis.webp' | asset_url }}";
        }
        else if (format.includes('vertical')) {
             if (matiere === 'alu-dibond') targetImage = "{{ '_duo-vertical-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_duo-vertical-brillant-chassis.webp' | asset_url }}";
        }
        else if (format.includes('horizontal')) {
             if (matiere === 'alu-dibond') targetImage = "{{ '_duo-horizontal-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_duo-horizontal-brillant-chassis.webp' | asset_url }}";
        }
    }

    // PRIORITY 3 : Format uniquement ou fallback
    else if (format !== "") {
        console.log('Update Duo: Case FORMAT ONLY');
        // Default to Brillant + Chassis for basic format view
        if (format.includes('ronde')) targetImage = "{{ '_duo-ronde-brillant-chassis.webp' | asset_url }}";
        else if (format.includes('carree')) targetImage = "{{ '_duo-carre-brillant-chassis.webp' | asset_url }}";
        else if (format.includes('vertical')) targetImage = "{{ '_duo-vertical-brillant-chassis.webp' | asset_url }}";
        else if (format.includes('horizontal')) targetImage = "{{ '_duo-horizontal-brillant-chassis.webp' | asset_url }}";
    }


    if (targetImage) {
        console.log('Switching to target image:', targetImage);
        if (mainDisplay) {
            mainDisplay.innerHTML = `<img src="${targetImage}" class="product__main-image" id="main-product-image-duo" style="width: 100%; height: auto; cursor: zoom-in;">`;
            
            thumbs.forEach(t => t.classList.remove('active'));
            const matchingThumb = Array.from(thumbs).find(t => {
               const thumbSrc = t.getAttribute('data-image-src');
               return thumbSrc && (thumbSrc.includes(targetImage) || targetImage.includes(thumbSrc));
            });
            
            if (matchingThumb) {
              matchingThumb.classList.add('active');
            } else {
               const exactThumb = document.querySelector(`.product__thumbnail[data-image-src="${targetImage}"]`);
               if(exactThumb) exactThumb.classList.add('active');
            }
        } else {
            console.error('mainDisplay not found!');
        }
    }
  }
  
  // Écouter les changements sur tous les selects
  if (formatSelect) {
    formatSelect.addEventListener('change', updateVariant);
    formatSelect.addEventListener('input', updateVariant);
  }
  if (matiereSelect) {
    matiereSelect.addEventListener('change', updateVariant);
    matiereSelect.addEventListener('input', updateVariant);
  }
  if (encadrementSelect) {
    encadrementSelect.addEventListener('change', updateVariant);
    encadrementSelect.addEventListener('input', updateVariant);
  }
  
  // Mise à jour initiale
  updateVariant();
  
  // ===== FILTRAGE DYNAMIQUE DES ENCADREMENTS =====
  // Règles :
  // 1. Format Ronde : seulement Attache métal et Chassis
  // 2. Chassis : désactivé si Alu Dibond
  // 3. Slim : désactivé si Plexi'Art ou Plexi'Art Mat
  
  // Encadrements disponibles par format
  const encadrementsForRonde = ['attache-metal', 'chassis'];
  const encadrementsForCarre = ['attache-metal', 'chassis', 'slim', 'box-noir', 'box-alu-noir', 'box-blanc', 'box-chene'];
  
  function filterEncadrements() {
    if (!formatSelect || !matiereSelect || !encadrementSelect) return;
    
    const format = formatSelect.value;
    const matiere = matiereSelect.value;
    const currentEncadrement = encadrementSelect.value;
    
    // Déterminer si c'est un format rond
    const isRonde = format.startsWith('ronde');
    
    // Déterminer les encadrements disponibles selon le format
    const availableEncadrements = isRonde ? encadrementsForRonde : encadrementsForCarre;
    
    // Parcourir toutes les options d'encadrement
    const options = encadrementSelect.querySelectorAll('option');
    let firstAvailable = null;
    let currentIsAvailable = false;
    
    options.forEach(function(option) {
      const value = option.value;
      
      // Allow empty value (placeholder "Choisir...") to be always available
      if (value === "") {
          option.disabled = true;
          option.style.display = '';
          if (value === currentEncadrement) {
            currentIsAvailable = true;
          }
          return;
      }

      let isAvailable = availableEncadrements.includes(value);
      
      // Appliquer les règles supplémentaires basées sur la matière
      if (isAvailable) {
        // Règle : Chassis désactivé si Alu Dibond (SAUF pour le format Rond qui l'accepte)
        // [MODIFICATION] Restriction levée : Mat + Chassis est maintenant autorisé pour tous les formats.
        // if (value === 'chassis' && matiere === 'alu-dibond' && !isRonde) {
        //   isAvailable = false;
        // }
        // Règle : Slim désactivé si Plexi'Art ou Plexi'Art Mat
        if (value === 'slim' && (matiere === 'plexi-brillant' || matiere === 'plexi-mat')) {
          isAvailable = false;
        }
      }
      
      // Appliquer la disponibilité
      option.disabled = !isAvailable;
      option.style.display = isAvailable ? '' : 'none';
      
      if (isAvailable && !firstAvailable) {
        firstAvailable = value;
      }
      if (value === currentEncadrement && isAvailable) {
        currentIsAvailable = true;
      }
    });
    
    // Si l'encadrement actuel n'est plus disponible, sélectionner le premier disponible
    if (!currentIsAvailable && firstAvailable) {
      encadrementSelect.value = firstAvailable;
      console.log('Encadrement DUO auto-sélectionné:', firstAvailable);
    }
    
    // Mettre à jour la variante après le filtrage
    updateVariant();
  }
  
  // Écouter les changements pour le filtrage
  if (formatSelect) {
    formatSelect.addEventListener('change', filterEncadrements);
  }
  if (matiereSelect) {
    matiereSelect.addEventListener('change', filterEncadrements);
  }
  
  // Filtrage initial au chargement
  filterEncadrements();
});
</script>

<script>
  // Script pour le carrousel vertical de miniatures (et horizontal sur mobile)
  document.addEventListener('DOMContentLoaded', function() {
    const carousel = document.getElementById('thumbnail-carousel');
    const btnUp = document.querySelector('.thumb-nav-up');
    const btnDown = document.querySelector('.thumb-nav-down');
    const scrollAmount = 120; // Scroll d'environ une vignette + marge

    if (carousel && btnUp && btnDown) {
      btnUp.addEventListener('click', function() {
        if (window.innerWidth < 990) {
            // Mode horizontal (bouton gauche)
            carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        } else {
            // Mode vertical (bouton haut)
            carousel.scrollBy({ top: -scrollAmount, behavior: 'smooth' });
        }
      });

      btnDown.addEventListener('click', function() {
        if (window.innerWidth < 990) {
            // Mode horizontal (bouton droit)
            carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        } else {
            // Mode vertical (bouton bas)
            carousel.scrollBy({ top: scrollAmount, behavior: 'smooth' });
        }
      });

    }
  });
</script>

