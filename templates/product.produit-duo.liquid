  <!-- Schema SEO -->
  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media -%}
        "image": [
          {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
        ],
      {%- endif %}
      "description": {{ product.description | strip_html | json }},
      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>

<!-- JavaScript pour le slider et la modal -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Gestion des miniatures cliquables
  const thumbnails = document.querySelectorAll('.product-solo-section .product__thumbnail');
  const mainImage = document.getElementById('main-product-image-duo');
  
  thumbnails.forEach(function(thumbnail) {
    thumbnail.addEventListener('click', function() {
      // Retirer la classe active de toutes les miniatures
      thumbnails.forEach(function(t) {
        t.classList.remove('active');
      });
      // Ajouter la classe active à la miniature cliquée
      this.classList.add('active');
      // Changer l'image principale
      const newSrc = this.getAttribute('data-image-src');
      mainImage.src = newSrc;
    });
  });

  // Slider principal (si nécessaire)
  if (typeof $ !== 'undefined' && $.fn.slick) {
    $('.product-solo-section .product__media-sublist').each(function() {
      $(this).slick(getSubSliderProductSettings($(this).parent().find('.product__media-list')));
    });
  }

  // Synchroniser la quantité visible avec l'input du snippet lié au formulaire
  const quantityInputVisible = document.getElementById('Quantity-solo');
  const hiddenQuantity = document.getElementById('hidden-quantity-solo');
  // Trouver l'input du snippet par son attribut form
  const snippetQuantityInput = document.querySelector('input[form="product-form-solo"][name="quantity"]');
  const quantityWrapper = document.querySelector('.quantity-solo-wrapper quantity-input');
  
  function syncQuantity() {
    if (quantityInputVisible) {
      const qty = parseInt(quantityInputVisible.value) || 1;
      // Synchroniser avec l'input hidden
      if (hiddenQuantity) {
        hiddenQuantity.value = qty;
      }
      // Synchroniser avec l'input du snippet (celui lié au formulaire)
      if (snippetQuantityInput) {
        snippetQuantityInput.value = qty;
        // Déclencher un événement change pour que Shopify le détecte
        snippetQuantityInput.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }
  }
  
  if (quantityInputVisible) {
    // Synchroniser à chaque changement
    quantityInputVisible.addEventListener('change', syncQuantity);
    quantityInputVisible.addEventListener('input', syncQuantity);
    
    // Écouter les clics sur les boutons +/-
    if (quantityWrapper) {
      const buttons = quantityWrapper.querySelectorAll('button');
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          setTimeout(syncQuantity, 100);
        });
      });
    }
    
    // Synchroniser en continu pour être sûr
    setInterval(syncQuantity, 200);
  }

  // ===== SYNCHRONISATION DES PROPRIÉTÉS PERSONNALISÉES =====
  function syncCustomProperties() {
    // Format de l'œuvre
    const formatSelect = document.getElementById('format-oeuvre');
    const propFormat = document.getElementById('prop-format-oeuvre');
    if (formatSelect && propFormat) {
      propFormat.value = formatSelect.options[formatSelect.selectedIndex].text;
    }

    // Matière du support
    const matiereSelect = document.getElementById('matiere-support');
    const propMatiere = document.getElementById('prop-matiere-support');
    if (matiereSelect && propMatiere) {
      propMatiere.value = matiereSelect.options[matiereSelect.selectedIndex].text;
    }

    // Encadrement de l'œuvre
    const encadrementSelect = document.getElementById('encadrement-oeuvre');
    const propEncadrement = document.getElementById('prop-encadrement-oeuvre');
    if (encadrementSelect && propEncadrement) {
      propEncadrement.value = encadrementSelect.options[encadrementSelect.selectedIndex].text;
    }

    // ===== PERSONNE 1 =====
    const nomInput1 = document.getElementById('nom-prenom-1');
    const propNom1 = document.getElementById('prop-nom-prenom-1');
    if (nomInput1 && propNom1) {
      propNom1.value = nomInput1.value;
    }

    const dateInput1 = document.getElementById('date-naissance-1');
    const unknownDate1 = document.getElementById('unknown-date-naissance-1');
    const propDate1 = document.getElementById('prop-date-naissance-1');
    if (propDate1) {
      propDate1.value = (unknownDate1 && unknownDate1.checked) ? 'Je ne sais pas' : (dateInput1 ? dateInput1.value : '');
    }

    const heureInput1 = document.getElementById('heure-naissance-1');
    const unknownHeure1 = document.getElementById('unknown-heure-naissance-1');
    const propHeure1 = document.getElementById('prop-heure-naissance-1');
    if (propHeure1) {
      propHeure1.value = (unknownHeure1 && unknownHeure1.checked) ? 'Je ne sais pas' : (heureInput1 ? heureInput1.value : '');
    }

    const lieuInput1 = document.getElementById('lieu-naissance-1');
    const unknownLieu1 = document.getElementById('unknown-lieu-naissance-1');
    const propLieu1 = document.getElementById('prop-lieu-naissance-1');
    if (propLieu1) {
      propLieu1.value = (unknownLieu1 && unknownLieu1.checked) ? 'Je ne sais pas' : (lieuInput1 ? lieuInput1.value : '');
    }

    // ===== PERSONNE 2 =====
    const nomInput2 = document.getElementById('nom-prenom-2');
    const propNom2 = document.getElementById('prop-nom-prenom-2');
    if (nomInput2 && propNom2) {
      propNom2.value = nomInput2.value;
