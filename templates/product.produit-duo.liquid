    const dateInput2 = document.getElementById('date-naissance-2');
    const unknownDate2 = document.getElementById('unknown-date-naissance-2');
    const propDate2 = document.getElementById('prop-date-naissance-2');
    if (propDate2) {
      propDate2.value = (unknownDate2 && unknownDate2.checked) ? 'Je ne sais pas' : (dateInput2 ? dateInput2.value : '');
