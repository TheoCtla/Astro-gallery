});
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Logic specifically for mobile/tablet devices
    if (window.innerWidth < 990) {
      const sentinel = document.getElementById('mobile-sticky-sentinel');
      const stickyHeader = document.querySelector('.product__media-wrapper');
      
      if (sentinel && stickyHeader) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            // When sentinel scrolls out of view (top < 0), we are stuck
            if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
              stickyHeader.classList.add('is-stuck');
            } else {
              stickyHeader.classList.remove('is-stuck');
            }
          });
        }, { threshold: 0 });
        
        observer.observe(sentinel);

        // Hide carousel on scroll (mobile only)
        if (stickyHeader) {
          window.addEventListener('scroll', function() {
            if (window.scrollY > 20) { // Threshold de 20px pour éviter les micros-mouvements
              stickyHeader.classList.add('hide-carousel');
            } else {
              stickyHeader.classList.remove('hide-carousel');
            }
          }, { passive: true });
        }
      }
    }
  });
</script>
