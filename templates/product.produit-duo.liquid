              <input type="hidden" name="properties[Personne 1 - Heure de naissance]" id="prop-heure-naissance-1" value="">
              <input type="hidden" name="properties[Personne 1 - Lieu de naissance]" id="prop-lieu-naissance-1" value="">
              <!-- Personne 2 -->
              <input type="hidden" name="properties[Personne 2 - Nom & Prénom]" id="prop-nom-prenom-2" value="">
              <input type="hidden" name="properties[Personne 2 - Date de naissance]" id="prop-date-naissance-2" value="">
              <input type="hidden" name="properties[Personne 2 - Heure de naissance]" id="prop-heure-naissance-2" value="">
              <input type="hidden" name="properties[Personne 2 - Lieu de naissance]" id="prop-lieu-naissance-2" value="">
