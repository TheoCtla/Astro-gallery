                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    show_badges: false,
                    price_class: 'price--buttons'
                  -%}
                </div>
                <div class="product-form__buttons product-form__buttons--custom">
                  <button
                    type="submit"
                    name="add"
                    class="product-form__submit button button--primary-size button--gold"
                    {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
