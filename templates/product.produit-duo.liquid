<style>
  /* Styles pour le carrousel vertical de miniatures */
  .product__media-list-wrapper {
    display: flex;
    gap: 20px;
  }
  
  .product__thumbnail-carousel-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 80px; /* Largeur fixe pour la colonne de miniatures */
  }

  .product__media-thumbnails {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 450px; /* Hauteur visible ajustée */
    overflow-y: hidden; /* Scroll caché, contrôlé par JS */
    scroll-behavior: smooth;
    width: 100%;
    padding: 5px 0;
  }
  
  .product__thumbnail {
    width: 100%;
    height: auto;
    border: 1px solid transparent;
    cursor: pointer;
    padding: 0;
    background: none;
    flex-shrink: 0; /* Empêche l'écrasement */
  }
  
  .product__thumbnail img, .product__thumbnail video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }
  
  .product__thumbnail.active {
    border-color: rgb(223, 190, 113); /* Couleur de sélection */
  }

  .thumb-nav-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 30px;
    z-index: 2;
  }
  
  .thumb-nav-btn svg {
    width: 20px;
    height: 20px;
  }
  
  .thumb-nav-btn:hover {
    background-color: #dfbe71;
    border-radius: 4px;
  }
  
  /* Responsive : Carousel horizontal en dessous de l'image pour < 990px */
  @media screen and (max-width: 989px) {
    .product__media-list-wrapper {
      flex-direction: column; /* Image au dessus, miniatures en dessous */
      gap: 10px;
    }

    .product__thumbnail-carousel-wrapper {
        width: 100%; /* Pleine largeur */
        flex-direction: row; /* Flèche G - Liste - Flèche D */
        order: 2; /* Force l'affichage APRES l'image principale */
        justify-content: center;
    }

    .product__media-thumbnails {
        flex-direction: row; /* Horizontal */
        justify-content: flex-start; /* Force align start to show video */
        max-height: none;
        max-width: 100%;
        overflow-y: hidden;
        overflow-x: auto; /* Permet le scroll au doigt */
        -webkit-overflow-scrolling: touch; /* Scroll fluide sur iOS */
        scroll-behavior: smooth;
        height: 80px; /* Hauteur fixe pour les miniatures */
        width: calc(100% - 70px); /* Place pour les flèches */
        padding: 0 5px;
    }

    .product__thumbnail {
        height: 100%;
        width: auto; /* Largeur auto selon le ratio */
    }

    .product__thumbnail img, .product__thumbnail video {
        width: auto;
        height: 100%;
    }

    .thumb-nav-btn {
        width: 35px;
        height: 80px !important; /* Force height to match carousel */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }
    
    /* Rotation des flèches pour indiquer gauche/droite */
    .thumb-nav-up svg {
        transform: rotate(-90deg); /* Haut devient Gauche */
    }
    .thumb-nav-down svg {
        transform: rotate(-90deg); /* Bas devient Droite */
    }
    
    .product__media-list.list-unstyled {
      width: 100%;
      order: 1; /* Image principale en premier */
    }
  }
</style>

{%- assign first_3d_model = product.media | where: "media_type", "model" | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
