    const heureInput2 = document.getElementById('heure-naissance-2');
    const unknownHeure2 = document.getElementById('unknown-heure-naissance-2');
    const propHeure2 = document.getElementById('prop-heure-naissance-2');
    if (propHeure2) {
      propHeure2.value = (unknownHeure2 && unknownHeure2.checked) ? 'Je ne sais pas' : (heureInput2 ? heureInput2.value : '');
    }

    const lieuInput2 = document.getElementById('lieu-naissance-2');
    const unknownLieu2 = document.getElementById('unknown-lieu-naissance-2');
    const propLieu2 = document.getElementById('prop-lieu-naissance-2');
    if (propLieu2) {
      propLieu2.value = (unknownLieu2 && unknownLieu2.checked) ? 'Je ne sais pas' : (lieuInput2 ? lieuInput2.value : '');
    }

    // Type d'œuvre (radio)
    const typeRadio = document.querySelector('input[name="type-oeuvre"]:checked');
    const propType = document.getElementById('prop-type-oeuvre');
    if (propType && typeRadio) {
      if (typeRadio.value === 'siderale') {
        propType.value = 'Œuvre Sidérale';
      } else if (typeRadio.value === 'tropicale') {
        propType.value = 'Œuvre Tropicale';
      } else if (typeRadio.value === 'je-ne-sais-pas') {
        propType.value = 'Je ne sais pas';
      }
    }

    // Demandes particulières
    const demandesTextarea = document.getElementById('demandes-particulieres');
    const propDemandes = document.getElementById('prop-demandes-particulieres');
    if (demandesTextarea && propDemandes) {
      propDemandes.value = demandesTextarea.value;
    }
  }

  // Synchroniser avant la soumission du formulaire
  const productForm = document.getElementById('product-form-solo');
  if (productForm) {
    productForm.addEventListener('submit', function(e) {
      syncCustomProperties();
    });
  }

  // Synchroniser aussi lors des changements de champs
  const formFields = [
    'format-oeuvre', 'matiere-support', 'encadrement-oeuvre',
    'nom-prenom-1', 'date-naissance-1', 'heure-naissance-1', 'lieu-naissance-1',
    'nom-prenom-2', 'date-naissance-2', 'heure-naissance-2', 'lieu-naissance-2',
    'demandes-particulieres'
  ];
  formFields.forEach(function(fieldId) {
    const field = document.getElementById(fieldId);
    if (field) {
      field.addEventListener('change', syncCustomProperties);
      field.addEventListener('input', syncCustomProperties);
    }
  });

  // Synchroniser les radios
  const typeRadios = document.querySelectorAll('input[name="type-oeuvre"]');
  typeRadios.forEach(function(radio) {
    radio.addEventListener('change', syncCustomProperties);
  });

  // Synchronisation initiale
  syncCustomProperties();

  // ===== VALIDATION DES CHAMPS OBLIGATOIRES (DUO) =====
  const productFormDuo = document.getElementById('product-form-solo');
  const submitButtonDuo = productFormDuo ? productFormDuo.querySelector('.product-form__submit') : null;
  
  if (submitButtonDuo) {
    submitButtonDuo.addEventListener('click', function(e) {
      const requiredFieldsDuo = [
        { id: 'format-oeuvre', label: 'Format de l\'œuvre' },
        { id: 'matiere-support', label: 'Matière du support' },
        { id: 'encadrement-oeuvre', label: 'Encadrement de l\'œuvre' },
        // Personne 1
        { id: 'nom-prenom-1', label: 'Nom & Prénom (Personne 1)' },
        { id: 'date-naissance-1', label: 'Date de naissance (Personne 1)' },
        { id: 'heure-naissance-1', label: 'Heure exacte de naissance (Personne 1)' },
        { id: 'lieu-naissance-1', label: 'Lieu de naissance (Personne 1)' },
        // Personne 2
        { id: 'nom-prenom-2', label: 'Nom & Prénom (Personne 2)' },
        { id: 'date-naissance-2', label: 'Date de naissance (Personne 2)' },
        { id: 'heure-naissance-2', label: 'Heure exacte de naissance (Personne 2)' },
        { id: 'lieu-naissance-2', label: 'Lieu de naissance (Personne 2)' },
      ];

      let isValid = true;
      let firstInvalidField = null;

      // Retirer les erreurs précédentes
      document.querySelectorAll('.custom-form__input--error').forEach(el => el.classList.remove('custom-form__input--error'));
      document.querySelectorAll('.custom-form__error-message').forEach(el => el.remove());

      // Vérifier chaque champ
      requiredFieldsDuo.forEach(function (field) {
        const input = document.getElementById(field.id);
        // ✅ Ignorer les champs désactivés (checkbox "Je ne sais pas" cochée)
        // Pour les select, vérifier si value est vide ou si c'est l'option disabled
        const isEmpty = input && !input.disabled && (
          (input.tagName === 'SELECT' && (!input.value || input.value === '')) ||
          (input.tagName !== 'SELECT' && !input.value.trim())
        );
        
        if (isEmpty) {
          isValid = false;
          input.classList.add('custom-form__input--error');

          // Ajouter un message d'erreur
          const errorMsg = document.createElement('span');
          errorMsg.className = 'custom-form__error-message';
          errorMsg.textContent = 'Ce champ est obligatoire';
          errorMsg.style.cssText = 'color: #e74c3c; font-size: 12px; display: block; margin-top: 4px;';

          // Trouver le container .custom-form__field
          const fieldContainer = input.closest('.custom-form__field');
          if (fieldContainer) {
            fieldContainer.appendChild(errorMsg);
          } else {
            input.parentElement.appendChild(errorMsg);
          }

          if (!firstInvalidField) firstInvalidField = input;
        }
      });
      
      if (!isValid) {
        e.preventDefault();
        e.stopPropagation();
        // Scroll vers le premier champ invalide
        if (firstInvalidFieldDuo) {
          firstInvalidFieldDuo.scrollIntoView({ behavior: 'smooth', block: 'center' });
          firstInvalidFieldDuo.focus();
        }
        return false;
      }

      // ===== ENVOI VERS GOOGLE SHEETS (DUO) =====
      const GOOGLE_SHEETS_WEBHOOK = 'https://script.google.com/macros/s/AKfycbxeyFuzzUs4jVK6CZoq_AL3UPInDUI728DW6RTHM2kgJ9FkdLD-3qyZXPfhKGnm7w/exec';
      
      // Récupérer les champs du formulaire
      const formatSelect = document.getElementById('format-oeuvre');
      const matiereSelect = document.getElementById('matiere-support');
      const encadrementSelect = document.getElementById('encadrement-oeuvre');
      const typeRadio = document.querySelector('input[name="type-oeuvre"]:checked');
      const demandesTextarea = document.getElementById('demandes-particulieres');
      
      // Personne 1
      const nomPrenom1 = document.getElementById('nom-prenom-1');
      const dateNaissance1 = document.getElementById('date-naissance-1');
      const heureNaissance1 = document.getElementById('heure-naissance-1');
      const lieuNaissance1 = document.getElementById('lieu-naissance-1');
      
      // Personne 2
      const nomPrenom2 = document.getElementById('nom-prenom-2');
      const dateNaissance2 = document.getElementById('date-naissance-2');
      const heureNaissance2 = document.getElementById('heure-naissance-2');
      const lieuNaissance2 = document.getElementById('lieu-naissance-2');

      // Variables Checkboxes
      const unknownDateCheckbox1 = document.getElementById('unknown-date-naissance-1');
      const unknownHeureCheckbox1 = document.getElementById('unknown-heure-naissance-1');
      const unknownLieuCheckbox1 = document.getElementById('unknown-lieu-naissance-1');
      const unknownDateCheckbox2 = document.getElementById('unknown-date-naissance-2');
      const unknownHeureCheckbox2 = document.getElementById('unknown-heure-naissance-2');
      const unknownLieuCheckbox2 = document.getElementById('unknown-lieu-naissance-2');
      
      const emailInput = document.getElementById('email');
      const telephoneInput = document.getElementById('telephone');

      // Récupérer le prix dynamique de la variante sélectionnée
      const currentPriceElement = document.querySelector('#price-duo .price-item--regular') || document.querySelector('#price-duo .price-item');
      const currentPrice = currentPriceElement ? currentPriceElement.textContent.trim().replace(/[^\d,\.]/g, '') : '{{ product.price | money_without_currency }}';
      
      const googleSheetsData = {
        soloDuo: 'Duo',
        prix: currentPrice,
        sideralTropical: (typeRadio && typeRadio.value === 'je-ne-sais-pas') ? 'Je ne sais pas' : (typeRadio && typeRadio.value === 'siderale' ? 'Œuvre Sidérale' : 'Œuvre Tropicale'),
        
        // Personne 1
        nomPrenom1: nomPrenom1 ? nomPrenom1.value : '',
        dateNaissance1: (unknownDateCheckbox1 && unknownDateCheckbox1.checked) ? 'Je ne sais pas' : (dateNaissance1 ? dateNaissance1.value : ''),
        heureNaissance1: (unknownHeureCheckbox1 && unknownHeureCheckbox1.checked) ? 'Je ne sais pas' : (heureNaissance1 ? heureNaissance1.value : ''),
        lieuNaissance1: (unknownLieuCheckbox1 && unknownLieuCheckbox1.checked) ? 'Je ne sais pas' : (lieuNaissance1 ? lieuNaissance1.value : ''),
        
        // Personne 2
        nomPrenom2: nomPrenom2 ? nomPrenom2.value : '',
        dateNaissance2: (unknownDateCheckbox2 && unknownDateCheckbox2.checked) ? 'Je ne sais pas' : (dateNaissance2 ? dateNaissance2.value : ''),
        heureNaissance2: (unknownHeureCheckbox2 && unknownHeureCheckbox2.checked) ? 'Je ne sais pas' : (heureNaissance2 ? heureNaissance2.value : ''),
        lieuNaissance2: (unknownLieuCheckbox2 && unknownLieuCheckbox2.checked) ? 'Je ne sais pas' : (lieuNaissance2 ? lieuNaissance2.value : ''),
        
        // Contact
        email: emailInput ? emailInput.value : '',
        telephone: telephoneInput ? telephoneInput.value : '',
        
        demandeParticuliere: demandesTextarea ? demandesTextarea.value : '',
        formatOeuvre: formatSelect ? formatSelect.options[formatSelect.selectedIndex].text : '',
        matiereSupport: matiereSelect ? matiereSelect.options[matiereSelect.selectedIndex].text : '',
        encadrement: encadrementSelect ? encadrementSelect.options[encadrementSelect.selectedIndex].text : ''
      };

      // 🐛 DEBUG: Afficher les données envoyées au Google Sheet
      console.log('📊 Données envoyées au Google Sheet (DUO):', googleSheetsData);

      // Envoyer vers Google Sheets (mode no-cors, non bloquant)
      fetch(GOOGLE_SHEETS_WEBHOOK, {
        method: 'POST',
        mode: 'no-cors',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(googleSheetsData)
      })
      .then(function() {
        console.log('Données Duo envoyées vers Google Sheets');
      })
      .catch(function(error) {
        console.error('Erreur envoi Google Sheets:', error);
      });
      // ===== FIN ENVOI GOOGLE SHEETS =====

      // La soumission du formulaire se poursuit normalement
    });
  }
  // ===== FIN VALIDATION DUO =====

  });

// Custom element pour la modal produit
if (!customElements.get('product-modal')) {
  class ProductModal extends ModalDialog {
    constructor() {
      super();
    }

    hide() {
      super.hide();
      window.pauseAllMedia();
    }

    show(opener) {
      super.show(opener);
      this.showActiveMedia();
    }

    showActiveMedia() {
      this.querySelectorAll(`[data-media-id]:not([data-media-id="${this.openedBy.getAttribute("data-media-id")}"])`).forEach((element) => {
        element.classList.remove('active');
      });
      const activeMedia = this.querySelector(`[data-media-id="${this.openedBy.getAttribute("data-media-id")}"]`);
      if (activeMedia) {
        activeMedia.classList.add('active');
        activeMedia.scrollIntoView();

        if (activeMedia.nodeName == 'DEFERRED-MEDIA' && activeMedia.querySelector('template')?.content?.querySelector('.js-youtube'))
          activeMedia.loadContent();
      }
    }
  }

  customElements.define('product-modal', ProductModal);
}
</script>

