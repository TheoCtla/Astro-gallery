  <script>
    document.addEventListener('DOMContentLoaded', function() {
        
        // ===== GESTION DES CHECKBOXES "JE NE SAIS PAS" =====
      function setupUnknownCheckbox(checkboxId, fieldId) {
        const checkbox = document.getElementById(checkboxId);
        const field = document.getElementById(fieldId);
        
        if (checkbox && field) {
          // Vérifier l'état initial au chargement
          if (checkbox.checked) {
            console.log(`${checkboxId} est cochée au chargement, désactivation du champ`);
            field.removeAttribute('required');
            field.disabled = true;
            field.value = '';
            field.setCustomValidity(''); // Effacer le message d'erreur du navigateur
            field.classList.add('custom-form__input--disabled');
          }
          
          // Écouter les changements
          checkbox.addEventListener('change', function() {
            console.log(`${checkboxId} changed to:`, this.checked);
            if (this.checked) {
              // Checkbox cochée : retirer required et désactiver le champ
              field.removeAttribute('required');
              field.disabled = true;
              field.value = ''; // Vider le champ
              field.setCustomValidity(''); // Effacer le message d'erreur du navigateur
              field.classList.add('custom-form__input--disabled');
              console.log(`${fieldId} désactivé et required retiré`);
            } else {
              // Checkbox décochée : remettre required et réactiver le champ
              field.setAttribute('required', 'required');
              field.disabled = false;
              field.setCustomValidity(''); // Réinitialiser la validation
              field.classList.remove('custom-form__input--disabled');
              console.log(`${fieldId} réactivé et required ajouté`);
            }
          });
        }
      }

      console.log('=== INITIALISATION CHECKBOXES DUO "JE NE SAIS PAS" ===');
      
      // Personne 1
      setupUnknownCheckbox('unknown-date-naissance-1', 'date-naissance-1');
      setupUnknownCheckbox('unknown-heure-naissance-1', 'heure-naissance-1');
      setupUnknownCheckbox('unknown-lieu-naissance-1', 'lieu-naissance-1');
      
      // Personne 2
      setupUnknownCheckbox('unknown-date-naissance-2', 'date-naissance-2');
      setupUnknownCheckbox('unknown-heure-naissance-2', 'heure-naissance-2');
      setupUnknownCheckbox('unknown-lieu-naissance-2', 'lieu-naissance-2');
      
      console.log('=== FIN INITIALISATION CHECKBOXES DUO ===');
      const faqItems = document.querySelectorAll('.faq-item__header');
      
      faqItems.forEach(function(header) {
        header.addEventListener('click', function() {
          const item = this.closest('.faq-item');
          const isOpen = item.classList.contains('faq-item--open');
          
          if (isOpen) {
            item.classList.remove('faq-item--open');
            this.setAttribute('aria-expanded', 'false');
          } else {
            item.classList.add('faq-item--open');
            this.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  </script>

