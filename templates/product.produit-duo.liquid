  <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'component-model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<section class="container product-solo-section">
  <div class="product row gallery-left gallery-before">
    
    <!-- Colonne Informations Produit -->
    <div class="product__info-wrapper col-lg-6">
      <div id="ProductInfo-solo" class="product__info-container product__info-container--sticky">
        
        {%- assign product_form_id = 'product-form-solo' -%}

        <!-- Vendor -->
        <p class="product__text subtitle">
          {{ product.vendor }}
        </p>

        <!-- Titre -->
        <div class="product__title__wrapper
          {%- if product.available == false %} price--sold-out {% endif -%}
          {%- if product.compare_at_price > product.price %} price--on-sale {% endif -%}">
          <h1 class="product__title h2">
            L'ŒUVRE<br>ASTRALE <span class="gold">DUO</span>
          </h1>
          <div class="badge-wrapper">
            <span class="badge price__badge-sale color-background-2" aria-hidden="true">
              {{ 'products.product.on_sale' | t }}
            </span>
            <span class="badge price__badge-sold-out color-{{ settings.sold_out_badge_color_scheme }}" aria-hidden="true">
              {{ 'products.product.sold_out' | t }}
            </span>
          </div>
        </div>

        <!-- Sous-titre -->
        <p class="product__subtitle">Une œuvre numérotée, nominative et unique, née de deux ciels réunis.</p>

        <!-- Description -->
        <div class="product__description rte">
          <p>À partir de vos deux thèmes natals, ASTROGALLERY crée une œuvre astrale design qui révèle l'alchimie entre deux êtres :<br>
          vos forces partagées, vos contrastes, vos complémentarités.</p>
          <p>Chaque création est <strong>numérotée, nominative</strong> et accompagnée d'un <strong>livret DUO de 110 pages</strong>, dont <strong>40 pages entièrement personnalisées</strong> à vos deux ciels.</p>
          <p><strong>Designée et fabriquée en France</strong><br>
          Création et livraison en 3 à 4 semaines.</p>
        </div>

        <!-- Prix et Quantité -->
        <div class="price-quantity-wrapper">
          <div class="no-js-hidden price-wrapper" id="price-duo">
            {%- render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--product' -%}
          </div>
        </div>
        <div style="margin: 0">
          {%- form 'product', product, id: 'product-form-installment-solo', class: 'installment caption-large' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {{ form | payment_terms }}
          {%- endform -%}
        </div>

        <!-- Tags -->
        {%- if product.tags != blank -%}
          <ul class="product-tags">
            {% for tag in product.tags %}
              <li class="product-tags__tag">{{ tag }} {% render 'icon-checkmark' %}</li>
            {% endfor %}
          </ul>
        {%- endif -%}

        <!-- Sélecteur de variantes désactivé - on utilise le formulaire personnalisé à la place -->
        <!--
        <div style="display: none;">
          {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
        </div>
        -->

        <!-- Formulaire personnalisé -->
        <div class="custom-product-form">
          <!-- Format de l'œuvre -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full custom-form__field--with-help">
              <label class="custom-form__label">Format de l'œuvre</label>
              <div class="custom-form__select-wrapper">
                <select class="custom-form__select" id="format-oeuvre">
                  <option value="" disabled selected>Choisir...</option>
                  <option value="ronde-40x40">Ronde (40 cm de diamètre)</option>
                  <option value="carree-40x40">Carrée (40 x 40 cm)</option>
                  <option value="rectangle-vertical-35x50">Rectangle vertical (35 x 50 cm)</option>
                  <option value="rectangle-horizontal-50x35">Rectangle horizontal (50 x 35 cm)</option>
                </select>
                {% render 'icon-caret' %}
              </div>
              <a href="#faq-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
            </div>
          </div>

          <!-- Matière du support -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full custom-form__field--with-help">
              <label class="custom-form__label">Matière du support</label>
              <div class="custom-form__select-wrapper">
                <select class="custom-form__select" id="matiere-support">
                  <option value="" disabled selected>Choisir...</option>
                  <option value="alu-dibond">Mat (Alu dibond)</option>
                  <option value="plexi-brillant">Brillant (Plexi'Art brillant)</option>
                </select>
                {% render 'icon-caret' %}
              </div>
              <a href="#matiere-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
            </div>
          </div>

          <!-- Encadrement de l'œuvre -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full custom-form__field--with-help">
              <label class="custom-form__label">Encadrement de l'œuvre</label>
              <div class="custom-form__select-wrapper">
                <select class="custom-form__select" id="encadrement-oeuvre">
                  <option value="" disabled selected>Choisir...</option>
                  <option value="chassis">Chassis</option>
                  <option value="box-blanc">Caisse Américaine Blanche</option>
                   <option value="box-noir">Caisse Américaine Noire</option>
                  <option value="box-alu-noir">Caisse Américaine Alu Noir</option>
                  <option value="box-chene">Caisse Américaine Chêne Naturel</option>
                </select>
                {% render 'icon-caret' %}
              </div>
              <a href="#cadre-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
            </div>
          </div>

          <!-- Texte d'information -->
          <div class="custom-form__row custom-form__row--no-border">
            <p style="font-size: 1.3rem; color: #e1c37d; margin: 10px 0; font-style: italic; margin-bottom: 1.8rem; padding-bottom: 1.8rem; border-bottom: 1px solid #f0f0f0;">
              Si vous ne connaissez pas encore certaines informations nécessaires, vous pouvez simplement indiquer « Je ne sais pas » et nous transmettre les éléments manquants ultérieurement.
            </p>
          </div>

          <!-- ===== PERSONNE 1 ===== -->

          <div class="custom-form__section-header">
            <h3 class="custom-form__section-title">Personne 1</h3>
          </div>

          <!-- Nom & Prénom + Date de naissance - Personne 1 -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Nom & Prénom<span class="required">*</span></label>
              <input type="text" class="custom-form__input" id="nom-prenom-1" placeholder="–" required>
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Date de naissance (JJ-MM-AA)<span class="required">*</span></label>
              <div class="custom-form__input-wrapper">
                <input type="date" class="custom-form__input" id="date-naissance-1" required>
                <span class="custom-form__input-icon">📅</span>
              </div>
              <!-- Checkbox Je ne sais pas pour Date de naissance 1 -->
              <div class="custom-form__checkbox-wrapper">
                <label class="custom-form__checkbox-label">
                  <input type="checkbox" id="unknown-date-naissance-1" class="custom-form__checkbox">
                  <span class="custom-form__checkbox-text">Je ne sais pas</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Heure exacte + Lieu de naissance - Personne 1 -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Heure exacte de naissance<span class="required">*</span></label>
              <div class="custom-form__input-wrapper">
                <input type="time" class="custom-form__input" id="heure-naissance-1" required>
                <span class="custom-form__input-icon">🕐</span>
              </div>
              <!-- Checkbox Je ne sais pas pour Heure de naissance 1 -->
              <div class="custom-form__checkbox-wrapper">
                <label class="custom-form__checkbox-label">
                  <input type="checkbox" id="unknown-heure-naissance-1" class="custom-form__checkbox">
                  <span class="custom-form__checkbox-text">Je ne sais pas</span>
                </label>
              </div>
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Lieu de naissance (ville+ pays)<span class="required">*</span></label>
              <input type="text" class="custom-form__input" id="lieu-naissance-1" placeholder="–" required>
              <!-- Checkbox Je ne sais pas pour Lieu de naissance 1 -->
              <div class="custom-form__checkbox-wrapper">
                <label class="custom-form__checkbox-label">
                  <input type="checkbox" id="unknown-lieu-naissance-1" class="custom-form__checkbox">
                  <span class="custom-form__checkbox-text">Je ne sais pas</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Email + Téléphone -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Email</label>
              <input type="email" class="custom-form__input" id="email" placeholder="–">
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Téléphone</label>
              <input type="tel" class="custom-form__input" id="telephone" placeholder="–">
            </div>
          </div>

          <!-- ===== PERSONNE 2 ===== -->
          <div class="custom-form__section-header">
            <h3 class="custom-form__section-title">Personne 2</h3>
          </div>

          <!-- Nom & Prénom + Date de naissance - Personne 2 -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Nom & Prénom<span class="required">*</span></label>
              <input type="text" class="custom-form__input" id="nom-prenom-2" placeholder="–" required>
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Date de naissance (JJ-MM-AA)<span class="required">*</span></label>
              <div class="custom-form__input-wrapper">
                <input type="date" class="custom-form__input" id="date-naissance-2" required>
                <span class="custom-form__input-icon">📅</span>
              </div>
              <!-- Checkbox Je ne sais pas pour Date de naissance 2 -->
              <div class="custom-form__checkbox-wrapper">
                <label class="custom-form__checkbox-label">
                  <input type="checkbox" id="unknown-date-naissance-2" class="custom-form__checkbox">
                  <span class="custom-form__checkbox-text">Je ne sais pas</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Heure exacte + Lieu de naissance - Personne 2 -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Heure exacte de naissance<span class="required">*</span></label>
              <div class="custom-form__input-wrapper">
                <input type="time" class="custom-form__input" id="heure-naissance-2" required>
                <span class="custom-form__input-icon">🕐</span>
              </div>
              <!-- Checkbox Je ne sais pas pour Heure de naissance 2 -->
              <div class="custom-form__checkbox-wrapper">
                <label class="custom-form__checkbox-label">
                  <input type="checkbox" id="unknown-heure-naissance-2" class="custom-form__checkbox">
                  <span class="custom-form__checkbox-text">Je ne sais pas</span>
                </label>
              </div>
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Lieu de naissance (ville+ pays)<span class="required">*</span></label>
              <input type="text" class="custom-form__input" id="lieu-naissance-2" placeholder="–" required>
              <!-- Checkbox Je ne sais pas pour Lieu de naissance 2 -->
              <div class="custom-form__checkbox-wrapper">
                <label class="custom-form__checkbox-label">
                  <input type="checkbox" id="unknown-lieu-naissance-2" class="custom-form__checkbox">
                  <span class="custom-form__checkbox-text">Je ne sais pas</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Œuvre Astrale ou Tropicale -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full">
              <label class="custom-form__label">Œuvre Sidérale ou Tropicale ?<span class="required">*</span></label>
              <div class="custom-form__radio-row">
                <div class="custom-form__radio-group">
                  <label class="custom-form__radio">
                    <input type="radio" name="type-oeuvre" value="siderale" checked>
                    <span class="custom-form__radio-circle"></span>
                    <span class="custom-form__radio-label">Œuvre Sidérale</span>
                  </label>
                  <label class="custom-form__radio">
                    <input type="radio" name="type-oeuvre" value="tropicale">
                    <span class="custom-form__radio-circle"></span>
                    <span class="custom-form__radio-label">Œuvre Tropicale</span>
                  </label>
                  <label class="custom-form__radio">
                    <input type="radio" name="type-oeuvre" value="je-ne-sais-pas">
                    <span class="custom-form__radio-circle"></span>
                    <span class="custom-form__radio-label">Je ne sais pas</span>
                  </label>
                </div>
                <a href="#faq-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
              </div>
            </div>
          </div>

          <!-- Demandes particulières -->
          <div class="custom-form__row custom-form__row--no-border">
            <div class="custom-form__field custom-form__field--full">
              <label class="custom-form__label">Demandes particulières (optionnel)</label>
              <textarea class="custom-form__textarea" id="demandes-particulieres" placeholder="Vous pouvez ajouter ici toute précision ou souhait spécifique : affichage avec ou sans prénom, formulation personnalisée, intention particulière, ou toute autre demande."></textarea>
            </div>
          </div>
        </div>

        <!-- Boutons d'achat -->
        <div>
          <product-form class="product-form" data-hide-errors="false">
            <div class="product-form__error-message-wrapper" role="alert" hidden>
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-error" viewBox="0 0 13 13">
