<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Gestion du sélecteur de montant carte cadeau
    const amountButtons = document.querySelectorAll('.gift-card-amount__btn');
    const variantInput = document.getElementById('gift-card-variant-id');
    
    amountButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        // Retirer la classe active de tous les boutons
        amountButtons.forEach(function(b) {
          b.classList.remove('gift-card-amount__btn--active');
        });
        // Ajouter la classe active au bouton cliqué
        this.classList.add('gift-card-amount__btn--active');
        // Mettre à jour l'ID de la variante
        if (variantInput) {
          variantInput.value = this.getAttribute('data-variant-id');
        }
      });
    });
    
    // Lire le paramètre amount de l'URL pour pré-sélectionner la variante
    const urlParams = new URLSearchParams(window.location.search);
    const amountParam = urlParams.get('amount');
    let selectedBtn = null;
    
    if (amountParam) {
      // Chercher le bouton correspondant au montant
      amountButtons.forEach(function(btn) {
        const btnText = btn.textContent.trim();
        // Vérifier si le texte contient le montant (ex: "50€", "100€", etc.)
        if (btnText.includes(amountParam + '€') || btnText.includes(amountParam + ' €') || btnText === amountParam + '€') {
          selectedBtn = btn;
        }
      });
    }
    
    // Si pas de paramètre ou pas trouvé, sélectionner le 2ème bouton par défaut (100€)
    if (!selectedBtn && amountButtons.length > 1) {
      selectedBtn = amountButtons[1];
    } else if (!selectedBtn && amountButtons.length > 0) {
      selectedBtn = amountButtons[0];
    }
    
    // Appliquer la sélection
    if (selectedBtn) {
      amountButtons.forEach(function(b) {
        b.classList.remove('gift-card-amount__btn--active');
      });
      selectedBtn.classList.add('gift-card-amount__btn--active');
      if (variantInput) {
        variantInput.value = selectedBtn.getAttribute('data-variant-id');
      }
    }
    
    // Gestion des clics sur les cartes cadeaux en bas de page
    const giftCardLinks = document.querySelectorAll('.gift-cards-section__card');
    giftCardLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        
        // Récupérer le montant depuis data-amount
        const amount = this.getAttribute('data-amount');
        
        // Scroller en haut de la page
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
        
        // Sélectionner le bon bouton de montant
        if (amount) {
          amountButtons.forEach(function(btn) {
            const btnText = btn.textContent.trim();
            // Vérifier si le texte contient le montant
            if (btnText.includes(amount + '€') || btnText.includes(amount + ' €') || btnText === amount + '€') {
              // Retirer la classe active de tous les boutons
              amountButtons.forEach(function(b) {
                b.classList.remove('gift-card-amount__btn--active');
              });
              // Activer ce bouton
              btn.classList.add('gift-card-amount__btn--active');
              // Mettre à jour la variante
              if (variantInput) {
                variantInput.value = btn.getAttribute('data-variant-id');
              }
            }
          });
        }
      });
    });
    
    
    // Forcer la soumission quand on clique sur le bouton ajouter au panier
    document.addEventListener('click', function(e) {
      const button = e.target.closest('.product-form__submit');
      if (button) {
        e.preventDefault();
        e.stopPropagation();
        
        const variantId = variantInput ? variantInput.value : null;
        
        if (!variantId) {
          console.error('Pas de variant ID !');
          return;
        }
        
        button.classList.add('loading');
        button.setAttribute('aria-disabled', 'true');
        
        const formData = {
          items: [{
            id: parseInt(variantId),
            quantity: 1
          }]
        };
        
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
          const cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer) {
            fetch('/?sections=cart-drawer,cart-icon-bubble')
              .then(res => res.json())
              .then(sections => {
                const drawerHTML = sections['cart-drawer'];
                const parser = new DOMParser();
                const doc = parser.parseFromString(drawerHTML, 'text/html');
                const newDrawerInner = doc.querySelector('.drawer__inner');
                const currentDrawerInner = cartDrawer.querySelector('.drawer__inner');
                if (newDrawerInner && currentDrawerInner) {
                  currentDrawerInner.innerHTML = newDrawerInner.innerHTML;
                }
                
                const iconHTML = sections['cart-icon-bubble'];
                const iconDoc = parser.parseFromString(iconHTML, 'text/html');
                const newIcon = iconDoc.querySelector('.shopify-section');
                const currentIcon = document.getElementById('cart-icon-bubble');
                if (newIcon && currentIcon) {
                  currentIcon.innerHTML = newIcon.innerHTML;
                }
                
                cartDrawer.classList.remove('is-empty');
                
                if (typeof cartDrawer.open === 'function') {
                  cartDrawer.open();
                } else {
                  cartDrawer.classList.add('animate', 'active');
                  document.body.classList.add('overflow-hidden');
                }
              });
          } else {
            window.location.href = '/cart';
          }
        })
        .catch(error => {
          console.error('Erreur ajout panier:', error);
          alert('Erreur lors de l\'ajout au panier. Veuillez réessayer.');
        })
        .finally(() => {
          button.classList.remove('loading');
          button.removeAttribute('aria-disabled');
        });
      }
    }, true);
  });
</script>

<!-- Lightbox CSS et JS -->
<style>
  .image-lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .image-lightbox__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    cursor: pointer;
  }
  
  .image-lightbox__content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    z-index: 1;
  }
  
  .image-lightbox__image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 10px 50px rgba(0, 0, 0, 0.5);
  }
  
  .image-lightbox__close {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: #fff;
    font-size: 36px;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: opacity 0.2s;
  }
  
  .image-lightbox__close:hover {
    opacity: 0.7;
  }
  
  .product__image-lightbox-trigger {
    display: block;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Lightbox pour l'image carte cadeau
  const trigger = document.querySelector('.product__image-lightbox-trigger');
  const lightbox = document.getElementById('image-lightbox-cadeau');
  
  if (trigger && lightbox) {
    const overlay = lightbox.querySelector('.image-lightbox__overlay');
    const closeBtn = lightbox.querySelector('.image-lightbox__close');
    const lightboxImage = lightbox.querySelector('.image-lightbox__image');
    
    // Ouvrir la lightbox
    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      const imageSrc = this.getAttribute('data-image-src');
      lightboxImage.src = imageSrc;
      lightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
    
    // Fermer avec le bouton X
    closeBtn.addEventListener('click', function() {
      lightbox.style.display = 'none';
      document.body.style.overflow = '';
    });
    
    // Fermer en cliquant sur l'overlay
    overlay.addEventListener('click', function() {
      lightbox.style.display = 'none';
      document.body.style.overflow = '';
    });
    
    // Fermer avec Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && lightbox.style.display === 'flex') {
        lightbox.style.display = 'none';
        document.body.style.overflow = '';
      }
    });
  }
});
</script>
