  <div class="how-it-works">
    <div class="how-it-works__container" style="text-transform: none !important;">
      <h2 class="how-it-works__heading">
        DE VOTRE CIEL DE NAISSANCE À VOTRE ŒUVRE ASTRALE
      </h2>
      <p class="how-it-works__subtitle">
        Trois étapes simples pour transformer votre carte du ciel en œuvre d'art.
      </p>

      <div class="how-it-works__columns" style="text-transform: none !important;">
        <div class="how-it-works__column" style="text-transform: none !important;">
          <div class="how-it-works__column-number">01.</div>
          <div class="how-it-works__column-icon">
            <img src="{{ 'ciel1.svg' | asset_url }}" alt="" class="how-it-works__icon-image">
          </div>
          <h3 class="how-it-works__column-title">VOS INFORMATIONS DE NAISSANCE</h3>
          <div class="how-it-works__column-description">
            <p>Partagez vos informations de naissance : Prénom, nom, date, heure et lieu. Ces données forment la carte de votre ciel, base de toute création ASTROGALLERY.</p>
          </div>
        </div>

        <div class="how-it-works__column" style="text-transform: none !important;">
          <div class="how-it-works__column-number">02.</div>
          <div class="how-it-works__column-icon">
            <img src="{{ 'ciel2.svg' | asset_url }}" alt="" class="how-it-works__icon-image">
          </div>
          <h3 class="how-it-works__column-title">ANALYSE & INTERPRÉTATION</h3>
          <div class="how-it-works__column-description">
            <p>A partir de votre thème natal, ASTROGALLERY interprète votre empreinte céleste pour en révéler l'essence.
Nous transformons la lecture de votre thème en œuvre astrale accompagnée de son livret d'interprétation complet.</p>
          </div>
        </div>

        <div class="how-it-works__column" style="text-transform: none !important;">
          <div class="how-it-works__column-number">03.</div>
          <div class="how-it-works__column-icon">
            <img src="{{ 'ciel3.svg' | asset_url }}" alt="" class="how-it-works__icon-image">
          </div>
          <h3 class="how-it-works__column-title">CRÉATION & LIVRAISON</h3>
          <div class="how-it-works__column-description">
            <p>Votre œuvre astrale et son livret sont ensuite produites en France selon plusieurs finitions haut de gamme au choix.
Elle est livrée chez vous sous 3 à 4 semaines maximum.</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Section Cartes Cadeaux -->
<div id="gift-cards-section" class="gift-cards-section">
    <div class="gift-cards-section__container">
      <h2 class="gift-cards-section__title">OFFREZ UNE CARTE CADEAU</h2>
      <p class="gift-cards-section__subtitle">Faites plaisir à l'un de vos proches en lui offrant une carte cadeau ASTROGALLERY</p>
      <div class="gift-cards-section__cards">
        <a href="#" class="gift-cards-section__card" data-amount="50">
          <img src="{{ 'cadeau.png' | asset_url }}" alt="Carte Cadeau 50€" loading="lazy">
        </a>
        <a href="#" class="gift-cards-section__card" data-amount="100">
          <img src="{{ 'cadeau1.png' | asset_url }}" alt="Carte Cadeau 100€" loading="lazy">
        </a>
        <a href="#" class="gift-cards-section__card" data-amount="150">
          <img src="{{ 'cadeau2.png' | asset_url }}" alt="Carte Cadeau 150€" loading="lazy">
        </a>
        <a href="#" class="gift-cards-section__card" data-amount="200">
          <img src="{{ 'cadeau3.png' | asset_url }}" alt="Carte Cadeau 200€" loading="lazy">
        </a>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const faqItems = document.querySelectorAll('.faq-item__header');
      
      faqItems.forEach(function(header) {
        header.addEventListener('click', function() {
          const item = this.closest('.faq-item');
          const isOpen = item.classList.contains('faq-item--open');
          
          if (isOpen) {
            item.classList.remove('faq-item--open');
            this.setAttribute('aria-expanded', 'false');
          } else {
            item.classList.add('faq-item--open');
            this.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  </script>

  <!-- Modal pour les images -->
  <product-modal id="ProductModal-solo" class="product-media-modal">
    <div class="product-media-modal__dialog" role="dialog" aria-label="{{ 'products.modal.label' | t }}" aria-modal="true" tabindex="-1">
      <button id="ModalClose-solo" type="button" class="product-media-modal__toggle" aria-label="{{ 'accessibility.close' | t }}">{% render 'icon-close' %}</button>

      <div class="product-media-modal__content" role="document" aria-label="{{ 'products.modal.label' | t }}" tabindex="0">
        {%- for media in product.media -%}
          {%- if media.media_type == 'image' -%}
            <img
              srcset="{%- if media.preview_image.width >= 550 -%}{{ media.preview_image | img_url: '550x' }} 550w,{%- endif -%}
                {%- if media.preview_image.width >= 1100 -%}{{ media.preview_image | img_url: '1100x' }} 1100w,{%- endif -%}
                {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | img_url: '1680x' }} 1680w,{%- endif -%}
                {%- if media.preview_image.width >= 2048 -%}{{ media.preview_image | img_url: '2048x' }} 2048w,{%- endif -%}
                {%- if media.preview_image.width >= 4096 -%}{{ media.preview_image | img_url: '4096x' }} 4096w{%- endif -%}"
              sizes="(min-width: 750px) calc(100vw - 12rem), 100vw"
              src="{{ media.preview_image | img_url: '750x' }}"
              alt="{{ media.alt | escape }}"
              loading="lazy"
              width="1100"
              height="{{ 1100 | divided_by: media.preview_image.aspect_ratio | ceil }}"
              data-media-id="{{ media.id }}"
            >
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </product-modal>

  <!-- Schema SEO -->
  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media -%}
        "image": [
          {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
        ],
      {%- endif %}
      "description": {{ product.description | strip_html | json }},
      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>

<!-- JavaScript pour le slider et la modal -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Gestion des miniatures cliquables
  const thumbnails = document.querySelectorAll('.product-solo-section .product__thumbnail');
  const mainImage = document.getElementById('main-product-image-solo');
  
  thumbnails.forEach(function(thumbnail) {
    thumbnail.addEventListener('click', function() {
      // Retirer la classe active de toutes les miniatures
      thumbnails.forEach(function(t) {
        t.classList.remove('active');
      });
      // Ajouter la classe active à la miniature cliquée
      this.classList.add('active');
      // Changer l'image principale
      const newSrc = this.getAttribute('data-image-src');
      mainImage.src = newSrc;
    });
  });

  // Slider principal (si nécessaire)
  if (typeof $ !== 'undefined' && $.fn.slick) {
    $('.product-solo-section .product__media-sublist').each(function() {
      $(this).slick(getSubSliderProductSettings($(this).parent().find('.product__media-list')));
    });
  }

  // Synchroniser la quantité visible avec l'input du snippet lié au formulaire
  const quantityInputVisible = document.getElementById('Quantity-solo');
  const hiddenQuantity = document.getElementById('hidden-quantity-solo');
  // Trouver l'input du snippet par son attribut form
  const snippetQuantityInput = document.querySelector('input[form="product-form-solo"][name="quantity"]');
  const quantityWrapper = document.querySelector('.quantity-solo-wrapper quantity-input');
  
  function syncQuantity() {
    if (quantityInputVisible) {
      const qty = parseInt(quantityInputVisible.value) || 1;
      // Synchroniser avec l'input hidden
      if (hiddenQuantity) {
        hiddenQuantity.value = qty;
      }
      // Synchroniser avec l'input du snippet (celui lié au formulaire)
      if (snippetQuantityInput) {
        snippetQuantityInput.value = qty;
        // Déclencher un événement change pour que Shopify le détecte
        snippetQuantityInput.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }
  }
  
  if (quantityInputVisible) {
    // Synchroniser à chaque changement
    quantityInputVisible.addEventListener('change', syncQuantity);
    quantityInputVisible.addEventListener('input', syncQuantity);
    
    // Écouter les clics sur les boutons +/-
    if (quantityWrapper) {
      const buttons = quantityWrapper.querySelectorAll('button');
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          setTimeout(syncQuantity, 100);
        });
      });
    }
    
    // Synchroniser en continu pour être sûr
    setInterval(syncQuantity, 200);
  }

  });

// Custom element pour la modal produit - désactivé pour éviter l'erreur ModalDialog
// Le thème principal gère déjà cette fonctionnalité
</script>

