{% comment %}
  Template personnalisé pour le produit Carte Cadeau
  Pour l'utiliser, allez dans l'admin Shopify > Produits > Carte Cadeau > Template > Sélectionnez "produit-cadeau"
{% endcomment %}

{{ 'produit-cadeau.css' | asset_url | stylesheet_tag }}
{{ 'component-badge.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'update-slider.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'testimonials.js' | asset_url }}" defer="defer"></script>

{%- assign first_3d_model = product.media | where: "media_type", "model" | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link id="ModelViewerStyle" rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css" media="print" onload="this.media='all'">
  <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'component-model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<section class="container product-solo-section">
  <div class="product row gallery-left gallery-before">
    
    <!-- Colonne Informations Produit -->
    <div class="product__info-wrapper col-lg-6">
      <div id="ProductInfo-solo" class="product__info-container product__info-container--sticky">
        
        {%- assign product_form_id = 'product-form-solo' -%}

        <!-- Vendor -->
        <p class="product__text subtitle">
          {{ product.vendor }}
        </p>

        <!-- Titre -->
        <div class="product__title__wrapper">
          <h1 class="product__title h2">
            CARTE CADEAU<br><span class="gold">ASTRO GALLERY</span>
          </h1>
        </div>

        <!-- Sous-titre -->
        <p class="product__subtitle product__subtitle--italic"><em>Offrir une carte cadeau Astro Gallery, c'est offrir bien plus qu'un simple présent.</em></p>
        <p class="product__subtitle product__subtitle--italic"><em>C'est permettre à une personne de transformer son thème natal en une œuvre astrale élégante et personnelle, reflet intime de son identité.</em></p>

        <!-- Description -->
        <div class="product__description rte">
          <p>La carte cadeau donne accès à la création d'une œuvre numérotée et nominative, accompagnée d'un livret de 110 pages dont 40 personnalisées à son ciel. Une expérience complète qui invite à la contemplation et à la découverte de soi.</p>
          <p>La personne à qui vous l'offrez choisit elle même son format, son design et confirme ses informations de naissance. Nous réalisons ensuite sa création dans notre atelier en France.</p>
          <p>Un cadeau profond, esthétique et mémorable pour célébrer une personne unique.</p>
          <p class="product__description--highlight"><strong>Création et livraison en 3 à 4 semaines après activation de la carte.</strong></p>
        </div>

        <!-- Sélecteur de montant -->
        <div class="gift-card-amount">
          <label class="gift-card-amount__label">Sélectionner le montant souhaité</label>
          <div class="gift-card-amount__options">
            {%- for variant in product.variants -%}
              <button type="button" 
                class="gift-card-amount__btn {% if forloop.index == 2 %}gift-card-amount__btn--active{% endif %}" 
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price | money }}">
                {{ variant.title }}
              </button>
            {%- endfor -%}
          </div>
        </div>

        <!-- Boutons d'achat -->
        <div>
          <product-form class="product-form" data-hide-errors="false">
            <div class="product-form__error-message-wrapper" role="alert" hidden>
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-error" viewBox="0 0 13 13">
                <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
              </svg>
              <span class="product-form__error-message"></span>
            </div>
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" id="gift-card-variant-id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">

              <div class="product-form__buttons product-form__buttons--custom product-form__buttons--centered">
                <button
                  type="submit"
                  name="add"
                  class="product-form__submit button button--primary-size button--gold"
                  {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                >
                  • AJOUTER AU PANIER •
                </button>
              </div>
            {%- endform -%}
          </product-form>

          <!-- Infos livraison -->
          <div class="product-info-badges">
            <div class="product-info-badge">
              <img
                class="product-info-badge__icon"
                src="{{ 'Calque_1.svg' | asset_url }}"
                alt="Livraison gratuite"
                loading="lazy"
              >
              <span class="product-info-badge__text">Livraison gratuite</span>
            </div>
            <div class="product-info-badge">
              <img
                class="product-info-badge__icon"
                src="{{ 'Calque_2.svg' | asset_url }}"
                alt="Fabrication à la commande"
                loading="lazy"
              >
              <span class="product-info-badge__text">Fabrication à la commande</span>
            </div>
            <div class="product-info-badge">
              <img
                class="product-info-badge__icon"
                src="{{ 'Calque_3.svg' | asset_url }}"
                alt="Certificat d'authenticité inclus"
                loading="lazy"
              >
              <span class="product-info-badge__text">Certificat d'authenticité inclus</span>
            </div>
          </div>
        </div>

          {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

          {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities | where: 'pick_up_enabled', true -%}

          <pickup-availability class="product__pickup-availabilities no-js-hidden"
            {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %} available{% endif %}
            data-base-url="{{ shop.url }}{{ routes.root_url }}"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            data-has-only-default-variant="{{ product.has_only_default_variant }}"
          >
            <template>
              <pickup-availability-preview class="pickup-availability-preview">
                {% render 'icon-unavailable' %}
                <div class="pickup-availability-info">
                  <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
                  <button class="pickup-availability-button link link--text underlined-link">{{ 'products.product.pickup_availability.refresh' | t }}</button>
                </div>
              </pickup-availability-preview>
            </template>
          </pickup-availability>

        <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>

      </div>
    </div>

    <!-- Colonne Galerie Média -->
    <div class="product__media-wrapper col-lg-6">
      <div class="product__media-list-wrapper">
        <!-- Image principale cliquable -->
        <div class="product__media-list list-unstyled" role="list">
          <div class="product__media-item slider__slide">
            <a href="#" class="product__image-lightbox-trigger" data-image-src="{{ 'carteCadeau.jpg' | asset_url }}">
              <img 
                src="{{ 'carteCadeau.jpg' | asset_url }}" 
                alt="{{ product.title | escape }}"
                class="product__main-image"
                id="main-product-image-cadeau"
                loading="eager"
                style="cursor: zoom-in;"
              >
            </a>
          </div>
        </div>
      </div>

      <!-- Lightbox Modal -->
      <div id="image-lightbox-cadeau" class="image-lightbox" style="display: none;">
        <div class="image-lightbox__overlay"></div>
        <div class="image-lightbox__content">
          <button class="image-lightbox__close" aria-label="Fermer">&times;</button>
          <img src="" alt="Image agrandie" class="image-lightbox__image">
        </div>
      </div>
      {%- if first_3d_model -%}
        <button
          class="button button--full-width product__xr-button"
          type="button"
          aria-label="{{ 'products.product.xr_button_label' | t }}"
          data-shopify-xr
          data-shopify-model3d-id="{{ first_3d_model.id }}"
          data-shopify-title="{{ product.title | escape }}"
          data-shopify-xr-hidden
        >
          {% render 'icon-3d-model' %}
          {{ 'products.product.xr_button' | t }}
        </button>
      {%- endif -%}
    </div>
  </div>

  <div class="container">
    <div class="testimonials">
      <div class="testimonials__text">
        <h2 class="testimonials__title">ILS ONT FAIT DE LEUR CIEL UNE ŒUVRE D'ART</h2>
        <p class="testimonials__description">Des créations vécues comme des révélations.</p>
        <div class="testimonials__buttons">
          <button class="testimonials__button testimonials__button--prev" aria-label="Prev">
            {% render 'icon-caret-left' %}
          </button>
          <div class="testimonials__counts">1/4</div>
          <button class="testimonials__button testimonials__button--next" aria-label="Next">
            {% render 'icon-caret-right' %}
          </button>
        </div>
      </div>
      <div class="testimonials__slider-wrapper">
        <div class="testimonials__slider" dir="ltr">
          <!-- Slide 1 -->
          <div class="testimonials__slide" data-slide-index="0">
            <div class="testimonials__slide-image">
              <img src="{{ 'imgAvis.png' | asset_url }}" alt="Témoignage" loading="lazy">
            </div>
            <div class="testimonials__slide-content">
              <div class="testimonials__slide-quote">
                <img src="{{ 'guillemets.svg' | asset_url }}" alt="Guillemets" width="34" height="27" loading="lazy">
              </div>
              <h3 class="testimonials__slide-title">Un grand merci à Caroline pour les deux magnifiques thèmes astrologiques réalisés.</h3>
              <p class="testimonials__slide-text">"Nos neveux et nièces ont été enchantés par leur cadeau: ils se sont vraiment reconnus dans les descriptions, ce qui a rendu l'expérience très personnelle. Le livret personnalisé est clair et très bien fait, il les a beaucoup aidés à comprendre et lire leur thème. La qualité du travail est remarquable, soignée et esthétique, au point que les œuvres peuvent être exposées. Nous recommandons chaleureusement Caroline pour la finesse et le sérieux de son travail. Merci encore !"</p>
              <div class="testimonials__slide-meta">
                <div class="testimonials__slide-info">
                  <div class="testimonials__slide-name">Mylène et Eric G.</div>
                  <div class="testimonials__slide-stars">
                    {% for i in (1..5) %}
                    <svg viewBox="0 0 17 16" fill="none" role="presentation" class="icon icon-star" aria-hidden="true" focusable="false">
                      <path d="M8.5 0L10.4084 5.87336L16.584 5.87336L11.5878 9.50329L13.4962 15.3766L8.5 11.7467L3.50383 15.3766L5.41219 9.50329L0.416019 5.87336L6.59163 5.87336L8.5 0Z" fill="#D1A85D"/>
                    </svg>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Slide 2 -->
          <div class="testimonials__slide" data-slide-index="1">
            <div class="testimonials__slide-image">
              <img src="{{ 'imgAvis.png' | asset_url }}" alt="Témoignage" loading="lazy">
            </div>
            <div class="testimonials__slide-content">
              <div class="testimonials__slide-quote">
                <img src="{{ 'guillemets.svg' | asset_url }}" alt="Guillemets" width="34" height="27" loading="lazy">
              </div>
              <h3 class="testimonials__slide-title">Un achat mémorable pour nos 30 ans de vie commune</h3>
              <p class="testimonials__slide-text">"Un achat mémorable pour nos 30 ans de vie commune. Le rendu est superbe, les finitions sont impeccables, et l'effet visuel dépasse nos attentes. C'est une pièce qui attire tous les regards et qui a une réelle valeur émotionnelle. Un achat que je recommande vivement !"</p>
              <div class="testimonials__slide-meta">
                <div class="testimonials__slide-info">
                  <div class="testimonials__slide-name">Frédéric R.</div>
                  <div class="testimonials__slide-stars">
                    {% for i in (1..5) %}
                    <svg viewBox="0 0 17 16" fill="none" role="presentation" class="icon icon-star" aria-hidden="true" focusable="false">
                      <path d="M8.5 0L10.4084 5.87336L16.584 5.87336L11.5878 9.50329L13.4962 15.3766L8.5 11.7467L3.50383 15.3766L5.41219 9.50329L0.416019 5.87336L6.59163 5.87336L8.5 0Z" fill="#D1A85D"/>
                    </svg>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Slide 3 -->
          <div class="testimonials__slide" data-slide-index="2">
            <div class="testimonials__slide-image">
              <img src="{{ 'imgAvis.png' | asset_url }}" alt="Témoignage" loading="lazy">
            </div>
            <div class="testimonials__slide-content">
              <div class="testimonials__slide-quote">
                <img src="{{ 'guillemets.svg' | asset_url }}" alt="Guillemets" width="34" height="27" loading="lazy">
              </div>
              <h3 class="testimonials__slide-title">Nous avons été pleinement séduits par l'expérience.</h3>
              <p class="testimonials__slide-text">"Le thème astral de couple que nous avons reçu est vraiment superbe : le modèle que nous avions choisi est moderne, élégant et d'une très belle qualité. Le rendu a une vraie présence et prend naturellement sa place chez nous. Le livret qui l'accompagne a été un vrai plus. Les mantras, les explications et les pistes de réflexion nous ont permis d'engager des discussions profondes, en lien direct avec ce que nous vivons au quotidien. Il nous aide à mieux comprendre ce qui nous unit, à valoriser nos forces, et à aborder avec plus de douceur certaines zones plus délicates de notre thème. Ce qui aurait pu être une faiblesse devient, grâce à ce guide, un espace pour grandir ensemble. Au final, c'est un support sincère, beau et inspirant pour nourrir notre relation. Nous sommes vraiment très satisfaits, autant par la qualité du cadre que par tout ce que cette expérience nous apporte. Nous le recommandons chaleureusement."</p>
              <div class="testimonials__slide-meta">
                <div class="testimonials__slide-info">
                  <div class="testimonials__slide-name">Amélie V. et Vincent L.</div>
                  <div class="testimonials__slide-stars">
                    {% for i in (1..5) %}
                    <svg viewBox="0 0 17 16" fill="none" role="presentation" class="icon icon-star" aria-hidden="true" focusable="false">
                      <path d="M8.5 0L10.4084 5.87336L16.584 5.87336L11.5878 9.50329L13.4962 15.3766L8.5 11.7467L3.50383 15.3766L5.41219 9.50329L0.416019 5.87336L6.59163 5.87336L8.5 0Z" fill="#D1A85D"/>
                    </svg>
