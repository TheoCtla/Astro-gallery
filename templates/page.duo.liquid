<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.querySelector('.finitions-carousel__track');
    const slides = Array.from(track.children);
    const nextButton = document.querySelector('.finitions-nav-btn.next-btn');
    const prevButton = document.querySelector('.finitions-nav-btn.prev-btn');
    const dotsNav = document.querySelector('.finitions-pagination');
    const dots = Array.from(dotsNav.children);

    const slideWidth = slides[0].getBoundingClientRect().width;

    // Arrange the slides next to one another
    const setSlidePosition = (slide, index) => {
      slide.style.left = slideWidth * index + 'px';
    };
    // Note: In CSS we use flex, so left positioning is not strictly needed if using transform X
    // But let's use pure transform based on index

    const moveToSlide = (track, currentSlide, targetSlide) => {
      const targetIndex = slides.findIndex(slide => slide === targetSlide);
      track.style.transform = 'translateX(-' + (targetIndex * 100) + '%)';
      
      currentSlide.classList.remove('current-slide');
      targetSlide.classList.add('current-slide');
    };

    const updateDots = (currentDot, targetDot) => {
      currentDot.classList.remove('active');
      targetDot.classList.add('active');
    };

    // Initialize first slide as current
    slides[0].classList.add('current-slide');

    // Next button
    nextButton.addEventListener('click', e => {
      const currentSlide = track.querySelector('.current-slide') || slides[0];
      const nextSlide = currentSlide.nextElementSibling || slides[0]; // Loop back to start
      const currentDot = dotsNav.querySelector('.active');
      const nextDot = currentDot.nextElementSibling || dots[0];

      moveToSlide(track, currentSlide, nextSlide);
      updateDots(currentDot, nextDot);
    });

    // Prev button
    prevButton.addEventListener('click', e => {
      const currentSlide = track.querySelector('.current-slide') || slides[0];
      const prevSlide = currentSlide.previousElementSibling || slides[slides.length - 1]; // Loop back to end
      const currentDot = dotsNav.querySelector('.active');
      const prevDot = currentDot.previousElementSibling || dots[dots.length - 1];

      moveToSlide(track, currentSlide, prevSlide);
      updateDots(currentDot, prevDot);
    });

    // Dots
    dotsNav.addEventListener('click', e => {
      const targetDot = e.target.closest('button');

      if (!targetDot) return;

      const currentSlide = track.querySelector('.current-slide') || slides[0];
      const currentDot = dotsNav.querySelector('.active');
      const targetIndex = dots.findIndex(dot => dot === targetDot);
      const targetSlide = slides[targetIndex];

      moveToSlide(track, currentSlide, targetSlide);
      updateDots(currentDot, targetDot);
    });
  });
</script>

