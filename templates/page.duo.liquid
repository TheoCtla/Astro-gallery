{% style %}
  .book-section::before {
    background-image: url('{{ "bgBook.png" | asset_url }}');
  }
  
  /* Réduction de la largeur du bouton dans la section livret - doit être après section-rich-text.css */
  .book-section .book-section__cta.button.button--oeuvres {
    padding-left: clamp(1rem, 1.5vw, 1.5rem) !important;
    padding-right: clamp(1rem, 1.5vw, 1.5rem) !important;
    font-size: clamp(9px, 1.1vw, 11px) !important;
    min-width: auto !important;
    width: auto !important;
    max-width: fit-content !important;
    display: inline-flex !important;
    margin-top: clamp(1.5rem, 2vw, 2rem) !important;
  }

  .book-section .book-section__cta.button.button--oeuvres .button__text {
    padding-left: clamp(0.3rem, 0.5vw, 0.5rem) !important;
    padding-right: clamp(0.3rem, 0.5vw, 0.5rem) !important;
    font-size: clamp(9px, 1.1vw, 11px) !important;
  }

  .book-section .book-section__cta.button.button--oeuvres::before {
    width: clamp(3px, 0.4vw, 4px) !important;
    height: clamp(3px, 0.4vw, 4px) !important;
    left: clamp(0.6rem, 0.8vw, 0.8rem) !important;
  }

  .book-section .book-section__cta.button.button--oeuvres::after {
    width: clamp(3px, 0.4vw, 4px) !important;
    height: clamp(3px, 0.4vw, 4px) !important;
    right: clamp(0.6rem, 0.8vw, 0.8rem) !important;
  }

  @media (hover: hover) and (pointer: fine) {
    .book-section .book-section__cta.button.button--oeuvres:hover {
      padding-left: clamp(1rem, 1.5vw, 1.5rem) !important;
      padding-right: clamp(1.2rem, 1.8vw, 1.8rem) !important;
    }

    .book-section .book-section__cta.button.button--oeuvres:hover::before {
      left: clamp(0.6rem, 0.8vw, 0.8rem) !important;
    }

    .book-section .book-section__cta.button.button--oeuvres:hover::after {
      right: clamp(0.6rem, 0.8vw, 0.8rem) !important;
    }
  }
{% endstyle %}

