{{ 'page-contact.css' | asset_url | stylesheet_tag }}

<div class="contact-page">
  <!-- Breadcrumb -->
  <nav class="contact-breadcrumb">
    <a href="/" class="contact-breadcrumb__link">Home</a>
    <span class="contact-breadcrumb__separator">›</span>
    <span class="contact-breadcrumb__current">Contact</span>
  </nav>

  <!-- Header -->
  <div class="contact-header">
    <h1 class="contact-header__title">UNE QUESTION, UN CONSEIL, UN ACCOMPAGNEMENT ?</h1>
    <p class="contact-header__subtitle">Notre équipe vous répond sous 24h, avec attention et précision.<br>Qu'il s'agisse d'un projet Solo, Duo ou d'un cadeau à offrir, nous sommes là pour vous guider.</p>
  </div>

  <!-- Content -->
  <div class="contact-content">
    <!-- Image -->
    <div class="contact-content__image">
      <img src="{{ 'contact.png' | asset_url }}" alt="Illustration astrologique" loading="lazy">
    </div>

    <!-- Form -->
    <div class="contact-content__form">
      {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-form__success">
            Merci de nous avoir contactés. Nous vous répondrons dès que possible.
          </div>
        {%- elsif form.errors -%}
          <div class="contact-form__error">
            Une erreur est survenue. Veuillez réessayer.
          </div>
        {%- endif -%}

        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="ContactForm-nom">Nom</label>
            <input type="text" id="ContactForm-nom" name="contact[Nom]" placeholder="..." autocomplete="family-name">
          </div>
          <div class="contact-form__field">
            <label for="ContactForm-prenom">Prénom</label>
            <input type="text" id="ContactForm-prenom" name="contact[Prénom]" placeholder="..." autocomplete="given-name">
          </div>
        </div>

        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="ContactForm-email">E-mail</label>
            <input type="email" id="ContactForm-email" name="contact[email]" placeholder="..." autocomplete="email" required aria-required="true">
          </div>
          <div class="contact-form__field">
            <label for="ContactForm-phone">Numéro de téléphone</label>
            <input type="tel" id="ContactForm-phone" name="contact[Téléphone]" placeholder="..." autocomplete="tel">
          </div>
        </div>

        <div class="contact-form__field contact-form__field--full">
          <label for="ContactForm-message">Votre message</label>
          <textarea id="ContactForm-message" name="contact[Message]" rows="6" placeholder="..."></textarea>
        </div>

        <div class="contact-form__submit">
          <button type="submit" class="contact-form__button">
            <span>• ENVOYER VOTRE MESSAGE •</span>
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

