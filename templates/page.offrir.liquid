<script>
document.addEventListener('DOMContentLoaded', function() {
  // Scroll vers section Solo/Duo
  const discoverBtn = document.getElementById('discover-btn');
  if (discoverBtn) {
    discoverBtn.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.getElementById('solo-duo-section');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  
  // Scroll vers section Cartes Cadeaux
  const giftCardsBtn = document.getElementById('gift-cards-btn');
  if (giftCardsBtn) {
    giftCardsBtn.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.getElementById('gift-cards-section');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  
  // Scroll vers section Cartes Cadeaux (bouton 2)
  const giftCardsBtn2 = document.getElementById('gift-cards-btn-2');
  if (giftCardsBtn2) {
    giftCardsBtn2.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.getElementById('gift-cards-section');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  
  // Scroll vers section Cartes Cadeaux (bouton 3 - discover section)
  const giftCardsBtn3 = document.getElementById('gift-cards-btn-3');
  if (giftCardsBtn3) {
    giftCardsBtn3.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.getElementById('gift-cards-section');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  
  // Scroll vers section Cartes Cadeaux (bouton 4 - cta footer)
  const giftCardsBtn4 = document.getElementById('gift-cards-btn-4');
  if (giftCardsBtn4) {
    giftCardsBtn4.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.getElementById('gift-cards-section');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  
  // Scroll vers section Cartes Cadeaux (bouton 5 - cta avant FAQ)
  const giftCardsBtn5 = document.getElementById('gift-cards-btn-5');
  if (giftCardsBtn5) {
    giftCardsBtn5.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.getElementById('gift-cards-section');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  
  // Scroll vers section Cartes Cadeaux (bouton 6 - book section)
  const giftCardsBtn6 = document.getElementById('gift-cards-btn-6');
  if (giftCardsBtn6) {
    giftCardsBtn6.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.getElementById('gift-cards-section');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
});
</script>

<div class="solo-hero">
  <img src="{{ 'offrirBG.png' | asset_url }}" alt="Offrir une Œuvre Astrale" class="solo-hero__image">
  <div class="solo-hero__overlay"></div>
  <div class="solo-hero__content">
    <h1 class="solo-hero__title">
      <span class="solo-hero__title-line">SOLO OU <span class="gold">DUO</span></span>
    </h1>
    <p class="solo-hero__subtitle">
      Une œuvre qui se contemple et s'analyse<br>
      pour mettre en lumières nos points forts et sensibles.
    </p>
    <a href="#solo-duo-section" class="solo-hero__cta button button--oeuvres mobile-small-btn" id="discover-btn">
      <span class="button__text">Découvrir les œuvres</span>
    </a>
  </div>
</div>

<div class="how-it-works oui">
  <div class="how-it-works__container" style="text-transform: none !important;">
    <h2 class="how-it-works__heading">
      UN CADEAU QUI A DU SENS
    </h2>
    <p class="how-it-works__subtitle">
      Offrir une Œuvre Astrale, c'est offrir plus qu'un objet.<br>
      C'est un symbole : une œuvre d'art qui révèle la beauté intérieure et l'histoire céleste de la personne à qui vous pensez.
    </p>

    <div class="how-it-works__columns" style="text-transform: none !important;">
      <!-- Étape 1 -->
      <div class="how-it-works__column" style="text-transform: none !important;">
        <div class="how-it-works__column-number">01.</div>
        <div class="how-it-works__column-icon">
          <img src="{{ 'solo-3.png' | asset_url }}" alt="" class="how-it-works__icon-image how-it-works__icon-image--large">
        </div>
        <h3 class="how-it-works__column-title">SINGULIÈRE</h3>
        <div class="how-it-works__column-description">
          <p>Une création à partir de son ciel de naissance.</p>
        </div>
      </div>

      <!-- Étape 2 -->
      <div class="how-it-works__column" style="text-transform: none !important;">
        <div class="how-it-works__column-number">02.</div>
        <div class="how-it-works__column-icon">
          <img src="{{ 'solo-1.png' | asset_url }}" alt="" class="how-it-works__icon-image how-it-works__icon-image--large">
        </div>
        <h3 class="how-it-works__column-title">SYMBOLIQUE</h3>
        <div class="how-it-works__column-description">
          <p>Un présent intime, entre art et âme.</p>
        </div>
      </div>

      <!-- Étape 3 -->
      <div class="how-it-works__column" style="text-transform: none !important;">
        <div class="how-it-works__column-number">03.</div>
        <div class="how-it-works__column-icon">
          <img src="{{ 'solo-2.png' | asset_url }}" alt="" class="how-it-works__icon-image how-it-works__icon-image--large">
        </div>
        <h3 class="how-it-works__column-title">DURABLE</h3>
        <div class="how-it-works__column-description">
          <p>Un objet d'art à contempler toute une vie.</p>
        </div>
      </div>
    </div>
  </div>
</div>


<!-- Section Titre "Deux façons de célébrer" -->
<section id="solo-duo-section" class="rich-text-section spaced-section">
  <div class="rich-text container">
    <div class="rich-text__wrapper">
      <h2 class="rich-text__heading title--section">SOLO OU DUO : DEUX CRÉATIONS, DEUX INTENTIONS</h2>
      <div class="rich-text__text rte">
        <p>Avant d'offrir, choisissez le type d'œuvre selon votre intention.<br>
        Chaque format a sa symbolique : introspective pour l'un, lien pour l'autre.</p>
      </div>
    </div>
  </div>
</section>

<!-- Section Galerie Solo / Duo / Offrir -->
<section class="gallery-with-text-section spaced-section">
  <div class="container">
    <div class="border-wrapper">
      <div class="gallery-with-text__container">
        <div class="gallery-with-text__wrapper" role="list">
          
          <!-- Card SOLO -->
          <li class="gallery-with-text__card color-inverse">
            <div class="gallery-with-text__media">
              <img src="{{ 'solo2.png' | asset_url }}" alt="Œuvre astrale Solo" loading="lazy" class="motion-reduce">
            </div>
            <h3 class="gallery-with-text__title subtitle">Collection SOLO</h3>
            <div class="gallery-with-text__info">
              <div class="gallery-with-text__info-item">
                <h2 class="gallery-with-text__info-title mt-0 title--section">SOLO, pour se révéler</h2>
                <div class="gallery-with-text__text">
                  <p>L'Œuvre Astrale Solo capture le ciel individuel d'une personne : ses forces, son essence, ses mantras.<br>
                  Une création introspective et poétique, parfaite pour un cadeau personnel.</p>
                </div>
                <a href="/products/solo" class="gallery-with-text__button button button--oeuvres color-background-1">
                  <span class="button__text">Simuler une œuvre SOLO</span>
                </a>
              </div>
              <a href="/products/solo" class="link link--overlay" aria-label="Découvrir l'œuvre SOLO"></a>
            </div>
          </li>

          <!-- Card DUO -->
          <li class="gallery-with-text__card color-inverse">
            <div class="gallery-with-text__media">
              <img src="{{ 'duo2.png' | asset_url }}" alt="Œuvre astrale Duo" loading="lazy" class="motion-reduce">
            </div>
            <h3 class="gallery-with-text__title subtitle">Collection DUO</h3>
            <div class="gallery-with-text__info">
              <div class="gallery-with-text__info-item">
                <h2 class="gallery-with-text__info-title mt-0 title--section">Duo, pour célébrer le lien</h2>
                <div class="gallery-with-text__text">
                  <p>L'Œuvre Astrale Duo réunit deux cartes du ciel : un couple, une amitié, une relation parent / enfant ou un partenariat.<br>
                  Une œuvre symbolique et émotionnelle, reflet d'un lien unique.</p>
                </div>
                <a href="/products/oeuvre-astrale-duo" class="gallery-with-text__button button button--oeuvres color-background-1">
                  <span class="button__text">Simuler une œuvre DUO</span>
                </a>
              </div>
              <a href="/products/oeuvre-astrale-duo" class="link link--overlay" aria-label="Découvrir l'œuvre DUO"></a>
            </div>
          </li>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Section Carte Cadeau -->
<section class="carte-cadeau-section">
  <div class="container">
    <div class="carte-cadeau">
      <div class="carte-cadeau__image">
        <img src="{{ 'cadeau.png' | asset_url }}" alt="Carte Cadeau ASTROGALLERY" loading="lazy">
      </div>
      <div class="carte-cadeau__content">
        <h2 class="carte-cadeau__title">
          <span>LAISSEZ LA PERSONNE</span>
          <span>CRÉER SA PROPRE ŒUVRE</span>
        </h2>
        <div class="carte-cadeau__text">
          <p>Offrez une carte cadeau ASTROGALLERY, le présent parfait pour ceux qui aiment choisir leur moment.</p>
          <p>Elle permet de créer librement une Œuvre Astrale Solo ou Duo, au moment qui lui semblera juste.</p>
        </div>
        <a href="/products/carte-cadeau-astrogallery" class="button button--oeuvres carte-cadeau__button">
          <span class="button__text">Offrir une œuvre astrale</span>
        </a>
      </div>
    </div>
  </div>
</section>

<div class="book-section">
  <div class="book-section__container">
    <div class="book-section__wrapper">
      <div class="book-section__content">
      <h2 class="book-section__title">
        <span class="book-section__title-line1">UN LIVRET POUR RÉVÉLER</span>
        <span class="book-section__title-line2">SA LUMIÈRE INTÉRIEURE</span>
      </h2>
      <div class="book-section__text">
        <p>Chaque Œuvre Astrale inclut un livret d'interprétation de <span class="gold">110 pages</span>, dont <span class="gold">40 personnalisées</span>.</p>
        <p>Un guide clair et poétique qui aide à comprendre son ciel, ses mantras et sa phrase clé : <em>le Cœur de son Ciel.</em></p>
        <ul class="book-section__list">
          <li>10 mantras personnalisés</li>
          <li>Phrase essentielle : <em>le Cœur de son Ciel</em></li>
          <li>Lecture planétaire claire et inspirante</li>
        </ul>
      </div>
      <div class="book-section__buttons">
        <a href="/products/carte-cadeau-astrogallery" class="book-section__cta button button--oeuvres">
          <span class="button__text">Offrir une œuvre astrale</span>
        </a>
        <div class="book-section__simulate">
          <span class="book-section__simulate-label">Simuler une œuvre :</span>
          <a href="/products/solo" class="book-section__simulate-btn">
            <span>SOLO</span>
          </a>
          <a href="/products/oeuvre-astrale-duo" class="book-section__simulate-btn">
            <span>DUO</span>
        </a>
        </div>
      </div>
      </div>
      <div class="book-section__image">
        <!-- Logo rotatif fixe sur l'image -->
        <div class="book-section__logo book-section__logo--on-image">
          <svg class="book-section__logo-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
            <defs>
              <path id="book-circle-path-offrir" d="M 100, 100 m -90, 0 a 90,90 0 1,1 180,0 a 90,90 0 1,1 -180,0" fill="none"/>
            </defs>
            <text class="book-section__logo-text" fill="#DFBE71" font-family="Arial, sans-serif" font-weight="400">
              <textPath xlink:href="#book-circle-path-offrir" startOffset="0%">
                ASTROGALLERY • ASTROGALLERY • ASTROGALLERY •
              </textPath>
            </text>
          </svg>
        </div>
        <img src="{{ 'bookIMG.png' | asset_url }}" alt="Livre ASTROGALLERY" class="book-section__book-img">
      </div>
    </div>
  </div>
</div>

<div class="how-it-works">
  <div class="how-it-works__container" style="text-transform: none !important;">
    <h2 class="how-it-works__heading">
      OFFRIR UNE ŒUVRE N'A JAMAIS ÉTÉ AUSSI SIMPLE
    </h2>
    <p class="how-it-works__subtitle">
      Vous ne connaissez pas les informations de naissance ?<br>
      Offrez une <a href="/products/carte-cadeau" class="gold-link">carte cadeau ASTROGALLERY</a>.<br>
      Elle permettra à la personne de créer sa propre œuvre, à son rythme, dans le parcours classique Solo ou Duo.
    </p>

    <div class="how-it-works__columns" style="text-transform: none !important;">
      <!-- Étape 1 -->
      <div class="how-it-works__column" style="text-transform: none !important;">
        <div class="how-it-works__column-number">01.</div>
        <div class="how-it-works__column-icon">
          <img src="{{ 'ciel1.svg' | asset_url }}" alt="" class="how-it-works__icon-image">
        </div>
        <h3 class="how-it-works__column-title">SIMULEZ UNE ŒUVRE SOLO OU DUO</h3>
        <div class="how-it-works__column-description">
          <p>Visualisez les formats, supports et finitions pour estimer le montant du cadeau.</p>
          <p>Vous pouvez offrir la valeur totale ou partielle de l'œuvre.</p>
        </div>
      </div>

      <!-- Étape 2 -->
      <div class="how-it-works__column" style="text-transform: none !important;">
        <div class="how-it-works__column-number">02.</div>
        <div class="how-it-works__column-icon">
          <img src="{{ 'ciel2.svg' | asset_url }}" alt="" class="how-it-works__icon-image">
        </div>
        <h3 class="how-it-works__column-title">CHOISISSEZ LE MONTANT DE LA CARTE CADEAU</h3>
        <div class="how-it-works__column-description">
          <p>Sélectionnez la carte correspondant au montant souhaité.</p>
          <p>Nous vous envoyons une carte cadeau élégante, prête à offrir (format physique ou digital).</p>
        </div>
      </div>

      <!-- Étape 3 -->
      <div class="how-it-works__column" style="text-transform: none !important;">
        <div class="how-it-works__column-number">03.</div>
        <div class="how-it-works__column-icon">
          <img src="{{ 'ciel3.svg' | asset_url }}" alt="" class="how-it-works__icon-image">
        </div>
        <h3 class="how-it-works__column-title">ELLE CRÉE SON ŒUVRE, À SON MOMENT</h3>
        <div class="how-it-works__column-description">
          <p>La personne recevra sa carte et pourra créer son œuvre personnalisée — Solo ou Duo — dans le parcours classique ASTROGALLERY.</p>
          <p>Fabrication en France, livraison en 3 à 4 semaines après création.</p>
        </div>
      </div>
    </div>
  </div>
  <div class="how-it-works__buttons">
      <a href="/products/solo" class="button how-it-works__button button--oeuvres">
        <span class="button__text">Simuler une œuvre Solo ou Duo</span>
      </a>
      <a href="/products/carte-cadeau-astrogallery" class="button how-it-works__button how-it-works__button--beige button--oeuvres">
        <span class="button__text">Offrir une carte cadeau</span>
      </a>
    </div>
</div>

