{% comment %}
  Template personnalisé pour le produit Solo
  Pour l'utiliser, allez dans l'admin Shopify > Produits > Œuvre Astrale Solo > Template > Sélectionnez "produit-solo"
{% endcomment %}

<link rel="stylesheet" href="{{ 'produit-solo.css' | asset_url }}">
{{ 'component-badge.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'update-slider.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'testimonials.js' | asset_url }}" defer="defer"></script>

{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link
    id="ModelViewerStyle"
    rel="stylesheet"
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    media="print"
    onload="this.media='all'"
  >
  <link
    id="ModelViewerOverride"
    rel="stylesheet"
    href="{{ 'component-model-viewer-ui.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
{%- endif -%}

<section class="container product-solo-section">
  <div class="product row gallery-left gallery-before">
    <!-- Colonne Informations Produit -->
    <div class="product__info-wrapper col-lg-6">
      <div id="ProductInfo-solo" class="product__info-container product__info-container--sticky">
        {%- assign product_form_id = 'product-form-solo' -%}

        <!-- Vendor -->
        <p class="product__text subtitle">
          {{ product.vendor }}
        </p>

        <!-- Titre -->
        <div
          class="
            product__title__wrapper
            {%- if product.available == false %} price--sold-out {% endif -%}
            {%- if product.compare_at_price > product.price %} price--on-sale {% endif -%}
          "
        >
          <h1 class="product__title h2">
            L'ŒUVRE<br>
            ASTRALE <span class="gold">SOLO</span>
          </h1>
          <div class="badge-wrapper">
            <span class="badge price__badge-sale color-background-2" aria-hidden="true">
              {{ 'products.product.on_sale' | t }}
            </span>
            <span
              class="badge price__badge-sold-out color-{{ settings.sold_out_badge_color_scheme }}"
              aria-hidden="true"
            >
              {{ 'products.product.sold_out' | t }}
            </span>
          </div>
        </div>

        <!-- Sous-titre -->
        <p class="product__subtitle">Une œuvre numérotée, nominative et singulière.</p>

        <!-- Description -->
        <div class="product__description rte">
          <p>
            À partir de votre thème natal, ASTROGALLERY réalise une œuvre astrale design qui réinvente la lecture
            classique de la carte du ciel.<br>
            Plus esthétique, plus intuitive, elle devient un objet d'art à contempler et à méditer, fidèle reflet de
            votre identité profonde.
          </p>
          <p>
            Chaque création est <strong>numérotée, nominative et accompagnée d'un livret de 110 pages</strong>, dont
            <strong>40 personnalisées</strong> à votre ciel.<br>
            <strong>Designée et fabriquée en France.</strong><br>
            <strong>Création et livraison en 3 à 4 semaines.</strong>
          </p>
        </div>

        <!-- Prix et Quantité -->
        <div class="price-quantity-wrapper">
          <div class="no-js-hidden price-wrapper" id="price-solo">
            {%- render 'price',
              product: product,
              use_variant: true,
              show_badges: true,
              price_class: 'price--product'
            -%}
          </div>
            
        </div>
        <div style="margin: 0">
          {%- form 'product', product, id: 'product-form-installment-solo', class: 'installment caption-large' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {{ form | payment_terms }}
          {%- endform -%}
        </div>

        <!-- Tags -->
        {%- if product.tags != blank -%}
          <ul class="product-tags">
            {% for tag in product.tags %}
              <li class="product-tags__tag">
                {{ tag }}
                {% render 'icon-checkmark' %}
              </li>
            {% endfor %}
          </ul>
        {%- endif -%}

        <!-- Sélecteur de variantes désactivé - on utilise le formulaire personnalisé à la place -->
        <!--
          <div style="display: none;">
            {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
          </div>
        -->

        <!-- Formulaire personnalisé -->
        <div class="custom-product-form">
          <!-- Format de l'œuvre -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full custom-form__field--with-help">
              <label class="custom-form__label">Format de l'œuvre</label>
              <div class="custom-form__select-wrapper">
                <select class="custom-form__select" id="format-oeuvre-custom">
                  <option value="" disabled selected>Choisir...</option>
                  <option value="ronde-40x40">Ronde (40 cm de diamètre)</option>
                  <option value="carree-40x40">Carrée (40 x 40 cm)</option>
                  <option value="rectangle-vertical-35x50">Rectangle vertical (35 x 50 cm)</option>
                  <option value="rectangle-horizontal-50x35">Rectangle horizontal (50 x 35 cm)</option>
                </select>
                {% render 'icon-caret' %}
              </div>
              <a href="#faq-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
            </div>
          </div>

          <!-- Matière du support -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full custom-form__field--with-help">
              <label class="custom-form__label">Matière du support</label>
              <div class="custom-form__select-wrapper">
                <select class="custom-form__select" id="matiere-support-custom">
                  <option value="" disabled selected>Choisir...</option>
                  <option value="alu-dibond">Mat (Alu dibond)</option>
                  <option value="plexi-brillant">Brillant (Plexi'Art)</option>
                </select>
                {% render 'icon-caret' %}
              </div>
              <a href="#faq-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
            </div>
          </div>

          <!-- Encadrement de l'œuvre -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full custom-form__field--with-help">
              <label class="custom-form__label">Encadrement de l'œuvre</label>
              <div class="custom-form__select-wrapper">
                <select class="custom-form__select" id="encadrement-oeuvre-custom">
                  <option value="" disabled selected>Choisir...</option>
                  <option value="chassis">Chassis</option>
                  <option value="box-blanc">Caisse Américaine Blanche</option>
                  <option value="box-noir">Caisse Américaine Noire</option>
                  <option value="box-alu-noir">Caisse Américaine Alu Noir</option>
                  <option value="box-chene">Caisse Américaine Chêne Naturel</option>
                </select>
                {% render 'icon-caret' %}
              </div>
              <a href="#faq-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
            </div>
          </div>

          <!-- Texte d'information -->
          <div class="custom-form__row custom-form__row--no-border">
            <p style="font-size: 1.3rem; color: #e1c37d; margin: 10px 0; font-style: italic; margin-bottom: 1.8rem; padding-bottom: 1.8rem; border-bottom: 1px solid #f0f0f0;">
              Si vous ne connaissez pas encore certaines informations nécessaires, vous pouvez simplement indiquer « Je ne sais pas » et nous transmettre les éléments manquants ultérieurement.
            </p>
          </div>

          <!-- Nom & Prénom + Date de naissance -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Nom & Prénom<span class="required">*</span></label>
              <input type="text" class="custom-form__input" id="nom-prenom" placeholder="–" required>
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Date de naissance (JJ-MM-AA)<span class="required">*</span></label>
              <div class="custom-form__input-wrapper">
                <input type="date" class="custom-form__input" id="date-naissance" required>
                <span class="custom-form__input-icon">📅</span>
              </div>
              <label class="custom-form__checkbox custom-form__checkbox--unknown">
                <input type="checkbox" id="unknown-date-naissance">
                <span>Je ne sais pas</span>
              </label>
            </div>
          </div>

          <!-- Heure exacte + Lieu de naissance -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Heure exacte de naissance<span class="required">*</span></label>
              <div class="custom-form__input-wrapper">
                <input type="time" class="custom-form__input" id="heure-naissance" required>
                <span class="custom-form__input-icon">🕐</span>
              </div>
              <label class="custom-form__checkbox custom-form__checkbox--unknown">
                <input type="checkbox" id="unknown-heure-naissance">
                <span>Je ne sais pas</span>
              </label>
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Lieu de naissance (ville+ pays)<span class="required">*</span></label>
              <input type="text" class="custom-form__input" id="lieu-naissance" placeholder="–" required>
              <label class="custom-form__checkbox custom-form__checkbox--unknown">
                <input type="checkbox" id="unknown-lieu-naissance">
                <span>Je ne sais pas</span>
              </label>
            </div>
          </div>

          <!-- Email + Téléphone -->
          <div class="custom-form__row custom-form__row--two-cols">
            <div class="custom-form__field">
              <label class="custom-form__label">Email</label>
              <input type="email" class="custom-form__input" id="email" placeholder="–">
            </div>
            <div class="custom-form__field">
              <label class="custom-form__label">Téléphone</label>
              <input type="tel" class="custom-form__input" id="telephone" placeholder="–">
            </div>
          </div>

          <!-- Œuvre Astrale ou Tropicale -->
          <div class="custom-form__row">
            <div class="custom-form__field custom-form__field--full">
              <label class="custom-form__label">Œuvre Sidérale ou Tropicale ?<span class="required">*</span></label>
              <div class="custom-form__radio-row">
                <div class="custom-form__radio-group">
                  <label class="custom-form__radio">
                    <input type="radio" name="type-oeuvre" value="siderale" checked>
                    <span class="custom-form__radio-circle"></span>
                    <span class="custom-form__radio-label">Œuvre Sidérale</span>
                  </label>
                  <label class="custom-form__radio">
                    <input type="radio" name="type-oeuvre" value="tropicale">
                    <span class="custom-form__radio-circle"></span>
                    <span class="custom-form__radio-label">Œuvre Tropicale</span>
                  </label>
                  <label class="custom-form__radio">
                    <input type="radio" name="type-oeuvre" value="je-ne-sais-pas">
                    <span class="custom-form__radio-circle"></span>
                    <span class="custom-form__radio-label">Je ne sais pas</span>
                  </label>
                </div>
                <a href="#faq-section" class="custom-form__help">Besoin d'aide pour choisir ?</a>
              </div>
            </div>
          </div>

          <!-- Demandes particulières -->
          <div class="custom-form__row custom-form__row--no-border">
            <div class="custom-form__field custom-form__field--full">
              <label class="custom-form__label">Demandes particulières (optionnel)</label>
              <textarea
                class="custom-form__textarea"
                id="demandes-particulieres"
                placeholder="Vous pouvez ajouter ici toute précision ou souhait spécifique : affichage avec ou sans prénom, formulation personnalisée, intention particulière, ou toute autre demande."
              ></textarea>
            </div>
          </div>
        </div>

        <!-- Boutons d'achat -->
        <div>
          <product-form class="product-form" data-hide-errors="false">
            <div class="product-form__error-message-wrapper" role="alert" hidden>
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-error" viewBox="0 0 13 13">
                <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
              </svg>
              <span class="product-form__error-message"></span>
            </div>
            {%- form 'product',
              product,
              id: product_form_id,
              class: 'form',
              novalidate: 'novalidate',
              data-type: 'add-to-cart-form'
            -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" id="hidden-quantity-solo" value="1">

              <!-- Propriétés personnalisées pour le panier -->
              <input type="hidden" name="properties[Format de l'œuvre]" id="prop-format-oeuvre" value="">
              <input type="hidden" name="properties[Matière du support]" id="prop-matiere-support" value="">
              <input type="hidden" name="properties[Encadrement de l'œuvre]" id="prop-encadrement-oeuvre" value="">
              <input type="hidden" name="properties[Nom & Prénom]" id="prop-nom-prenom" value="">
              <input type="hidden" name="properties[Date de naissance]" id="prop-date-naissance" value="">
              <input type="hidden" name="properties[Heure de naissance]" id="prop-heure-naissance" value="">
              <input type="hidden" name="properties[Lieu de naissance]" id="prop-lieu-naissance" value="">
              <input type="hidden" name="properties[Type d'œuvre]" id="prop-type-oeuvre" value="">
              <input type="hidden" name="properties[Demandes particulières]" id="prop-demandes-particulieres" value="">

              <div class="product-form__wrapper-with-price">
                <div class="product-form__price-display" id="price-display-buttons">
                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    show_badges: false,
                    price_class: 'price--buttons'
                  -%}
                </div>
                <div class="product-form__buttons product-form__buttons--custom">
                  <button
                    type="submit"
                    name="add"
                    class="product-form__submit button button--primary-size button--gold"
                    {% if product.selected_or_first_available_variant.available == false %}
                      disabled
                    {% endif %}
                  >
                    • AJOUTER AU PANIER •
                  </button>
                  <a href="/products/carte-cadeau-astrogallery" class="button button--outline-gold">
                    • OFFRIR UNE CARTE CADEAU •
                  </a>
                </div>
              </div>
            {%- endform -%}
          </product-form>

          <!-- Infos livraison -->
          <div class="product-info-badges">
            <div class="product-info-badge">
              <img
                class="product-info-badge__icon"
                src="{{ 'Calque_1.svg' | asset_url }}"
                alt="Livraison gratuite"
                loading="lazy"
              >
              <span class="product-info-badge__text">Livraison gratuite</span>
            </div>
            <div class="product-info-badge">
              <img
                class="product-info-badge__icon"
                src="{{ 'Calque_2.svg' | asset_url }}"
                alt="Fabrication à la commande"
                loading="lazy"
              >
              <span class="product-info-badge__text">Fabrication à la commande</span>
            </div>
            <div class="product-info-badge">
              <img
                class="product-info-badge__icon"
                src="{{ 'Calque_3.svg' | asset_url }}"
                alt="Certificat d'authenticité inclus"
                loading="lazy"
              >
              <span class="product-info-badge__text">Certificat d'authenticité inclus</span>
            </div>
          </div>
        </div>

        {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

        {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
          | where: 'pick_up_enabled', true
        -%}

        <pickup-availability
          class="product__pickup-availabilities no-js-hidden"
          {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
            available
          {% endif %}
          data-base-url="{{ shop.url }}{{ routes.root_url }}"
          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
          data-has-only-default-variant="{{ product.has_only_default_variant }}"
        >
          <template>
            <pickup-availability-preview class="pickup-availability-preview">
              {% render 'icon-unavailable' %}
              <div class="pickup-availability-info">
                <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
                <button class="pickup-availability-button link link--text underlined-link">
                  {{ 'products.product.pickup_availability.refresh' | t }}
                </button>
              </div>
            </pickup-availability-preview>
          </template>
        </pickup-availability>

        <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
      </div>
    </div>

    <!-- Colonne Galerie Média -->
    <!-- Sentinel for Mobile Sticky Detection -->
    <div id="mobile-sticky-sentinel"></div>
    <div class="product__media-wrapper col-lg-6">
      <div class="product__media-list-wrapper">
        <!-- Miniatures (Carousel Vertical) -->
        <div class="product__thumbnail-carousel-wrapper">
          <button class="thumb-nav-btn thumb-nav-up" aria-label="Scroll Up">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="18 15 12 9 6 15"></polyline>
            </svg>
          </button>

          <div class="product__media-thumbnails" id="thumbnail-carousel-solo">
            <!-- VIDEO -->
            <button class="product__thumbnail active js-thumb-video" data-video-url="https://cdn.shopify.com/videos/c/o/v/0fa3ca7f61544fcc8ad634cef1ac2995.mp4">
              <video src="https://cdn.shopify.com/videos/c/o/v/0fa3ca7f61544fcc8ad634cef1ac2995.mp4#t=0.1" muted preload="metadata" style="width: 100%; height: 100%; object-fit: cover;"></video>
            </button>
  
            <!-- RONDE (2) -->
            <button class="product__thumbnail" data-image-src="{{ '_solo-ronde-mat-chassis.webp' | asset_url }}"><img src="{{ '_solo-ronde-mat-chassis.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-ronde-brillant-chassis.webp' | asset_url }}"><img src="{{ '_solo-ronde-brillant-chassis.webp' | asset_url }}" loading="lazy"></button>
  
            <!-- CARRE (8) -->
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-mat-chassis.webp' | asset_url }}"><img src="{{ '_solo-carre-mat-chassis.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-mat-alu-noir.webp' | asset_url }}"><img src="{{ '_solo-carre-mat-alu-noir.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-mat-blanche.webp' | asset_url }}"><img src="{{ '_solo-carre-mat-blanche.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-mat-noire.webp' | asset_url }}"><img src="{{ '_solo-carre-mat-noire.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-mat-chene.webp' | asset_url }}"><img src="{{ '_solo-carre-mat-chene.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-brillant-chassis.webp' | asset_url }}"><img src="{{ '_solo-carre-brillant-chassis.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-brillant-alu-noir.webp' | asset_url }}"><img src="{{ '_solo-carre-brillant-alu-noir.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-brillant-blanche.webp' | asset_url }}"><img src="{{ '_solo-carre-brillant-blanche.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-brillant-noire.webp' | asset_url }}"><img src="{{ '_solo-carre-brillant-noire.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-carre-brillant-chene.webp' | asset_url }}"><img src="{{ '_solo-carre-brillant-chene.webp' | asset_url }}" loading="lazy"></button>
  
            <!-- VERTICAL (8) -->
            <button class="product__thumbnail" data-image-src="{{ '_solo-vertical-mat-chassis.webp' | asset_url }}"><img src="{{ '_solo-vertical-mat-chassis.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-vertical-mat-alu-noir.webp' | asset_url }}"><img src="{{ '_solo-vertical-mat-alu-noir.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-vertical-mat-blanche.webp' | asset_url }}"><img src="{{ '_solo-vertical-mat-blanche.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-vertical-mat-noire.webp' | asset_url }}"><img src="{{ '_solo-vertical-mat-noire.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-vertical-mat-chene.webp' | asset_url }}"><img src="{{ '_solo-vertical-mat-chene.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-vertical-brillant-chassis.webp' | asset_url }}"><img src="{{ '_solo-vertical-brillant-chassis.webp' | asset_url }}" loading="lazy"></button>
            <button class="product__thumbnail" data-image-src="{{ '_solo-vertical-brillant-alu-noir.webp' | asset_url }}"><img src="{{ '_solo-vertical-brillant-alu-noir.webp' | asset_url }}" loading="lazy"></button>
