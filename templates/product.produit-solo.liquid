<script>
  // S'assurer que le formulaire fonctionne correctement
  document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('product-form-solo');
    const variantInput = form ? form.querySelector('input[name="id"]') : null;
    const submitButton = form ? form.querySelector('[type="submit"]') : null;
    const productFormElement = document.querySelector('product-form');

    // S'assurer que l'input n'est pas disabled et a une valeur
    if (variantInput) {
      variantInput.disabled = false;
      if (!variantInput.value) {
        variantInput.value = '{{ product.selected_or_first_available_variant.id }}';
      }
    }

    // S'assurer que le bouton n'est pas disabled
    if (submitButton) {
      submitButton.disabled = false;
      submitButton.removeAttribute('disabled');
      submitButton.removeAttribute('aria-disabled');
    }

    // Écouter la soumission du formulaire
    if (form) {
      form.addEventListener('submit', function (e) {
      });
    }

    // Forcer la soumission quand on clique sur le bouton ou ses enfants
    document.addEventListener(
      'click',
      function (e) {
        const button = e.target.closest('.product-form__submit');
        if (button) {
          e.preventDefault();
          e.stopPropagation();

          // Récupérer le formulaire
          const form = document.getElementById('product-form-solo');
          const variantId = form ? form.querySelector('input[name="id"]').value : null;
          const quantity = form ? form.querySelector('input[name="quantity"]')?.value || 1 : 1;

          if (!variantId) {
            return;
          }

          // ===== VALIDATION DES CHAMPS OBLIGATOIRES =====
          const requiredFields = [
            { id: 'format-oeuvre-custom', label: 'Format de l\'œuvre' },
            { id: 'matiere-support-custom', label: 'Matière du support' },
            { id: 'encadrement-oeuvre-custom', label: 'Encadrement de l\'œuvre' },
            { id: 'nom-prenom', label: 'Nom & Prénom' },
            { id: 'date-naissance', label: 'Date de naissance' },
            { id: 'heure-naissance', label: 'Heure exacte de naissance' },
            { id: 'lieu-naissance', label: 'Lieu de naissance' },
          ];

          let isValid = true;
          let firstInvalidField = null;

          // Retirer les erreurs précédentes
          requiredFields.forEach(function (field) {
            const input = document.getElementById(field.id);
            if (input) {
              input.classList.remove('custom-form__input--error');
              // Chercher le message d'erreur dans le container parent
              const fieldContainer = input.closest('.custom-form__field');
              const errorMsg = fieldContainer
                ? fieldContainer.querySelector('.custom-form__error-message')
                : input.parentElement.querySelector('.custom-form__error-message');
              if (errorMsg) errorMsg.remove();
            }
          });

          // Vérifier chaque champ
          requiredFields.forEach(function (field) {
            const input = document.getElementById(field.id);
            // ✅ Ignorer les champs désactivés (checkbox "Je ne sais pas" cochée)
            // Pour les select, vérifier si value est vide ou si c'est l'option disabled
            const isEmpty = input && !input.disabled && (
              (input.tagName === 'SELECT' && (!input.value || input.value === '')) ||
              (input.tagName !== 'SELECT' && !input.value.trim())
            );
            
            if (isEmpty) {
              isValid = false;
              input.classList.add('custom-form__input--error');

              // Ajouter un message d'erreur - trouver le bon parent (custom-form__field)
              const errorMsg = document.createElement('span');
              errorMsg.className = 'custom-form__error-message';
              errorMsg.textContent = 'Ce champ est obligatoire';
              errorMsg.style.cssText = 'color: #e74c3c; font-size: 12px; display: block; margin-top: 4px;';

              // Trouver le container .custom-form__field pour ajouter l'erreur après le champ/wrapper
              const fieldContainer = input.closest('.custom-form__field');
              if (fieldContainer) {
                fieldContainer.appendChild(errorMsg);
              } else {
                input.parentElement.appendChild(errorMsg);
              }

              if (!firstInvalidField) firstInvalidField = input;
            }
          });

          if (!isValid) {
            // Scroll vers le premier champ invalide
            if (firstInvalidField) {
              firstInvalidField.scrollIntoView({ behavior: 'smooth', block: 'center' });
              firstInvalidField.focus();
            }
            return;
          }
          // ===== FIN VALIDATION =====

          // Ajouter la classe loading
          button.classList.add('loading');
          button.setAttribute('aria-disabled', 'true');

          // Collecter les propriétés personnalisées du formulaire
          const formatSelect = document.getElementById('format-oeuvre-custom');
          const matiereSelect = document.getElementById('matiere-support-custom');
          const encadrementSelect = document.getElementById('encadrement-oeuvre-custom');
          const nomInput = document.getElementById('nom-prenom');
          const dateInput = document.getElementById('date-naissance');
          const heureInput = document.getElementById('heure-naissance');
          const lieuInput = document.getElementById('lieu-naissance');
          const emailInput = document.getElementById('email');
          const telephoneInput = document.getElementById('telephone');
          const typeRadio = document.querySelector('input[name="type-oeuvre"]:checked');
          const demandesTextarea = document.getElementById('demandes-particulieres');

          const properties = {};
          if (formatSelect) properties["Format de l'œuvre"] = formatSelect.options[formatSelect.selectedIndex].text;
          if (matiereSelect) properties['Matière du support'] = matiereSelect.options[matiereSelect.selectedIndex].text;
          if (encadrementSelect)
            properties["Encadrement de l'œuvre"] = encadrementSelect.options[encadrementSelect.selectedIndex].text;
          if (nomInput && nomInput.value) properties['Nom & Prénom'] = nomInput.value;
          
          // ✅ Vérifier les checkboxes "Je ne sais pas" pour les champs de naissance
          const unknownDateCheckbox = document.getElementById('unknown-date-naissance');
          const unknownHeureCheckbox = document.getElementById('unknown-heure-naissance');
          const unknownLieuCheckbox = document.getElementById('unknown-lieu-naissance');
          
          // Date de naissance
          if (unknownDateCheckbox && unknownDateCheckbox.checked) {
            properties['Date de naissance'] = 'Je ne sais pas';
          } else if (dateInput && dateInput.value) {
            properties['Date de naissance'] = dateInput.value;
          }
          
          // Heure de naissance
          if (unknownHeureCheckbox && unknownHeureCheckbox.checked) {
            properties['Heure de naissance'] = 'Je ne sais pas';
          } else if (heureInput && heureInput.value) {
            properties['Heure de naissance'] = heureInput.value;
          }
          
          // Lieu de naissance
          if (unknownLieuCheckbox && unknownLieuCheckbox.checked) {
            properties['Lieu de naissance'] = 'Je ne sais pas';
          } else if (lieuInput && lieuInput.value) {
            properties['Lieu de naissance'] = lieuInput.value;
          }
          if (typeRadio) {
            if (typeRadio.value === 'siderale') {
              properties["Type d'œuvre"] = 'Œuvre Sidérale';
            } else if (typeRadio.value === 'tropicale') {
              properties["Type d'œuvre"] = 'Œuvre Tropicale';
            } else if (typeRadio.value === 'je-ne-sais-pas') {
              properties["Type d'œuvre"] = 'Je ne sais pas';
            }
          }
          if (demandesTextarea && demandesTextarea.value) properties['Demandes particulières'] = demandesTextarea.value;

          // Envoyer la requête pour ajouter au panier
          const formData = {
            items: [
              {
                id: parseInt(variantId),
                quantity: parseInt(quantity),
                properties: properties,
              },
            ],
          };

          // ===== ENVOI VERS GOOGLE SHEETS =====
          const GOOGLE_SHEETS_WEBHOOK = 'https://script.google.com/macros/s/AKfycbxeyFuzzUs4jVK6CZoq_AL3UPInDUI728DW6RTHM2kgJ9FkdLD-3qyZXPfhKGnm7w/exec';
          
          // Récupérer le prix dynamique de la variante sélectionnée
          const currentPriceElement = document.querySelector('#price-solo .price-item--regular') || document.querySelector('#price-solo .price-item');
          const currentPrice = currentPriceElement ? currentPriceElement.textContent.trim().replace(/[^\d,\.]/g, '') : '{{ product.price | money_without_currency }}';
          
          const googleSheetsData = {
            soloDuo: 'Solo',
            prix: currentPrice,
            sideralTropical: properties["Type d'œuvre"] || '',
            nomPrenom1: nomInput ? nomInput.value : '',
            email: emailInput ? emailInput.value : '',
            telephone: telephoneInput ? telephoneInput.value : '',
            dateNaissance1: (unknownDateCheckbox && unknownDateCheckbox.checked) ? 'Je ne sais pas' : (dateInput ? dateInput.value : ''),
            heureNaissance1: (unknownHeureCheckbox && unknownHeureCheckbox.checked) ? 'Je ne sais pas' : (heureInput ? heureInput.value : ''),
            lieuNaissance1: (unknownLieuCheckbox && unknownLieuCheckbox.checked) ? 'Je ne sais pas' : (lieuInput ? lieuInput.value : ''),
            demandeParticuliere: demandesTextarea ? demandesTextarea.value : '',
            formatOeuvre: formatSelect ? formatSelect.options[formatSelect.selectedIndex].text : '',
            matiereSupport: matiereSelect ? matiereSelect.options[matiereSelect.selectedIndex].text : '',
            encadrement: encadrementSelect ? encadrementSelect.options[encadrementSelect.selectedIndex].text : ''
          };

          // 🐛 DEBUG: Afficher les données envoyées au Google Sheet
          console.log('📊 Données envoyées au Google Sheet:', googleSheetsData);

          // Envoyer vers Google Sheets en premier (mode no-cors, non bloquant)
          fetch(GOOGLE_SHEETS_WEBHOOK, {
            method: 'POST',
            mode: 'no-cors',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(googleSheetsData)
          })
          .then(function() {
            console.log('Données Solo envoyées vers Google Sheets');
          })
          .catch(function(error) {
            console.error('Erreur envoi Google Sheets:', error);
          });
          // ===== FIN ENVOI GOOGLE SHEETS =====

          // Envoyer la requête pour ajouter au panier
          fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
          })
            .then((response) => response.json())
            .then((data) => {
              console.log('Ajouté au panier:', data);

              // Ouvrir le cart drawer
              const cartDrawer = document.querySelector('cart-drawer');
              if (cartDrawer) {
                // Rafraîchir le drawer et l'ouvrir
                fetch('/?sections=cart-drawer,cart-icon-bubble')
                  .then((res) => res.json())
                  .then((sections) => {
                    // Mettre à jour le contenu du drawer
                    const drawerHTML = sections['cart-drawer'];
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(drawerHTML, 'text/html');
                    const newDrawerInner = doc.querySelector('.drawer__inner');
                    const currentDrawerInner = cartDrawer.querySelector('.drawer__inner');
                    if (newDrawerInner && currentDrawerInner) {
                      currentDrawerInner.innerHTML = newDrawerInner.innerHTML;
                    }

                    // Mettre à jour l'icône du panier
                    const iconHTML = sections['cart-icon-bubble'];
                    const iconDoc = parser.parseFromString(iconHTML, 'text/html');
                    const newIcon = iconDoc.querySelector('.shopify-section');
                    const currentIcon = document.getElementById('cart-icon-bubble');
                    if (newIcon && currentIcon) {
                      currentIcon.innerHTML = newIcon.innerHTML;
                    }

                    // Retirer la classe is-empty si besoin
                    cartDrawer.classList.remove('is-empty');

                    // Ouvrir le drawer avec la méthode native
                    if (typeof cartDrawer.open === 'function') {
                      cartDrawer.open();
                    } else {
                      // Fallback si la méthode n'existe pas
                      cartDrawer.classList.add('animate', 'active');
                      document.body.classList.add('overflow-hidden');
                    }
                  });
              } else {
                // Rediriger vers le panier si pas de drawer
                window.location.href = '/cart';
              }
            })
            .catch((error) => {
              console.error('Erreur ajout panier:', error);
              alert("Erreur lors de l'ajout au panier. Veuillez réessayer.");
            })
            .finally(() => {
              button.classList.remove('loading');
              button.removeAttribute('aria-disabled');
            });
        }
      },
      true
    ); // capture phase pour intercepter avant l'app tierce
  });
</script>

