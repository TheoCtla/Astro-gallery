<script>
document.addEventListener('DOMContentLoaded', function() {
  const thumbs = document.querySelectorAll('.product__thumbnail');
  const mainDisplay = document.querySelector('.product__media-item');
  const lightbox = document.getElementById('image-lightbox-solo');
  const lightboxImage = lightbox ? lightbox.querySelector('.image-lightbox__image') : null;

  // Sélecteurs
  const formatSelect = document.getElementById('format-oeuvre-custom');
  const matiereSelect = document.getElementById('matiere-support-custom');
  const encadrementSelect = document.getElementById('encadrement-oeuvre-custom');

  // Déplacer la lightbox dans le body pour éviter les problèmes de z-index/transform
  if (lightbox && lightbox.parentNode !== document.body) {
    document.body.appendChild(lightbox);
  }

  // Fonction pour ouvrir la lightbox
  function openLightbox(imageSrc) {
    if (lightbox && lightboxImage) {
      lightboxImage.src = imageSrc;
      lightbox.style.display = 'flex';
      document.body.classList.add('lightbox-open');
    }
  }

  // Fonction pour fermer la lightbox
  function closeLightbox() {
    if (lightbox) {
      lightbox.style.display = 'none';
      document.body.classList.remove('lightbox-open');
    }
  }

  // Attacher les handlers de fermeture de la lightbox
  if (lightbox) {
    const closeBtn = lightbox.querySelector('.image-lightbox__close');
    const overlay = lightbox.querySelector('.image-lightbox__overlay');

    // Fermer avec le bouton X
    if (closeBtn) {
      closeBtn.addEventListener('click', closeLightbox);
    }

    // Fermer en cliquant sur l'overlay
    if (overlay) {
      overlay.addEventListener('click', closeLightbox);
    }

    // Fermer avec Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && lightbox.style.display === 'flex') {
        closeLightbox();
      }
    });
  }

  // Attacher le clic sur l'image principale pour le zoom
  function attachImageClickHandler() {
    const mainImage = mainDisplay.querySelector('.product__main-image');
    if (mainImage) {
      // Nettoyage des anciens listeners pour éviter doublons (optionnel si reset innerHTML)
      mainImage.onclick = function(e) {
        e.preventDefault();
        openLightbox(this.src);
      };
    }
  }

  // Attacher au chargement initial
  attachImageClickHandler();

  // Gestion du clic sur les miniatures
  thumbs.forEach(thumb => {
    thumb.addEventListener('click', function(e) {
      e.preventDefault();
      
      thumbs.forEach(t => t.classList.remove('active'));
      this.classList.add('active');

      if (this.classList.contains('js-thumb-video')) {
        const videoUrl = this.getAttribute('data-video-url');
        mainDisplay.innerHTML = `
          <video id="main-product-video-solo" autoplay loop muted playsinline style="width: 100%; height: auto;">
            <source src="${videoUrl}" type="video/mp4">
          </video>`;
      } else {
        const imgSrc = this.getAttribute('data-image-src');
        mainDisplay.innerHTML = `<img src="${imgSrc}" class="product__main-image" id="main-product-image-solo" style="width: 100%; height: auto; cursor: zoom-in;">`;
        attachImageClickHandler();
      }
    });
  });

  // --- LOGIQUE COMBINATOIRE (Copie adaptée de DUO) ---
  function updateSoloImage() {
    const format = formatSelect ? formatSelect.value : "";
    const matiere = matiereSelect ? matiereSelect.value : "";
    const encadrement = encadrementSelect ? encadrementSelect.value : "";
    
    console.log('Update Solo Image - Format:', format, 'Matiere:', matiere, 'Encadrement:', encadrement);

    let targetImage = '';

    // CAS 1 : Tout vide -> Rien
    if (format === "" && matiere === "" && encadrement === "") {
        return; 
    }

    // PRIORITY 1 : Combinaison complète
    if (format !== "" && matiere !== "" && encadrement !== "") {
        
        // --- ROND ---
        if (format === 'ronde-40x40') {
             if (matiere === 'alu-dibond') {
                 if (encadrement === 'chassis') targetImage = "{{ '_solo-ronde-mat-chassis.webp' | asset_url }}";
                 // Pas d'autres cadres pour Alu Rund
             } else if (matiere === 'plexi-brillant') {
                 if (encadrement === 'chassis') targetImage = "{{ '_solo-ronde-brillant-chassis.webp' | asset_url }}";
                 // Pas d'autres cadres pour Plexi Rund
             }
        }
        
        // --- CARRE ---
        else if (format === 'carree-40x40') {
            if (matiere === 'alu-dibond') {
                if (encadrement === 'chassis') targetImage = "{{ '_solo-carre-mat-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_solo-carre-mat-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_solo-carre-mat-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_solo-carre-mat-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_solo-carre-mat-chene.webp' | asset_url }}";
            } else if (matiere === 'plexi-brillant') {
                if (encadrement === 'chassis') targetImage = "{{ '_solo-carre-brillant-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_solo-carre-brillant-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_solo-carre-brillant-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_solo-carre-brillant-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_solo-carre-brillant-chene.webp' | asset_url }}";
            }
        }

        // --- RECTANGLE VERTICAL ---
        else if (format === 'rectangle-vertical-35x50') {
             if (matiere === 'alu-dibond') {
                if (encadrement === 'chassis') targetImage = "{{ '_solo-vertical-mat-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_solo-vertical-mat-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_solo-vertical-mat-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_solo-vertical-mat-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_solo-vertical-mat-chene.webp' | asset_url }}";
            } else if (matiere === 'plexi-brillant') {
                if (encadrement === 'chassis') targetImage = "{{ '_solo-vertical-brillant-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_solo-vertical-brillant-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_solo-vertical-brillant-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_solo-vertical-brillant-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_solo-vertical-brillant-chene.webp' | asset_url }}";
            }
        }
        
        // --- RECTANGLE HORIZONTAL ---
        else if (format === 'rectangle-horizontal-50x35') {
             if (matiere === 'alu-dibond') {
                if (encadrement === 'chassis') targetImage = "{{ '_solo-horizontal-mat-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_solo-horizontal-mat-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_solo-horizontal-mat-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_solo-horizontal-mat-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_solo-horizontal-mat-chene.webp' | asset_url }}";
            } else if (matiere === 'plexi-brillant') {
                if (encadrement === 'chassis') targetImage = "{{ '_solo-horizontal-brillant-chassis.webp' | asset_url }}";
                else if (encadrement === 'box-alu-noir') targetImage = "{{ '_solo-horizontal-brillant-alu-noir.webp' | asset_url }}";
                else if (encadrement === 'box-blanc') targetImage = "{{ '_solo-horizontal-brillant-blanche.webp' | asset_url }}";
                else if (encadrement === 'box-noir') targetImage = "{{ '_solo-horizontal-brillant-noire.webp' | asset_url }}";
                else if (encadrement === 'box-chene') targetImage = "{{ '_solo-horizontal-brillant-chene.webp' | asset_url }}";
            }
        }
    }

    // PRIORITY 2 : Format + Matière (Encadrement vide)
    else if (format !== "" && matiere !== "" && encadrement === "") {
         if (format === 'ronde-40x40') {
             if (matiere === 'alu-dibond') targetImage = "{{ '_solo-ronde-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_solo-ronde-brillant-chassis.webp' | asset_url }}";
         }
         else if (format === 'carree-40x40') {
             if (matiere === 'alu-dibond') targetImage = "{{ '_solo-carre-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_solo-carre-brillant-chassis.webp' | asset_url }}";
         }
         else if (format === 'rectangle-vertical-35x50') {
             if (matiere === 'alu-dibond') targetImage = "{{ '_solo-vertical-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_solo-vertical-brillant-chassis.webp' | asset_url }}";
         }
         else if (format === 'rectangle-horizontal-50x35') {
             if (matiere === 'alu-dibond') targetImage = "{{ '_solo-horizontal-mat-chassis.webp' | asset_url }}";
             else if (matiere === 'plexi-brillant') targetImage = "{{ '_solo-horizontal-brillant-chassis.webp' | asset_url }}";
         }
    }

    // PRIORITY 3 : Format uniquement
    else if (format !== "") {
        switch(format) {
            case 'ronde-40x40':
                 targetImage = "{{ '_solo-ronde-mat-chassis.webp' | asset_url }}"; 
                 break;
            case 'carree-40x40':
                 targetImage = "{{ '_solo-carre-mat-chassis.webp' | asset_url }}";
                 break;
            case 'rectangle-vertical-35x50':
                 targetImage = "{{ '_solo-vertical-mat-chassis.webp' | asset_url }}";
                 break;
             case 'rectangle-horizontal-50x35':
                 targetImage = "{{ '_solo-horizontal-mat-chassis.webp' | asset_url }}";
                 break;
        }
    }

    // Application de l'image si trouvée
    if (targetImage) {
        console.log('Setting target image Solo:', targetImage);
        if (mainDisplay) {
            mainDisplay.innerHTML = `<img src="${targetImage}" class="product__main-image" id="main-product-image-solo" style="width: 100%; height: auto; cursor: zoom-in;">`;
            attachImageClickHandler();
            
            // Highlight thumbnail
            thumbs.forEach(t => t.classList.remove('active'));
            const matchingThumb = Array.from(thumbs).find(t => {
                const thumbSrc = t.getAttribute('data-image-src');
                return thumbSrc && (thumbSrc.includes(targetImage) || targetImage.includes(thumbSrc));
            });
            if (matchingThumb) matchingThumb.classList.add('active');
        }
    }
  }

  // Listeners
  if (formatSelect) formatSelect.addEventListener('change', updateSoloImage);
  if (matiereSelect) matiereSelect.addEventListener('change', updateSoloImage);
  if (encadrementSelect) encadrementSelect.addEventListener('change', updateSoloImage);
});
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
  const carousel = document.getElementById('thumbnail-carousel-solo');
  const upBtn = document.querySelector('.thumb-nav-up');
  const downBtn = document.querySelector('.thumb-nav-down');
  
  if (carousel && upBtn && downBtn) {
    const scrollAmount = 150; 

    // Garde le scroll fluide pour les boutons (très bien pour les clics)
    upBtn.addEventListener('click', function() {
      if (window.innerWidth < 990) {
          carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      } else {
          carousel.scrollBy({ top: -scrollAmount, behavior: 'smooth' });
      }
    });

    downBtn.addEventListener('click', function() {
      if (window.innerWidth < 990) {
          carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      } else {
          carousel.scrollBy({ top: scrollAmount, behavior: 'smooth' });
      }
    });


  }
});
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Logic specifically for mobile/tablet devices
    if (window.innerWidth < 990) {
      const sentinel = document.getElementById('mobile-sticky-sentinel');
      const stickyHeader = document.querySelector('.product__media-wrapper');
      
      if (sentinel && stickyHeader) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            // When sentinel scrolls out of view (top < 0), we are stuck
            if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
              stickyHeader.classList.add('is-stuck');
            } else {
              stickyHeader.classList.remove('is-stuck');
            }
          });
        }, { threshold: 0 });
        
        observer.observe(sentinel);
      }

      // Hide carousel on scroll (mobile only)
      if (stickyHeader) {
        window.addEventListener('scroll', function() {
          if (window.scrollY > 20) { // Threshold de 20px pour éviter les micros-mouvements
            stickyHeader.classList.add('hide-carousel');
          } else {
            stickyHeader.classList.remove('hide-carousel');
          }
        }, { passive: true });
      }
    }
  });
</script>
