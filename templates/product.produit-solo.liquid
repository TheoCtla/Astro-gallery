<script>
  document.addEventListener('DOMContentLoaded', function () {
    // ===== CONNEXION DES VARIANTES =====
    // Ce script détecte les sélections de l'utilisateur et met à jour le variant ID et le prix

    const variantsData = JSON.parse(document.getElementById('product-variants-json').textContent);
    const formatSelect = document.getElementById('format-oeuvre-custom');
    const matiereSelect = document.getElementById('matiere-support-custom');
    const encadrementSelect = document.getElementById('encadrement-oeuvre-custom');
    const variantInput = document.querySelector('#product-form-solo input[name="id"]');
    const priceElement = document.querySelector('#price-solo .price-item--regular');

    // Mapping des valeurs du formulaire vers les noms Shopify
    const formatMapping = {
      'ronde-40x40': 'Ronde (40 x 40)',
      'ronde-50x50': 'Ronde (50 x 50)',
      'carree-40x40': 'Carré (40 x 40)',
      'carree-50x50': 'Carré (50 x 50)',
      'rectangle-vertical-35x50': 'Rectangulaire vertical (35 x 50)',
      'rectangle-vertical-50x70': 'Rectangulaire vertical (50 x 70)',
      'rectangle-horizontal-50x35': 'Rectangulaire horizontal (50 x 35)',
      'rectangle-horizontal-70x50': 'Rectangulaire horizontal (70 x 50)',
    };

    const matiereMapping = {
      'alu-dibond': 'Alu dibond',
      'plexi-brillant': "Plexi'art",
      'plexi-mat': "PlexiI'art mat anti-reflet", // Note: double I dans Shopify (typo dans les données)
    };

    const encadrementMapping = {
      'attache-metal': 'Attache métal',
      chassis: 'Chassis',
      slim: 'Slim',
      'box-noir': 'Caisse Américaine Noir',
      'box-alu-noir': 'Caisse Américaine Alu Noir',
      'box-blanc': 'Caisse Américaine Blanche',
      'box-chene': 'Caisse Américaine Chêne Naturel',
    };

    function findMatchingVariant() {
      if (!formatSelect || !matiereSelect || !encadrementSelect) {
        console.log('Selects non trouvés');
        return null;
      }

      const formatValue = formatMapping[formatSelect.value];
      const matiereValue = matiereMapping[matiereSelect.value];
      const encadrementValue = encadrementMapping[encadrementSelect.value];

      if (!formatValue || !matiereValue || !encadrementValue) {
        return null;
      }
      
      console.log('🔍 Recherche variante pour:', { formatValue, matiereValue, encadrementValue });

      let targetEncadrement = encadrementValue;

      // CORRECTION SPECIFIQUE: Pour le format Rond, "Chassis" dans l'UI correspond à "Attache métal" dans les variantes Shopify
      if (formatValue.toLowerCase().includes('ronde') && encadrementValue.toLowerCase() === 'chassis') {
          console.log('🔄 Remapping Chassis -> Attache métal pour le format Rond');
          targetEncadrement = 'Attache métal';
      }

      // DEBUG: Afficher toutes les variantes pour voir les options disponibles
      console.log('📋 Liste complète des variantes disponibles:', variantsData.map(v => ({
          title: v.title,
          options: v.options,
          price: v.price
      })));

      // Chercher la variante correspondante
      const matchingVariant = variantsData.find(function (variant) {
        // 1. Essai de correspondance EXACTE sur les options (sensible à la casse)
        const exactMatchStrict =
          (variant.option1 === formatValue ||
            variant.option1 === matiereValue ||
            variant.option1 === targetEncadrement) &&
          (variant.option2 === formatValue ||
            variant.option2 === matiereValue ||
            variant.option2 === targetEncadrement) &&
          (variant.option3 === formatValue || variant.option3 === matiereValue || variant.option3 === targetEncadrement);
          
        if (exactMatchStrict) return true;

        // 2. Essai de correspondance EXACTE sur les options (INSENSIBLE à la casse)
        const formatLower = formatValue.toLowerCase();
        const matiereLower = matiereValue.toLowerCase();
        const encadrementLower = targetEncadrement.toLowerCase();
        
        const opts = variant.options.map(o => o.toLowerCase());
        const exactMatchLoose = opts.includes(formatLower) && opts.includes(matiereLower) && opts.includes(encadrementLower);
        
        if (exactMatchLoose) return true;
        
        // 3. Fallback : Correspondance partielle (dangereux mais parfois nécessaire si les noms diffèrent légèrement)
        // On vérifie que TOUS les termes recherchés sont présents dans les options ou le titre
        const allTermsPresent = 
            (variant.title.toLowerCase().includes(formatLower) || variant.options.some(o => o.toLowerCase().includes(formatLower))) &&
            (variant.title.toLowerCase().includes(matiereLower) || variant.options.some(o => o.toLowerCase().includes(matiereLower))) &&
            (variant.title.toLowerCase().includes(encadrementLower) || variant.options.some(o => o.toLowerCase().includes(encadrementLower)));
            
        return allTermsPresent;
      });

      if (matchingVariant) {
          console.log('✅ Variante trouvée:', matchingVariant.title, 'ID:', matchingVariant.id, 'Prix:', matchingVariant.price);
      } else {
          console.warn('❌ Aucune variante trouvée pour:', { formatValue, matiereValue, encadrementValue });
      }
      return matchingVariant;
    }

    function updateVariant() {
      const variant = findMatchingVariant();

      if (variant) {
        // Mettre à jour l'input variant ID
        if (variantInput) {
          variantInput.value = variant.id;
          console.log('Variant ID mis à jour:', variant.id);
        }

        // Mettre à jour le prix affiché
        if (priceElement) {
          const formattedPrice = (variant.price / 100).toLocaleString('fr-FR', {
            style: 'currency',
            currency: 'EUR',
          });
          priceElement.textContent = formattedPrice;
          console.log('Prix mis à jour:', formattedPrice);
        }

        // Mettre à jour aussi via le data attribute si utilisé
        const priceWrapper = document.querySelector('#price-solo');
        if (priceWrapper) {
          const allPrices = priceWrapper.querySelectorAll('.price-item');
          allPrices.forEach(function (el) {
            const formattedPrice = (variant.price / 100).toLocaleString('fr-FR', {
              style: 'currency',
              currency: 'EUR',
            });
            el.textContent = formattedPrice;
          });
        }

        // Mettre à jour le prix à côté du bouton "Ajouter au panier"
        const priceButtonsWrapper = document.querySelector('#price-display-buttons');
        if (priceButtonsWrapper) {
          const buttonPrices = priceButtonsWrapper.querySelectorAll('.price-item');
          buttonPrices.forEach(function (el) {
            const formattedPrice = (variant.price / 100).toLocaleString('fr-FR', {
              style: 'currency',
              currency: 'EUR',
            });
            el.textContent = formattedPrice;
          });
        }
      } else {
      }
    }

    // Écouter les changements sur tous les selects
    if (formatSelect) {
      formatSelect.addEventListener('change', updateVariant);
      formatSelect.addEventListener('input', updateVariant);
    }
    if (matiereSelect) {
      matiereSelect.addEventListener('change', updateVariant);
      matiereSelect.addEventListener('input', updateVariant);
    }
    if (encadrementSelect) {
      encadrementSelect.addEventListener('change', updateVariant);
      encadrementSelect.addEventListener('input', updateVariant);
    }

    // Mise à jour initiale
    updateVariant();

    // ===== FILTRAGE DYNAMIQUE DES ENCADREMENTS =====
    // Règles :
    // 1. Format Ronde : seulement Attache métal et Chassis
    // 2. Chassis : désactivé si Alu Dibond
    // 3. Slim : désactivé si Plexi'Art ou Plexi'Art Mat

    // Encadrements disponibles par format
    const encadrementsForRonde = ['chassis'];
    const encadrementsForCarre = [
      'attache-metal',
      'chassis',
      'slim',
      'box-noir',
      'box-alu-noir',
      'box-blanc',
      'box-chene',
    ];

    function filterEncadrements() {
      if (!formatSelect || !matiereSelect || !encadrementSelect) return;

      const format = formatSelect.value;
      const matiere = matiereSelect.value;
      const currentEncadrement = encadrementSelect.value;

      // Déterminer si c'est un format rond
      // Note: 'ronde-40x40' starts with 'ronde'
      const isRonde = format.startsWith('ronde');
      
      // Déterminer les encadrements disponibles selon le format
      const availableEncadrements = isRonde ? encadrementsForRonde : encadrementsForCarre;

      // Parcourir toutes les options d'encadrement
      const options = encadrementSelect.querySelectorAll('option');
      let firstAvailable = null;
      let currentIsAvailable = false;

      options.forEach(function (option) {
        const value = option.value;
        let isAvailable = false;
        
        // Toujours autoriser le placeholder vide mais le désactiver
        if (value === "") {
            option.disabled = true;
            option.style.display = '';
            if (value === currentEncadrement) {
                currentIsAvailable = true;
            }
            return;
        } else {
            isAvailable = availableEncadrements.includes(value);

            // Appliquer les règles supplémentaires basées sur la matière
            if (isAvailable) {
               // Règle : Slim désactivé si Plexi'Art ou Plexi'Art Mat
               if (value === 'slim' && (matiere === 'plexi-brillant' || matiere === 'plexi-mat')) {
                 isAvailable = false;
               }
            }
        }

        // Appliquer la disponibilité
        option.disabled = !isAvailable;
        option.style.display = isAvailable ? '' : 'none';

        if (isAvailable && value !== "" && !firstAvailable) {
          firstAvailable = value;
        }
        if (value === currentEncadrement && isAvailable) {
          currentIsAvailable = true;
        }
      });

      // Si l'encadrement actuel n'est plus disponible, sélectionner le premier disponible
      if (!currentIsAvailable && firstAvailable && currentEncadrement !== "") {
        encadrementSelect.value = firstAvailable;
        // Trigger generic change event to update other listeners
        encadrementSelect.dispatchEvent(new Event('change'));
      }
      
      // Mettre à jour la variante après le filtrage
      updateVariant();
    }

    // Écouter les changements pour le filtrage
    if (formatSelect) {
      formatSelect.addEventListener('change', filterEncadrements);
    }
    if (matiereSelect) {
      matiereSelect.addEventListener('change', filterEncadrements);
    }

    // Filtrage initial au chargement
    filterEncadrements();
  });
</script>

